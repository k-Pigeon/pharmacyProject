		// 🔹 총 가격 & 할인 적용된 가격 계산
		function calculateTotalPrice() {
		    let totalPrice = 0; // 최종 계산값

		    // #table_body의 각 행을 반복하여 총 가격 계산
		    $("#table_body tr").each(function () {
		        let price = parseFloat($(this).find("#price").val()) || 0; // 가격
		        let inventory = parseFloat($(this).find(".inventory").val()) || 0; // 재고 수량

		        totalPrice += price * inventory;
		    });

		    // 할인 금액 가져오기
		    let discountTotal = parseFloat($(".clientName").val().replace(/,/g, "")) || 0;

		    // 할인 적용된 최종 가격 계산
		    let updatedTotalPrice = totalPrice - discountTotal;

		    // totalPrice가 0 이하로 내려가지 않도록 제한
		    if (updatedTotalPrice < 0) {
		        updatedTotalPrice = 0;
		    }

		    // 결과 반영 (숫자 포맷 적용)
		    $("#totalPrice").text(updatedTotalPrice.toLocaleString()); // 남은 가격
		    $("#generalPrice").val(totalPrice.toLocaleString()); // 총 가격
		}

		// 🔹 재고가 변할 때 `#generalPrice` 업데이트
		function updateGeneralPrice() {

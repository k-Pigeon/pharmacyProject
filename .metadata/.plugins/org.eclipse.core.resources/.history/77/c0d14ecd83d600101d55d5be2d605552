		function focusRightInRow($row, $fromInput, offset = 1) {
			  // 보이는 td만 대상으로
			  const $tds = $row.children('td:visible');
			  const fromIdx = $fromInput.closest('td:visible').index();  // 여기서도 :visible
			  const targetIdx = fromIdx + offset;

			  if (targetIdx < 0 || targetIdx >= $tds.length) return false;

			  const $target = $tds.eq(targetIdx)
			    .find('input, select, textarea')
			    .filter(':visible:enabled')
			    .first();

			  if ($target.length) {
			    $target.focus().select();
			    return true;
			  }
			  return false;
			}



$(document).on("keydown", "input", function (e) {
  const $currentInput = $(this);
  const $currentTd = $currentInput.closest("td:visible");
  const $currentTr = $currentInput.closest("tr:visible");

  const $visibleTds = $currentTr.children("td:visible");
  const visColIndex = $visibleTds.index($currentTd);

  let $targetInput = $();

  if(!$("#selTable").is(":visible")){
	  if (e.key === "ArrowUp") {
	    const $targetTr = $currentTr.prevAll("tr:visible").first();
	    if ($targetTr.length) {
	      $targetInput = $targetTr.children("td:visible").eq(visColIndex)
	        .find("input:visible:enabled").first();
	    }
	  } else if (e.key === "ArrowDown") {
	    const $tbody    = $currentTr.parent();
	    const $lastTr   = $tbody.children("tr:visible").last();
	    const $targetTr = $currentTr.nextAll("tr:visible").first();

	    if ($targetTr.length) {
	      if ($targetTr.is($lastTr)) {
	        // 👉 마지막 행이면 .medicineName으로 이동
	        $targetInput = $targetTr.find("input.medicineName:visible:enabled").first();
	      } else {
	        $targetInput = $targetTr.children("td:visible").eq(visColIndex)
	          .find("input:visible:enabled").first();
	      }
	    }
	  } else if (e.key === "ArrowLeft") {
	    const el = $currentInput.get(0);
	    if (el.selectionStart === 0 && visColIndex > 0) {
	      $targetInput = $visibleTds.eq(visColIndex - 1)
	        .find("input:visible:enabled").first();
	    }
	  } else if (e.key === "ArrowRight") {
	    const el = $currentInput.get(0);
	    if (el.selectionEnd === el.value.length && visColIndex < $visibleTds.length - 1) {
	      $targetInput = $visibleTds.eq(visColIndex + 1)
	        .find("input:visible:enabled").first();
	    }
	  } else if (e.key === "Enter") {
	    const $targetTr = $currentTr.nextAll("tr:visible").first();
	    if ($targetTr.length) {
	      $targetInput = $targetTr.children("td:visible").eq(visColIndex)
	        .find("input:visible:enabled").first();
	    }
	  } else {
	    return;
	  }
	}

	  

  if ($targetInput.length) {
    e.preventDefault();
    $("input").removeClass("inputCheckStyle");
    $targetInput.addClass("inputCheckStyle").focus().select();
  }
});

	

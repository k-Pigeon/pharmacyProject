		    $("#table_body tr").each(function () {
		        let price = parseFloat($(this).find("#price").val()) || 0; // 가격
		        let inventory = parseFloat($(this).find("#inventory").val()) || 0; // 재고 개수

		        totalGeneralPrice += price * inventory;
		    });

		    // 총 가격을 #generalPrice에 업데이트
		    $("#generalPrice").val(totalGeneralPrice.toLocaleString()); // 숫자 포맷 적용

		    // 할인 금액 적용하여 totalPrice 업데이트
		    let discountTotal = parseFloat($(".clientName").val().replace(/,/g, "")) || 0;
		    let updatedTotalPrice = totalGeneralPrice - discountTotal;

		    // totalPrice가 0 이하로 내려가지 않도록 제한
		    if (updatedTotalPrice < 0) {
		        updatedTotalPrice = 0;
		    }

		    // totalPrice 업데이트
		    $("#totalPrice").text(updatedTotalPrice.toLocaleString());
		}

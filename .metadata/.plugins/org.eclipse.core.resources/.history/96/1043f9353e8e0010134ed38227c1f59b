	                // 같은 제품들 찾기
	                const rows = Array.from(document.querySelectorAll('tr'));
	                const sameProducts = rows.filter(r => {
	                    return r.cells[2].textContent === medicineName;
	                });

	                // 유통기한이 가장 짧은 제품 찾기
	                let minExpiryRow = null;
	                let minExpiryDate = null;

	                sameProducts.forEach(r => {

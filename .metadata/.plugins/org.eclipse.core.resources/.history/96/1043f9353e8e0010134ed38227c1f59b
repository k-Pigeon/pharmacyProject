	        // 검색 실행 함수
	        function executeSearch() {
	            const searchValue = nameSearch.value.trim();

	            if (searchValue === "") {
	                alert("검색어를 입력해 주세요.");
	                return;
	            }

	            console.log("검색 실행됨 - 검색어:", searchValue);

	            // AJAX 요청
	            const xhr = new XMLHttpRequest();
	            xhr.open("POST", "getData.jsp", true);
	            xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");

	            xhr.onreadystatechange = function () {
	                if (xhr.readyState === 4) {
	                    if (xhr.status === 200) {
	                        console.log("AJAX 요청 성공");
	                        tableBody.innerHTML = xhr.responseText; // 검색 결과 표시
	                        updateRowColors();

	                        minExpiryRow = r;
	                    }
	                });

	                // 해당 제품 이름의 상태를 가져옴
	                const isHidden = toggleStates[medicineName] || false;

	                if (isHidden) {
	                    // 모든 제품 보이게 함
	                    sameProducts.forEach(r => {
	                        r.style.display = ''; // 모든 제품 보이기

	<script type="text/javascript">
	$(document).ready(function () {
		$(document).on("change", "#customDate", function (e) {
			  e.preventDefault();
			  const selectedDate = $("#customDate").val(); // 날짜 가져오기
			  // AJAX 요청
			  $.ajax({
			    type: "POST",
			    url: "customDate.jsp",
			    data: {
			      customDateVal: selectedDate // 날짜를 전송!
			    },
			    success: function (response) {
			      $("#inventory_list").html(response);
			    },
			    error: function (xhr) {
			      console.error("AJAX 오류:", xhr.status);
			    }
			  });
			});

		
		$("#formTeg .filter #nameSearch").on("mouseover", function(){
			$(this).addClass("searchFocus");
		}).on("mouseout", function(){
			$(this).removeClass("searchFocus");
		});
		
		flatpickr("#customDate", {
		    dateFormat: "Y-m-d", // 날짜 포맷 설정
		    theme: "material_blue", // 테마 설정 (커스텀 가능)
		  });
		
		//반품된 행들은 디자인 변경, 아닐경우 그대로.
		$(document).on('change', "#wrap .table_line #inventory_list tr td:eq(10) .returnProduct", function() {
    		const $row = $(this).closest('tr'); // 현재 클릭된 .returnProduct가 속한 <tr>
    		const returnProductValue = $(this).val();
    
    		if (returnProductValue === "반품됨") {
        		$row.css("opacity", "0.5"); // "반품됨"인 경우 글자를 흐리게 처리
    		} else {
        		$row.css("opacity", ""); // 기본 상태 유지
    		}
		});

		
		document.querySelector('.downloadBtn').addEventListener('click', function () {
            // HTML 테이블 가져오기
            var table = document.querySelector('.table_line');
            var workbook = XLSX.utils.table_to_book(table, { sheet: "Sheet1" });

            //날짜를 가져올 변수 기둥
            let today = new Date();   

            let year = today.getFullYear(); // 년도
            let month = today.getMonth() + 1;  // 월
            let date = today.getDate();  // 날짜
            
            // 엑셀 파일 다운로드
            XLSX.writeFile(workbook, year + '.' + month + '.' + date + '.xlsx');
        });
	    // 이벤트 위임 - 동적으로 추가된 버튼도 작동하게 함
	    $("#inventory_list").on("click", ".updateInfo", function (event) {
	        event.preventDefault(); // 기본 동작 방지


	        // 클릭한 행의 데이터 가져오기
	        var row = $(this).closest("tr");
	        var secondTdText = row.find("td:eq(2)").text().trim(); // 제품명
	        var eighthTdText = row.find("td:eq(5)").text().trim(); // 규격
	        var ninthTdText = row.find("td:eq(3)").text().trim();  // 유통기한

	        console.log("보낼 데이터:", secondTdText, eighthTdText, ninthTdText);

	        // AJAX 요청
	        $.ajax({
	            url: "dataUpdate.jsp",
	            type: "POST",
	            data: {
	                secondData: secondTdText,
	                eighthData: eighthTdText,
	                ninthData: ninthTdText
	            },
	            success: function (response) {
	                console.log("AJAX 성공:", response);

	                // AJAX 성공 후 페이지 이동
	                window.location.href = "editPage.jsp";
	            },
	            error: function (xhr, status, error) {
	                console.error("AJAX 오류:", error);
	                alert("데이터 전송 실패: " + error);
	            }
	        });
	    });
	});

	$('#inventory_list').on('click', ".deleteInfo", function(event) {
        event.preventDefault();  
        if (confirm('삭제하시겠습니까?')) {
            var row = $(this).closest("tr");
            var secondTdText = row.find("td:eq(2)").text();  // 2번째 td
            var eighthTdText = row.find("td:eq(5)").text();  // 8번째 td
            var ninthTdText = row.find("td:eq(3)").text();   // 9번째 td
            console.log(secondTdText, eighthTdText, ninthTdText);

            // 여러 행을 배열로 전송
            var dataArray = [
                {
                    secondData: secondTdText,
                    eighthData: eighthTdText,
                    ninthData: ninthTdText
                }
            ];

            $.ajax({
                url: 'datadelete.jsp',
                type: 'POST',
                contentType: "application/json",  // JSON 형식으로 전송 (중요)
                data: JSON.stringify(dataArray),  // 여러 데이터를 배열로 전송
                success: function(response) {
                    console.log('Data sent successfully');
                },
                error: function(xhr, status, error) {
                    console.error('Error fetching data:', error);
                }
            });
        } else {
            alert('NO');
        }
	});
		$(document).ready(function() {
			//가격 정렬
			$(".priceAscendingOrder").click(function() {
				sortTable(true); // 오름차순 정렬 함수 호출
			});
			$(".priceDescendingOrder").click(function() {
				sortTable(false); // 내림차순 정렬 함수 호출
			});
			//이름 정렬
			$(".nameAscendingOrder").click(function() {
				sortByName(true); // 이름을 오름차순으로 정렬하는 함수 호출
			});
			$(".nameDescendingOrder").click(function() {
				sortByName(false); // 이름을 내림차순으로 정렬하는 함수 호출
			});
			//재고 수량 정렬
			$(".invAscendingOrder").click(function() {
				sortByinv(true); // 이름을 오름차순으로 정렬하는 함수 호출
			});
			$(".invDescendingOrder").click(function() {
				sortByinv(false); // 이름을 내림차순으로 정렬하는 함수 호출
			});
			//일정 유통기한 확인 스크립트
			// 일정 유통기한 확인 스크립트
			$("#wrap #formTeg #deliveryDateCh").on("input",function() {
				var inputDate = new Date($(this).val()); // 사용자가 입력한 날짜 가져오기
				var today = new Date(); // 오늘 날짜 가져오기
				if (inputDate == "") {
					$("#wrap .table_line #inventory_list tr").show(); // 유통기한 선택이 없으면 전체 보여주기												}
				}
				if (!isNaN(inputDate)) {
					var inputYear = inputDate.getFullYear();
					var inputMonth = inputDate.getMonth(); // 월은 0부터 11까지이므로 주의
					var inputDay = inputDate.getDate(); // 일자 추가
					$("#wrap .table_line #inventory_list tr").each(function() {
						var dateText = $(this).find("td:eq(3)").text().trim(); // 8번째 셀(td)의 유통기한 텍스트 가져오기
						var date = new Date(dateText); // 유통기한을 Date 객체로 변환
						if (!isNaN(date)) {// 선택된 날짜가 오늘부터 이후 날짜인지 확인
							if (date >= today && date <= inputDate) {
								$(this).show();
							} else {
								$(this).hide();
							}
						} else {
							$(this).hide();
						}

<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>세트 만들기</title>
<link href="style.css" rel="stylesheet">
<style>
#popup #popup-table #popup-content tr:hover {
	background-color: #FAFAD2;
}
#wrap #table_input input[type=text]{
    height: 30px;
    width: 75%;
}
</style>
</head>
<body>
	<div id="wrap">
		<header>
			<jsp:include page="header.jsp"></jsp:include>
		</header>
		<h1
			style="position: absolute; display: block; text-align: center; width: 100%; margin-top: 80px;">세트
			만들기</h1>
		<table class="table_line" id="table_input"
			style="border-collapse: collapse; border-collapse: collapse; height: 45vh; margin-top: 200px;">
			<tr>
				<th colspan=2>단일 세트 이름</th>
				<td colspan=2><input type="text" id="setName" name="setName" required></td>
			</tr>
			<tr>
				<th colspan="4">제품 정보</th>
			</tr>
			<tr>
				<th>제품 이름</th>
				<th>사입 가격</th>
				<th>판매 가격</th>
				<th>규격</th>
			</tr>
			<tr>
				<td><input type="text" id="productName1" name="productName1" class="medicineName"></td>
				<td><input type="text" id="buyingPrice1" class="buyingPrice"></td>
				<td><input type="text"  class="price"></td>
				<td><input type="text" class="standard"></td>
			</tr>
			<tr>
        		<th colspan=2>사입 가격 총합</th>
        		<td colspan=2>
        			<input type="text" id="totalBuyingPrice">
        		</td>
        	</tr>
        	<tr>
        		<th colspan=2>판매 가격 총합</th>
        		<td colspan=2><input type="text"  id="totalSellingPrice"></td>
    		</tr>
    		<tr>
    			<td  colspan=4><input type="button" class="setMakeAjax" value="세트 추가"></td>
    		</tr>
		</table>
		<br>
	</div>
	<div id="popup" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background-color: white; border: 1px solid #ccc; z-index: 1000; box-shadow: 0px 0px 10px gray; min-width: 1500px; min-height: 30vh;">
		<h3 style="position: fixed; margin: 10px; width: 100%; text-align: center;">검색 결과</h3>
		<table id="popup-table" style="display: block; width: 100%; height: 50vh; border-collapse: collapse; margin-top: 50px; overflow: scroll;">
			<colgroup>
				<col style="width: 600px">
				<col style="width: 200px">
				<col style="width: 100px">
				<col style="width: 150px">
				<col style="width: 150px">
				<col style="width: 150px">
				<col style="width: 150px">
			</colgroup>
			<thead>
				<tr style="background-color: #f0f0f0;">
					<th style="border: 1px solid #ccc; padding: 5px;">제품명</th>
					<th style="border: 1px solid #ccc; padding: 5px;">회사명</th>
					<th style="border: 1px solid #ccc; padding: 5px;">재고</th>
					<th style="border: 1px solid #ccc; padding: 5px;">종류</th>
					<th style="border: 1px solid #ccc; padding: 5px;">일련번호</th>
					<th style="border: 1px solid #ccc; padding: 5px;">입고 날짜</th>
					<th style="border: 1px solid #ccc; padding: 5px;">유통기한</th>
					<th style="border: 1px solid #ccc; padding: 5px;">사입가격</th>
					<th style="border: 1px solid #ccc; padding: 5px;">구매가격</th>
				</tr>
			</thead>
			<tbody id="popup-content"></tbody>
		</table>
	</div>
	<script src="jquery-3.7.1.min.js"></script><script src="script.js"></script>
	<script>
		$(document).ready(function(){
		    $(".setMakeAjax").click(function () {
		        var setName = $("#setName").val();
		        var productName = $("#productName1").val();
		        var buyingPrice = $("#buyingPrice1").val();
		        var sellingPrice = $(".price").val();
		        var inventory = $(".inventory").val();

		        if (productName == "" || buyingPrice == "" || sellingPrice == "" || standard == "") {
		            alert("모든 값을 입력하세요.");
		            return;
		        }

		        $.ajax({
		            type: "POST",
		            url: "insertSet.jsp",
		            data: {
		                medicineName: productName,
		                Buyingprice: buyingPrice,
		                price: sellingPrice,
		                inventory: 1,  // 항상 1로 설정
		                saleInventory: standard // 규격 값을 saleInventory에 저장
		            },
		            success: function (response) {
		                alert("세트가 성공적으로 추가되었습니다.");
		                location.reload();
		            },
		            error: function () {
		                alert("오류가 발생했습니다.");
		            }
		        });
		    });
			$(".table_line").on("keydown", ".medicineName", function (e) {
		        if (e.key === "Enter") { // Enter 키 감지
		            e.preventDefault(); // 폼 제출 방지
		            let medicineName = $(this).val();
		            currentRow = $(this).closest('tr');

		            // 현재 포커스가 있는 행을 추적
		            currentRow = $(this).closest('tr'); // 현재 입력 필드가 속한 행

		            if (medicineName.trim() !== "") {
		                // Ajax 요청
		                $.ajax({
		                    url: "searchMedicine.jsp", // 데이터 검색 JSP
		                    method: "POST",
		                    data: { medicineName: medicineName }, // LIKE 검색 조건
		                    success: function (response) {
		                        $("#popup-content").html(response); // 결과를 테이블에 표시
		                        $("#popup").show(); // 팝업 표시
		                        currentRowIndex = -1;
		                    },
		                    error: function () {
		                        return false;
		                    }
		                });
		            }
		        }
		    });
			
		    $(document).on("click", function (e) {
		        if (!$(e.target).closest("#popup, .medicineName").length) {
		            $("#popup").hide();
		        }
		    });
		    $(document).on("keydown", function (e) {
		        if ($("#popup").is(":visible")) { // 팝업이 열려 있을 때만 동작
		            const rows = $("#popup-content .result-row");

		            if (e.key === "ArrowDown") { // ↓ 키
		                e.preventDefault();
		                if (currentRowIndex < rows.length - 1) {
		                    currentRowIndex++;
		                }
		            } else if (e.key === "ArrowUp") { // ↑ 키
		                e.preventDefault();
		                if (currentRowIndex > 0) {
		                    currentRowIndex--;
		                }
		            } else if (e.key === "Enter" && currentRowIndex >= 0) { // Enter 키로 선택된 행 처리
		                e.preventDefault();
		                const selectedRow = $(rows[currentRowIndex]); // 현재 강조된 행
		                populateFields(selectedRow.data()); // 선택된 데이터 채우기
		            }

		            // 강조 효과 업데이트
		            rows.removeClass("highlight"); // 모든 행의 강조 제거
		            if (currentRowIndex >= 0) {
		                $(rows[currentRowIndex]).addClass("highlight"); // 현재 선택된 행에 강조 추가
		            }
		        }
		    });
		    $(document).on("click", "#popup-content tr", function () {
		        let selectedRow = $(this);
		        let medicineName = selectedRow.find("td:eq(0)").text().trim(); // 첫 번째 컬럼 (제품명)
		        let buyingPrice = selectedRow.find("td:eq(7)").text().trim(); // 두 번째 컬럼 (사입 가격)
		        let sellingPrice = selectedRow.find("td:eq(8)").text().trim(); // 세 번째 컬럼 (판매 가격)

		        console.log(medicineName);
		        console.log(buyingPrice);
		        console.log(sellingPrice);
		        
		        
		        // 현재 입력 중이던 행에 값 채우기
		        currentRow.find(".medicineName").val(medicineName);
		        currentRow.find(".buyingPrice").val(buyingPrice);
		        currentRow.find(".price").val(sellingPrice);

		        $("#popup").hide(); // 팝업 숨기기
		    });
		    
		    function calculateTotal() {
	            let totalBuying = 0;
	            let totalSelling = 0;

	            $(".table_line tr").each(function() {
	                let buyingPrice = parseFloat($(this).find(".buyingPrice").val()) || 0;
	                let sellingPrice = parseFloat($(this).find(".price").val()) || 0;

	                totalBuying += buyingPrice;
	                totalSelling += sellingPrice;
	            });

	            $("#totalBuyingPrice").val(totalBuying.toLocaleString());
	            $("#totalSellingPrice").val(totalSelling.toLocaleString());
	        }

	        // 가격 입력할 때마다 계산
	        $(document).on("keyup", ".buyingPrice, .price", function() {
	            calculateTotal();
	        });

	        // 팝업에서 제품 선택 시 자동 합산 반영
	        $(document).on("click", "#popup-content tr", function () {
	            let selectedRow = $(this);
	            let buyingPrice = selectedRow.find("td:eq(7)").text().trim();
	            let sellingPrice = selectedRow.find("td:eq(8)").text().trim();

	            currentRow.find(".buyingPrice").val(buyingPrice);
	            currentRow.find(".sellingPrice").val(sellingPrice);

	            $("#popup").hide();
	            calculateTotal(); // 선택 후 합산 업데이트
	        });
	        
	        $(".setMakeAjax").on("click", function () {
	            let setName = $("#setName").val().trim();
	            let productList = [];
	            let totalBuying = 0;
	            let totalSelling = 0;

	            // 제품 정보 수집
	            $("#table_input tr").each(function (index) {
	                // 첫 번째 및 두 번째 행은 제품 정보가 아니므로 건너뜀
	                if (index < 3) return;

	                // 각 제품의 입력 필드 선택
	                let medicineNameInput = $(this).find(".medicineName");
	                let buyingPriceInput = $(this).find(".buyingPrice");
	                let sellingPriceInput = $(this).find(".price");

	                // 요소가 존재하는지 확인 후 값 추출
	                if (medicineNameInput.length > 0 && buyingPriceInput.length > 0 && sellingPriceInput.length > 0) {
	                    let medicineName = medicineNameInput.val().trim();
	                    let buyingPrice = parseFloat(buyingPriceInput.val()) || 0;
	                    let sellingPrice = parseFloat(sellingPriceInput.val()) || 0;

	                    // 총합 계산
	                    totalBuying += buyingPrice;
	                    totalSelling += sellingPrice;

	                    if (medicineName) { // 빈 값 제외
	                        productList.push({
	                            medicineName: medicineName,
	                            buyingPrice: buyingPrice,
	                            sellingPrice: sellingPrice
	                        });
	                    }
	                }
	            });

	            // AJAX로 보낼 데이터
	            let sendData = {
	                setName: setName,
	                products: productList,
	                totalBuyingPrice: totalBuying,
	                totalSellingPrice: totalSelling
	            };

	            // 데이터 확인
	            console.log("전송 데이터:", JSON.stringify(sendData, null, 2));

	            // AJAX 요청
	            $.ajax({
	                url: "setDataSave.jsp", // 데이터를 처리할 JSP 파일
	                type: "POST",
	                contentType: "application/json",
	                data: JSON.stringify(sendData),
	                success: function (response) {
	                    console.log("서버 응답:", response);
	                    alert("세트 정보가 성공적으로 저장되었습니다!");
	                },
	                error: function (xhr, status, error) {
	                    console.error("AJAX 오류:", error);
	                    alert("저장 중 오류가 발생했습니다.");
	                }
	            });
	        });


		});
	</script>
</body>
</html>

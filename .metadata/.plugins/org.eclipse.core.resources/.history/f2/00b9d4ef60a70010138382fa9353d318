	<script>
	$(document).ready(function () {
		$("#popup .closeMedicine").on("click", function(){
			$("#popup").hide();
		});
		function addNewRowWithToday() {
		    const $firstRow = $("#table_input .insertTR:first").clone(); // 첫 행 복제
		    const todayDate = new Date().toISOString().split('T')[0];
		    $firstRow.find(".receiptDate").val(todayDate);
		    $firstRow.find("input[type=text]").val('');
		    $firstRow.removeClass("focusRow");
		    $("#table_input .tableBody").append($firstRow);
		}
		$("#wrap .tableBody").on("click",".deleteTR", function(){
			if($("#wrap #table_input .insertTR").length == 1){
				return false;
			}else{
				$(this).closest("tr").remove();
			}
		});
		$("#wrap").on("focus", "#table_input input", function () {
		    // 모든 tr/td에서 클래스 제거
		    $("#table_input tbody tr").removeClass("focusRow");
		    $("#table_input tbody td").removeClass("focusCol focusCell");

		    // 포커스된 input의 tr에 클래스 추가 (행 강조)
		    const $tr = $(this).closest("tr");
		    $tr.addClass("focusRow");

		    // 포커스된 td의 index 구하기
		    const $td = $(this).closest("td");
		    const colIndex = $td.index();

		    // 같은 열에 있는 모든 td에 클래스 추가 (열 강조)
		    $("#table_input tbody tr").each(function () {
		        $(this).children("td").eq(colIndex).addClass("focusCol");
		    });

		    // 자기 자신(td)은 교차점이니까 별도 강조
		    $td.addClass("focusCell");
		});

		// 천 단위 쉼표 자동 적용 - 모든 tr에 동작
		$("#wrap #formTeg").on("input", ".price, .Buyingprice, .inventory", function(){
		    let value = $(this).val().replace(/[^0-9]/g, ""); // 숫자만
		    if (value) {
		        let formatted = value.replace(/\B(?=(\d{3})+(?!\d))/g, ",");
		        $(this).val(formatted);
		    }
		});

        // 키보드 '+' 키를 자동으로 입력 (Keypad '+')
        let plusEvent = new KeyboardEvent('keydown', {
            key: '+',
            code: 'NumpadAdd',
            keyCode: 107, // 숫자 키패드 + 키 코드
            which: 107,
            bubbles: true
        });
		//바코드 스캔 자료
		document.addEventListener("keydown", function(event) {
		    if (event.key === "!") { // 바코드가 "!"로 시작하면
		        event.preventDefault();
	            // 현재 포커스된 요소에 이벤트를 강제로 발생
	            document.activeElement.dispatchEvent(plusEvent);
	            addNewRowWithToday();
	            $(".insertTR:eq(-2)").find("td .SerialNumber").focus();
		    }
		});
		document.getElementById("logoutButton").addEventListener("click", function() {
            window.location.href = "logout.jsp"; // 로그아웃 JSP로 리다이렉트
        });
		
	    let currentRowIndex = -1; // 현재 선택된 행의 인덱스 초기화
	    let currentRow; // 현재 선택된 행을 추적할 변수 추가

	    // 검색 입력 시 Ajax 요청
	    $("#table_input").on("keydown", ".insertTR .medicineName", function (e) {
	        if (e.key === "Enter") { // Enter 키 감지
	            e.preventDefault(); // 폼 제출 방지
	            let medicineName = $(this).val();

	            // 현재 포커스가 있는 행을 추적
	            currentRow = $(this).closest('tr'); // 현재 입력 필드가 속한 행

	            if (medicineName.trim() !== "") {
	                // Ajax 요청
	                $.ajax({
	                    url: "productMedicine.jsp", // 데이터 검색 JSP
	                    method: "POST",
	                    data: { medicineName: medicineName }, // LIKE 검색 조건
	                    success: function (response) {
	                        $("#popup-content").html(response); // 결과를 테이블에 표시
	                        $("#popup").show(); // 팝업 표시
	                        currentRowIndex = -1;
	                    },
	                    error: function () {
	                        return false;
	                    }
	                });
	            }
	        }
	    });

	    // 팝업 외부 클릭 시 닫기
	    $(document).on("click", function (e) {
	        if (!$(e.target).closest("#popup, .medicineName").length) {
	            $("#popup").hide();
	        }
	    });

	    // 테이블 행 클릭 시 데이터 입력
	    $(document).on("click", ".result-row", function () {
	        let data = $(this).data(); // 선택된 데이터 가져오기

	        // 입력 필드에 값 채우기
	        populateFields(data);
	    });

		$('#popup').on("mouseover", "tbody tr", function(){
			  const rows = $('#popup-content tr:visible');
			  currentRowIndex = rows.index(this);
			  rows.removeClass('medicineHover');
			  $(this).addClass('medicineHover');
		});
		let selectedRowIndex = -1;
	    // 키보드 이벤트 처리 (방향키 및 Enter 키)
		$(document).on('keydown', function (e) {
			if (!$('#popup').is(':visible')) return;
			if($("#popup").is(":visible")){
				if(e.keyCode === 27){
					e.preventDefault();
					$('#popup').hide();
				}
			}
			
			const rows = $('#popup-content tr:visible');
			if (!rows.length) return;
			if (e.key === 'ArrowDown') {
				e.preventDefault();
			if (currentRowIndex < rows.length - 1) currentRowIndex++;
			} else if (e.key === 'ArrowUp') {
				e.preventDefault();
			if (currentRowIndex > 0) currentRowIndex--;
			} else if (e.key === 'Enter' && currentRowIndex >= 0) {
				e.preventDefault();
				$(rows[currentRowIndex]).trigger('click'); // 기존 클릭 로직 재사용
			} else {
				return;
			}
			
			rows.removeClass('medicineHover');
			if (currentRowIndex >= 0) {
		    	$(rows[currentRowIndex]).addClass('medicineHover');
		    	// 강조행이 가려졌다면 살짝만 보이게 스크롤
		    	rows[currentRowIndex].scrollIntoView({block: 'nearest'});
			}
		});

	    // 입력 필드에 데이터 채우기
	    function populateFields(data) {
	        // 현재 선택된 행에만 값 채우기
	        currentRow.find(".medicineName").val(data.medicinename);
	        currentRow.find(".companyName").val(data.companyname);
	        currentRow.find(".standard").val(data.standard);
	        currentRow.find(".kind").val(data.kind);
	        currentRow.find(".inventory").val(data.inventory);
	        currentRow.find(".SerialNumber").val(data.serialnumber);
	        currentRow.find(".DeliveryDate").val(data.deliverydate);
	        currentRow.find(".Buyingprice").val(data.buyingprice);
	        currentRow.find(".price").val(data.price);

	        $("#popup").hide(); // 팝업 숨기기
	        currentRow.find(".DeliveryDate").focus(); // 입력 필드에 포커스 이동
	    }
	});





	document.addEventListener('keydown', (event) => {
	    //console.log(`Key: ${event.key}, ASCII Code: ${event.keyCode}`);
	    // - 키를 누르면 맨 아래 리스트가 삭제
		if (event.keyCode == 109) { // '-' 키
	event.preventDefault();
	const $rows = $("#table_input .insertTR");

	if ($rows.length > 1) {
		$rows.last().remove(); // 마지막 행 제거
	} else {
		alert("더 이상 삭제할 수 없습니다.");
	}
}

	    

		if (event.keyCode === 106){
			event.preventDefault();
			alert("데이터가 저장되었습니다.");
			$("#formTeg").submit();
		}

	    // + 버튼을 누르면 리스트가 하나 새로 추가
if (event.keyCode == 107) {
    event.preventDefault();

    addNewRowWithToday();
}

	});
 	document.addEventListener("input", function (event) {
	    if (event.target.classList.contains("DeliveryDate")) {
	        let input = event.target.value.replace(/[^0-9]/g, ""); // 숫자 외 제거
	        let formatted = "";

	        if (input.length > 2) {
	            formatted += input.substring(0, 2) + "/"; // 첫 번째 슬래시 추가
	        } else {
	            formatted += input;
	        }

	        if (input.length > 4) {
	            formatted += input.substring(2, 4) + "/"; // 두 번째 슬래시 추가
	            formatted += input.substring(4, 6); // 나머지 추가
	        } else if (input.length > 2) {
	            formatted += input.substring(2); // 첫 슬래시 뒤 나머지 추가
	        }
	        event.target.value = formatted.slice(0, 8); // 최대 8자리 유지
	    }
	});
 	document.addEventListener("keydown", function (event) {
	    // Enter 키와 PageDown 키 감지
	    if (event.keyCode === 34) {
	        event.preventDefault(); // 기본 동작 방지

	        const currentInput = event.target;

	        // 현재 input의 부모 td 요소 찾기
	        const currentTd = currentInput.closest("td");
	        if (!currentTd) return; // td가 없으면 종료

	        // 현재 td의 이전 형제 td 찾기
	        const prevTd = currentTd.previousElementSibling;

	        // 이전 td에 input 요소가 있는지 확인 후 포커스 이동
	        if (prevTd) {
	            const prevInput = prevTd.querySelector("input");
	            if (prevInput) {
	                prevInput.focus();
	            }
	        }
	    }
	});


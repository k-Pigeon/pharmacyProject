	        }

	        // 현재 입력 필드의 부모 <td>에서 다음 <td>를 찾음
	        const nextTd = currentInput.closest("td").nextElementSibling;
	        if (nextTd) {
	            const nextInput = nextTd.querySelector("input, select"); // 다음 <td> 안의 input 또는 select 찾기
	            if (nextInput) {
	                event.preventDefault(); // 기본 Enter 키 동작 방지
	                nextInput.focus(); // 다음 입력 필드로 포커스 이동
	            }
	        } else {
	            // 마지막 필드인 경우 추가적인 동작(필요 시 구현)
	            event.preventDefault();
	        }
	    }
	});
	// 방향키로 행 이동
document.addEventListener("keydown", function(event) {
    // 위쪽(ArrowUp)과 아래쪽(ArrowDown) 키만 처리
    if (event.key === "ArrowDown" || event.key === "ArrowUp") {
        event.preventDefault(); // 기본 화살표 동작 방지

        const currentInput = event.target; // 현재 포커스된 input 요소
        const currentTd = currentInput.closest("td"); // 현재 input이 속한 td
        const currentTr = currentTd.closest("tr"); // 현재 td가 속한 tr
        const currentTable = currentTr.closest("table"); // 현재 tr이 속한 table

        let targetTd; // 이동할 대상 td를 변수로 설정

        // 방향키에 따른 이동
        if (event.key === "ArrowDown") {
            const targetTr = currentTr.nextElementSibling; // 다음 행
            if (targetTr) {
                targetTd = targetTr.children[currentTd.cellIndex]; // 현재 td의 같은 위치
            } else {
                // 마지막 행일 경우 첫 번째 행으로 이동
                const firstRow = currentTable.querySelector("tbody tr:first-child");
                targetTd = firstRow.children[currentTd.cellIndex];
            }
        }
        else if (event.key === "ArrowUp") {
            const targetTr = currentTr.previousElementSibling; // 이전 행
            if (targetTr) {
                targetTd = targetTr.children[currentTd.cellIndex]; // 현재 td의 같은 위치
            } else {
                // 첫 번째 행일 경우 마지막 행으로 이동
                const lastRow = currentTable.querySelector("tbody tr:last-child");
                targetTd = lastRow.children[currentTd.cellIndex];
            }
        }

        // 이동할 td가 존재하면, 해당 td의 input 요소로 포커스 이동
        if (targetTd) {
            const targetInput = targetTd.querySelector("input"); // 대상 td의 input 요소 찾기
            if (targetInput) {
                targetInput.focus(); // 해당 input 요소에 포커스 이동
            }
        }
    }

    // 좌우 방향키 (ArrowLeft, ArrowRight)에 대한 처리를 하지 않음
    else if (event.key === "ArrowLeft" || event.key === "ArrowRight") {
        event.preventDefault(); // 좌우 키 동작 방지
    }
});





	<script>
		let currentPage = 1;
		let totalPages = 0;
		let firstLoad = true;
		let inventoryAlertMode = false;

		$(document).ready(function(){
			$.ajax({
			    url: "inventoryFlag.jsp",
			    type: "GET",
			    cache: false,   // 캐시 방지
			    success: function(result){

			        if (result && result.trim() === "Y") {
			            $(".inventoryNotification").addClass("inventory-warning");
			        } else {
			            $(".inventoryNotification").removeClass("inventory-warning");
			        }
			    },
			    error: function(xhr, status, error){
			        console.error("[inventoryFlag ERROR]", xhr.status, status, error);
			        alert("inventoryFlag 에러: " + xhr.status + " / " + status);
			    }
			});

			$(".inventoryNotification").on("click", function(){
			    inventoryAlertMode = !inventoryAlertMode;  // 🔥 토글 방식

			    if (!inventoryAlertMode) {
			        // 해제되면 다시 오른쪽 리스트 초기화
			        loadPage(currentPage);
			        return;
			    }

			    // 고정 모드(=true)일 때만 부족 리스트 로드
			    $.ajax({
			        url: "getInventoryWarningList.jsp",
			        type: "GET",
			        dataType: "json",
			        success: function(res){
			            if(res.found){
			                $("#inventory_list").html(res.html);
			            } else {
			                alert("조건에 맞는 제품이 없습니다.");
			            }
			        }
			    });
			});




		    if (firstLoad) {
		        loadPage(1);
		        firstLoad = false;   // 이제 다시는 실행되지 않음
		    }
			function loadPage(page, updatePageInfo = true) {
			    $.ajax({
			        url: "getDatasUpdate.jsp",
			        type: "GET",
			        data: { page: page },
			        dataType: "json",
			        success: function(data) {
			        	if (!inventoryAlertMode) {
			        	    $("#inventory_list").html(data.html);
			        	}

			            currentPage = page;
			            totalPages = data.totalPages;

			            if (updatePageInfo) {
			                $("#pageInfo").text(page + " / " + totalPages);
			            }
			        },
			        error: function() {
			            alert("데이터 불러오기 실패");
			        }
			    });
			}
			document.addEventListener("keydown", function(e){
				//행 복사 F3
				if(e.keyCode == "114"){
					e.preventDefault();
					$("#wrap .cloneCV").click();
				}
				//저장 F11
				if(e.keyCode == "122"){
					e.preventDefault();
					$("#wrap .saveLeftList").click();
				}
				//행 삭제 F4
				if(e.keyCode == "115"){
					e.preventDefault();
					$("#wrap .cloneDelete").click();
				}
				//새로고침 F7
				if(e.keyCode === 118){
					e.preventDefault();
					window.location.reload();
				}
				//제어 F5
				if(e.keyCode === 116){
					e.preventDefault();
				}
			});

			$("#nextPage").click(() => { 
			    if (currentPage < totalPages) {
			        loadPage(currentPage + 1);
			        setTimeout(() => checkAllInventory(), 300);
			    }
			});
			$("#prevPage").click(() => { 
			    if (currentPage > 1) {
			        loadPage(currentPage - 1);
			        setTimeout(() => checkAllInventory(), 300);
			    }
			});
			
			function loadInventoryInfo(medicineName) {
		        return new Promise(function(resolve, reject) {
		            $.ajax({
		                url: "getInventoryInfo.jsp",
		                type: "GET",
		                data: { medicineName },
		                dataType: "json",
		                success: resolve,
		                error: reject
		            });
		        });
		    }
			//수정할 내용을 선택하는 구문
			$("#wrap #inventory_list").on("click", "tr", async function(){
		        $(".table_line tbody tr").removeClass("focusTr");

		        const $tr = $(this).closest("tr");
		        $tr.addClass("focusTr");

		        /* 1) 이름 가져오기 */
		        const medicineName = $(this).find("td").eq(0).text().trim();

		        /* 2) DB에서 재고/규격 받아오기 */
		        const db = await loadInventoryInfo(medicineName);

		        const dbInventory = parseFloat(db.inventory) || 0;
		        const dbStandard = db.standard || "1";

		        /* 3) 왼쪽 상세화면 로드 요청 */
		        $.ajax({
		            url: "getMedicineDetail.jsp",
		            type: "GET",
		            data: { medicineName },
		            success: function(html){

		                /* 왼쪽 내용 적용 */
		                $(".leftList .table_line .inventoryUpdate").html(html);
		            }
		        });
			});
			
			$("#wrap").on("mouseover","#inventory_list tr", function(){
				$("#wrap").find("#inventory_list tr").removeClass("hoverMouse");
				$(this).addClass("hoverMouse");
			});
			
			//수정할 때 focus 인식 부분
			$("#wrap").on("focus", ".table_line input", function () {
			    // 모든 tr/td에서 클래스 제거
			    $(".table_line tbody tr").removeClass("focusRow");
			    $(".table_line tbody td").removeClass("focusCol focusCell");

			    // 포커스된 input의 tr에 클래스 추가 (행 강조)
			    const $tr = $(this).closest("tr");
			    $tr.addClass("focusRow");

			    // 포커스된 td의 index 구하기
			    const $td = $(this).closest("td");
			    const colIndex = $td.index();

			    // 같은 열에 있는 모든 td에 클래스 추가 (열 강조)
			    $(".table_line tbody tr").each(function () {
			        $(this).children("td").eq(colIndex).addClass("focusCol");
			    });

			    // 자기 자신(td)은 교차점이니까 별도 강조
			    $td.addClass("focusCell");
			});
			
			//숫자 쉼표 입력
			$("#wrap .inventoryUpdate").on("input", ".price, .Buyingprice, .inventory", function(){
			    let value = $(this).val().replace(/[^0-9]/g, ""); // 숫자만
			    if (value) {
			        let formatted = value.replace(/\B(?=(\d{3})+(?!\d))/g, ",");
			        $(this).val(formatted);
			    }
			});
			
			
			//방향키로 input 이동
			$("#wrap .leftList .table_line").on("keydown", "input", function (e) {
				  const $currentInput = $(this);
				  const $currentTd = $currentInput.closest("td");
				  const colIndex = $currentTd.index();
				  const $currentTr = $currentInput.closest("tr");

				  let $targetInput;

				  if (e.key === "ArrowUp") {
				    const $targetTr = $currentTr.prev("tr");
				    $targetInput = $targetTr.find("td").eq(colIndex).find("input").click();
				    $(this).select();
				  } else if (e.key === "ArrowDown") {
				    const $targetTr = $currentTr.next("tr");
				    $targetInput = $targetTr.find("td").eq(colIndex).find("input").click();
				    $(this).select();
				  } else if (e.key === "ArrowLeft") {
				    const $tds = $currentTr.find("td");
				    if (colIndex > 0) {
				      $targetInput = $tds.eq(colIndex - 1).find("input").click();
					    $(this).select();
				    }
				  } else if (e.key === "ArrowRight") {
				    const $tds = $currentTr.find("td");
				    if (colIndex < $tds.length - 1) {
				      $targetInput = $tds.eq(colIndex + 1).find("input").click();
					    $(this).select();
				    }
				  } else {
				    return;
				  }

				  if ($targetInput && $targetInput.length) {
				    e.preventDefault();
				    $("input").removeClass("inputCheckStyle"); // 모든 input에서 제거
				    $targetInput.addClass("inputCheckStyle").focus(); // 이동한 input에 추가
				  }
			});
			//input 클릭 시 내용 전체 선택
			$("#wrap .leftList .table_line").on("click", "input", function(){
				$(this).select();
			});
			//날짜 정규식 yy/mm/dd
			$("#wrap .leftList .table_line").on("input", ".receiptDate, .DeliveryDate", function () {
			    let val = $(this).val();

			    // 숫자와 '/'만 허용
			    val = val.replace(/[^0-9]/g, "");

			    // 길이에 따라 자동 슬래시 추가
			    if (val.length >= 5) {
			        val = val.substring(0, 6); // 최대 6자리 (yy mm dd)
			        val = val.replace(/(\d{2})(\d{2})(\d{1,2})/, "$1/$2/$3");
			    } else if (val.length >= 3) {
			        val = val.replace(/(\d{2})(\d{1,2})/, "$1/$2");
			    }

			    $(this).val(val);
			});
			$("#wrap .cloneCV").on("click", function () {
			    let cloned = $(".focusRow").clone();

			    // tr 자체의 클래스 제거
			    cloned.removeClass("focusCol focusRow");

			    // 내부 td 의 클래스 제거
			    cloned.find("td").removeClass("focusCol focusCell");

			    // 클론한 tr을 붙이기
			    $(".leftList .table_line").append(cloned);
			});
			$("#wrap .cloneDelete").on("click", function(){
				if($("#wrap .leftList .table_line tr").length == 1){
					return false;
				}else{
					$("#wrap .leftList .table_line .focusRow").remove();
				}
			});
			//좌측 내용 일괄 수정
			$("#wrap .saveLeftList").on("click", function () {
				let rows = [];

				$(".leftList .leftEditRow").each(function () {
				    let row = {
				        SerialNumber: $(this).find(".SerialNumber").val(),
				        medicineName: $(this).find(".medicineName").val(),
				        Buyingprice: $(this).find(".Buyingprice").val().replace(/,/g,""),
				        price: $(this).find(".price").val().replace(/,/g,""),
				        inventory: $(this).find(".inventory").val(),
				        quantity: $(this).find(".quantity").val(),
				        DeliveryDate: $(this).find(".DeliveryDate").val(),
				        receiptDate: $(this).find(".receiptDate").val(),
				        kind: $(this).find(".kind").val(),
				        companyName: $(this).find(".companyName").val(),
				        standard: $(this).find(".standard").val()
				    };

				    rows.push(row);
				});

				$.ajax({
				    url: "saveLeftList.jsp",  // ← 새 파일
				    type: "POST",
				    contentType: "application/json; charset=utf-8",
				    data: JSON.stringify(rows),
				    success: function (res) { alert("수정 완료!"); }
				});
			});
		});
	</script>

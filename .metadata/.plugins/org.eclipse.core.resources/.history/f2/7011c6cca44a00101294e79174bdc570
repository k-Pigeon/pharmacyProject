	height: 100%;
	z-index: 100;
}

#warningLetter .Phrase {
	position: fixed;
	width: 500px;
	height: 300px;
	background-color: white;
	border: 1px solid black;
	top: 50%;
	left: 50%;
	transform: translate(-50%, -50%);
}

#warningLetter .Phrase h1, #warningLetter .Phrase h3 {

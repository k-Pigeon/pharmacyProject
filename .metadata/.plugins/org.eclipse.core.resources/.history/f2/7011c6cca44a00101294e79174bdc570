}

.changeAcc .form-container .closePopup {
	position: absolute;
	width: 100px;
	height: 40px;
	left: 75%;
	line-height: 40px;
	text-align: center;
	border: 1px solid black;
	border-radius: 10px;
	font-size: 25px;
}

.changeAcc .form-container .closePopup:hover {
	cursor: pointer;
}
/* 게이지 바 */
#loadingBarWrapper {
	width: 100%;
	height: 10px;
	background-color: #eee;
	border-radius: 5px;
	overflow: hidden;
	margin-top: 20px;
}

#loadingBar {
	width: 0%;
	height: 100%;
	background-color: #3498db;
	transition: width 0.4s ease;
}

.managerAcc {
	width: 100%;
	height: 100%;
	font-size: 30px;
	text-align: center;
	font-weight: bold;
}

#warningLetter {
	position: absolute;
	background-color: RGBA(127, 127, 127, 0.8);

<%!private Double parseDoubleOrExtractNumbers(String value, Double defaultValue) {
		if (value != null && !value.trim().isEmpty()) {
			try {
				String numericValue = value.replaceAll("[^0-9.]", "");
				return numericValue.isEmpty() ? defaultValue : Double.parseDouble(numericValue);
			} catch (NumberFormatException e) {
				System.err.println("숫자 변환 오류: " + value);
			}
		}
		return defaultValue;
	}

	private Double parseStandardOrMultiply(String standard, Double inventory) {
		if (standard != null && !standard.trim().isEmpty()) {
			boolean hasUnit = standard.matches(".*\\b(g|ml|l|cm)\\b.*");
			String[] parts = standard.split("\\s+");

			List<Double> numbers = new ArrayList<>();
			for (String part : parts) {
				Double number = parseDoubleOrExtractNumbers(part, null);
				if (number != null)
					numbers.add(number);
			}

			if (numbers.size() >= 2) {
				Double multipliedValue = 1.0;
				for (Double n : numbers)
					multipliedValue *= n;
				return inventory * multipliedValue;
			}
			if (hasUnit)
				return inventory;
			if (!numbers.isEmpty())
				return inventory * numbers.get(0);
		}
		return inventory;
	}%>
<%
String dbName = (session != null) ? (String) session.getAttribute("dbName") : null;
String id = (session != null) ? (String) session.getAttribute("id") : null;
String idSortation = (session != null) ? (String) session.getAttribute("idSortation") : null;
if (id == null || dbName == null) {
	response.sendRedirect("login.jsp");
	return;
}

jdbcDriver = dbName;
response.setCharacterEncoding("UTF-8");

JSONObject result = new JSONObject();
PreparedStatement ps = null;
ResultSet rs = null;

try {
	String sql = "SELECT medicineName, quantity, inventory, standard " + "FROM testTable" + idSortation;

	ps = conn.prepareStatement(sql, ResultSet.TYPE_SCROLL_INSENSITIVE, ResultSet.CONCUR_READ_ONLY);
	rs = ps.executeQuery();

	List<String> shortageList = new ArrayList<>();

	while (rs.next()) {
		String firstName = rs.getString("medicineName");
		String standard = rs.getString("standard");
		double inventoryValue = parseStandardOrMultiply(standard, rs.getDouble("inventory"));
		int qty = rs.getInt("quantity");

		if (inventoryValue < qty) { // ✅ 여기서 비교
	shortageList.add(firstName + " : 재고 " + inventoryValue + ", 필요 " + qty);
		}
	}

	if (!shortageList.isEmpty()) {
		result.put("representative", shortageList.get(0));
		result.put("others", shortageList.size() - 1);
	} else {
		result.put("representative", "");
		result.put("others", 0);
	}

} catch (Exception e) {
	result.put("error", e.getMessage());
} finally {
	if (rs != null)
		try {
	rs.close();
		} catch (SQLException ignore) {
		}
	if (ps != null)
		try {
	ps.close();
		} catch (SQLException ignore) {
		}
	if (conn != null)
		try {
	conn.close();
		} catch (SQLException ignore) {
		}
}

out.print(result.toString());
%>

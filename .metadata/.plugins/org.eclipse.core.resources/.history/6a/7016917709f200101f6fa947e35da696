/* ===== 판매 페이지 전체 ===== */
body.sale-body {
    background: #f0f0f0;
    overflow-x: hidden;
}

/* 메인 컨테이너 */
body.sale-body #wrap.wrap-container {
    width: 100%;
    margin: 0 auto;
    text-align: center;
}

/* 제목 영역 */
body.sale-body #wrap .sale-title-area {
    margin: 20px 0 30px 0;
}

body.sale-body #wrap .sale-title-area h1 {
    font-size: 24px;
    margin-bottom: 8px;
}

/* 메인 2열 레이아웃 */
body.sale-body #wrap #data.layout-grid {
    display: grid;
    grid-template-columns: 70% 30%;
    column-gap: 32px;
    align-items: start;
    padding: 0 20px 40px;
}

/* 좌측 판매 영역 */
body.sale-body #wrap #data .rightUI.right-ui-area {
    width: 100%;
}

/* 우측 세트 영역 */
body.sale-body #wrap #data .leftUI.left-ui-area {
    width: 100%;
}
/* 모든 판매 테이블 공통 */
body.sale-body #wrap #data .rightUI table.table_line {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    background: #ffffff;
}

/* 컬럼 셀 */
body.sale-body #wrap #data .rightUI table.table_line th,
body.sale-body #wrap #data .rightUI table.table_line td {
    border: 1px solid #cfcfcf;
    padding: 6px 4px;
    height: 40px;
    text-align: center;
    font-size: 13px;
    white-space: nowrap;
}

/* 헤더 색상 */
body.sale-body #wrap #data .rightUI table.table_line thead th {
    background: #e6e6e6;
    font-weight: 600;
}

/* 스크롤 테이블 영역 */
body.sale-body #wrap #data .rightUI .scroll-table-area {
    max-height: 170px;
    overflow-y: auto;
    border: 1px solid #aaa;
    margin-bottom: 12px;
}
body.sale-body #wrap #data .rightUI table.table_line input[type="text"] {
    width: 100%;
    height: 26px;
    font-size: 12px;
    padding: 2px 4px;
    text-align: center;
    border: 1px solid #bdbdbd;
    border-radius: 3px;
    background: #ffffff;
    outline: none;
}

body.sale-body #wrap #data .rightUI table.table_line input[type="text"]:focus {
    border-color: #4caf50;
}
body.sale-body #wrap #data .rightUI #preparations div {
    display: flex;
    justify-content: center;
    gap: 6px;
}

body.sale-body #wrap #data .rightUI .discount-btn {
    height: 26px;
    padding: 0 8px;
    font-size: 12px;
    border-radius: 4px;
}
body.sale-body #wrap #data .rightUI #exhaustionInv {
    width: 100%;
    height: 44px;
    font-size: 15px;
    background: #4caf50;
    color: #fff;
    border-radius: 6px;
}
body.sale-body #wrap #data .rightUI .consumerInfo {
    display: flex;
    gap: 14px;
    margin-bottom: 12px;
    align-items: center;
}

body.sale-body #wrap #data .rightUI .memberName,
body.sale-body #wrap #data .rightUI .scheduleDate {
    height: 32px;
    padding: 4px 8px;
    font-size: 12px;
}
/* 세트 테이블 공통 */
body.sale-body #wrap #data .leftUI table.regularTable {
    width: 100%;
    border-collapse: collapse;
    background: #ffffff;
    margin-bottom: 20px;
    border-radius: 10px;
    overflow: hidden;
}

/* 세트 헤더 */
body.sale-body #wrap #data .leftUI table.regularTable thead {
    background: #cdeed1;
}

body.sale-body #wrap #data .leftUI table.regularTable th,
body.sale-body #wrap #data .leftUI table.regularTable td {
    border: 1px solid #e0bebe;
    height: 42px;
    text-align: center;
    font-size: 13px;
    padding: 4px;
}

body.sale-body #wrap #data .leftUI table.regularTable td:hover {
    background: #ffecec;
    cursor: pointer;
}
body.sale-body #wrap #data .leftUI table.regularTable th {
    position: relative;
}

body.sale-body #wrap #data .leftUI .leftLid,
body.sale-body #wrap #data .leftUI .rightLid {
    position: absolute;
    top: 0;
    width: 50%;
    height: 100%;
    line-height: 42px;
    font-weight: bold;
    background: #c0e4c4;
}

body.sale-body #wrap #data .leftUI .leftLid { left: 0; }
body.sale-body #wrap #data .leftUI .rightLid { right: 0; }
body.sale-body #popup.popup-window {
    position: fixed;
    inset: 8%;
    background: #ffffff;
    border: 1px solid #999;
    z-index: 1000;
    padding: 10px;
}

body.sale-body #warningBox {
    z-index: 9999;
}
/* =========================
   검색 팝업 정상화
========================= */

body.sale-body #popup.popup-window {
    display: none;              /* 기본은 숨김 */
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80%;
    max-width: 1200px;
    height: 60%;
    max-height: 600px;
    background: #ffffff;
    border: 2px solid #666;
    border-radius: 8px;
    z-index: 5000;
    padding: 10px;
    box-shadow: 0 0 20px rgba(0,0,0,0.3);
}

/* 팝업 내부 테이블 */

body.sale-body #popup.popup-window .popup-table {
    width: 100%;
    height: calc(100% - 40px);
    overflow-y: auto;
    display: block;
    border-collapse: collapse;
}

/* 팝업 제목 */

body.sale-body #popup.popup-window h3 {
    margin-bottom: 10px;
    font-size: 16px;
}

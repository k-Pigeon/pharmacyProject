    pstmt = conn.prepareStatement(sql);
    pstmt.setString(1, saleDate);
    rs = pstmt.executeQuery();

    while (rs.next()) {
        JSONObject o = new JSONObject();
        o.put("medicineName", rs.getString("medicineName"));

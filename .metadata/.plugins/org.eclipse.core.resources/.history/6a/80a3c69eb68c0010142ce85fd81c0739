System.out.println(month);

PreparedStatement pstmt = null;
ResultSet rs = null;

try {
    String sql = "SELECT medicineName, " +
                 " CAST(Buyingprice AS DECIMAL) AS Buyingprice, " +
                 " CAST(price AS DECIMAL) AS price, " +
                 " CAST(inventory AS DECIMAL) AS inventory, " +
                 " (CAST(price AS DECIMAL) - CAST(Buyingprice AS DECIMAL)) AS margin, " +
                 " ROUND(((CAST(price AS DECIMAL) - CAST(Buyingprice AS DECIMAL)) / NULLIF(CAST(price AS DECIMAL),0)) * 100, 2) AS marginRate " +
                 " FROM " + tableName +

        o.put("price", rs.getBigDecimal("price"));              // 숫자 그대로
        o.put("inventory", rs.getBigDecimal("inventory"));      // 숫자 그대로
        o.put("margin", rs.getBigDecimal("margin"));            // 숫자 그대로
        o.put("marginRate", rs.getBigDecimal("marginRate"));    // 숫자 그대로
        rows.put(o);
    }

    result.put("saleDate", saleDate);
    result.put("rows", rows);
    result.write(response.getWriter());

} catch(Exception e){
    result.put("error", e.getMessage()).write(response.getWriter());
} finally {
    if (rs != null) try { rs.close(); } catch(Exception ig){}
    if (pstmt != null) try { pstmt.close(); } catch(Exception ig){}
    if (conn != null) try { conn.setAutoCommit(true);} catch(Exception ig){}

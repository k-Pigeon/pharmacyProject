<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="org.json.JSONArray" %>
<%@ page import="org.json.JSONObject" %>
<%@ page import="java.sql.*" %>
<%@ page import="java.util.*, java.util.Date" %>
<%@ page import="java.text.*" %>
<%@ include file="sessionManager.jsp"%>
<%@ include file="DBconnection.jsp"%>
<%
    String dbName = (session != null) ? (String) session.getAttribute("dbName") : null;
    String id = (session != null) ? (String) session.getAttribute("id") : null;
    String password = (session != null) ? (String) session.getAttribute("password") : null;

    if (id == null || dbName == null) {
        response.sendRedirect("login.jsp");
        return;
    }

    jdbcDriver = dbName;
    request.setCharacterEncoding("UTF-8");
    PreparedStatement ps = null;
    PreparedStatement ps2 = null;
    ResultSet rs = null;

    try {
        Class.forName("com.mysql.cj.jdbc.Driver");

        String medicinesJson = request.getParameter("medicines");
        JSONArray medicines = new JSONArray(medicinesJson);
        String regiDate = request.getParameter("regiDate");

        Timestamp currentTime;

        try {
            if (regiDate != null && !regiDate.trim().isEmpty()) {
                if (regiDate.matches("^\\d{2}/\\d{2}/\\d{2}$")) {
                    SimpleDateFormat inputFormat = new SimpleDateFormat("yy/MM/dd");
                    Date parsed = inputFormat.parse(regiDate);
                    SimpleDateFormat fullFormat = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss");
                    regiDate = fullFormat.format(parsed);
                }
                SimpleDateFormat tsFormat = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss");
                currentTime = new Timestamp(tsFormat.parse(regiDate).getTime());
            } else {
                currentTime = new Timestamp(System.currentTimeMillis());
            }
        } catch (Exception e) {
            currentTime = new Timestamp(System.currentTimeMillis());
        }

        // ✅ 기존 데이터 삭제
        String deleteSQL = "DELETE FROM SalesData WHERE sale_date = ?";
        ps2 = conn.prepareStatement(deleteSQL);
        ps2.setTimestamp(1, currentTime);
        ps2.executeUpdate();

        // ✅ 새 데이터 삽입
        String insertSQL = "INSERT INTO SalesData (sale_date, customer_id, medicine_name, inventory, standard, price, total_price, discounted, lowerAndHigest) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)";
        ps = conn.prepareStatement(insertSQL);

        for (int i = 0; i < medicines.length(); i++) {
            JSONObject medicine = medicines.getJSONObject(i);

            String medicineName = medicine.optString("medicineName", "").trim();
            if (medicineName.isEmpty()) continue;

            String inventory = medicine.optString("inventory", "");
            String standard = medicine.optString("standard", "");
            String price = medicine.optString("price", "0").replaceAll("[^0-9.]", "");
            String totalPrice = medicine.optString("totalPrice", "0").replaceAll("[^0-9.]", "");
            String customerId = medicine.optString("customerId", "");
            String lowerAndHigest = medicine.optString("lowerAndHigest", "");
            String discounted = String.valueOf(medicine.opt("discounted"));

            double priceValue = price.isEmpty() ? 0.0 : Double.parseDouble(price);
            double totalPriceValue = totalPrice.isEmpty() ? 0.0 : Double.parseDouble(totalPrice);

            ps.setTimestamp(1, currentTime);
            ps.setString(2, customerId);
            ps.setString(3, medicineName);
            ps.setString(4, inventory);
            ps.setString(5, standard);
            ps.setDouble(6, priceValue);
            ps.setDouble(7, totalPriceValue);
            ps.setString(8, discounted);
            ps.setString(9, lowerAndHigest);
            ps.executeUpdate();
        }

        out.println("Data inserted successfully.");
    } catch (Exception e) {
        e.printStackTrace();
        out.println("Error: " + e.getMessage());
    } finally {
        try {
            try { if (ps != null) ps.close(); } catch (Exception ignored) {}
            try { if (ps2 != null) ps2.close(); } catch (Exception ignored) {}
            try { if (rs != null) rs.close(); } catch (Exception ignored) {}
        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
%>
<%@ include file="DBclose.jsp" %>
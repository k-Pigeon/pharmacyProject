private String formatDate(String inputDate) {
    try {
        if (inputDate == null) return null;
        String s = inputDate.trim();
        if (s.isEmpty() || "null".equalsIgnoreCase(s) || "undefined".equalsIgnoreCase(s)) {
            return null;
        }

        // ISO T 를 공백으로 정규화
        s = s.replace('T', ' ');

        // 케이스 A: yyyy-MM-dd HH:mm:ss (이미 완전)
        if (s.matches("\\d{4}-\\d{2}-\\d{2}\\s+\\d{2}:\\d{2}:\\d{2}")) {
            return s;
        }
        // 케이스 B: yyyy-MM-dd (시간 없음 → 자정 붙이기)
        if (s.matches("\\d{4}-\\d{2}-\\d{2}")) {
            return s + " 00:00:00";
        }

        // 케이스 C: yy/MM/dd 또는 yyyy/MM/dd
        if (s.matches("\\d{2,4}/\\d{1,2}/\\d{1,2}")) {
            String[] parts = s.split("/");
            int year = Integer.parseInt(parts[0]);
            int month = Integer.parseInt(parts[1]);
            int day = Integer.parseInt(parts[2]);

            // 2자리 연도 → 2000~2099
            if (year < 100) year += 2000;

            return String.format("%04d-%02d-%02d 00:00:00", year, month, day);
        }

        // 그 외 포맷은 파싱 실패로 처리
        throw new IllegalArgumentException("지원하지 않는 날짜 형식: " + inputDate);
    } catch (Exception e) {
        System.err.println("날짜 변환 오류: " + inputDate + ", 오류: " + e.getMessage());
        return null;
    }
}

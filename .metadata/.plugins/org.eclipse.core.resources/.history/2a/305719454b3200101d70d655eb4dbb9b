<!DOCTYPE html>
<html>
<head>
<title>에스팜</title>
<style>
#header ul {
	display: block;
}

#wrap #section {
	display: block;
	width: 100%;
	height: 95vh;
	transform: translateY(5vh);
}

#wrap #section h1 {
	text-align: center;
}

#wrap #section .tableWrapper {
    height: 500px;
    overflow-y: auto;
    margin: auto;
    width: 90%;
    border: 1px solid #ccc;
}

#wrap #section .salesTable {
    border-collapse: separate;
    border-spacing: 0; 
    width: 100%;
    table-layout: fixed;
}

#wrap #section .salesTable thead th {
    position: sticky;
    top: 0;
    background-color: #6c4ba0;
    z-index: 1;
    color:white;
}

#wrap #section .salesTable th,
#wrap #section .salesTable td {
    text-align: center;
    padding: 8px;
    border: 1px solid #ccc;
}
#wrap #section .salesTable td:nth-child(1){
	background-color:#c6aef0;
	color:white;
}
#wrap #section .salesTable tbody tr:even{
	background-color:#bbb;
}
</style>
</head>
<body>
	<div id="wrap" style="display: block;">
		<header>
			<jsp:include page="header.jsp"></jsp:include>
		</header>
		<section id="section">
			<h1>매출</h1>
			<div class="tableWrapper">
				<table class="salesTable">
					<thead>
						<tr>
							<th>날짜</th>
							<th>판매액</th>
							<th>사입가</th>
							<th>마진</th>
							<th>마진률</th>
						</tr>
					</thead>
					<tbody id="totalSales">
						<%
						PreparedStatement pstmt = null;
						ResultSet rs = null;
						String sql = " SELECT date(saleDate) AS SalesDate, "
								   + " FORMAT(Buyingprice, 0) AS Buyingprice, FORMAT(price, 0) AS price, "
								   + " FORMAT((CAST(price AS DECIMAL) - CAST(Buyingprice AS DECIMAL)), 0) AS margin, "
								   + " (CONCAT(ROUND((price - Buyingprice) / price * 100, 2), '%')) AS marginRate "
								   + " FROM salesRecord ";
						pstmt = conn.prepareStatement(sql);
						rs = pstmt.executeQuery();
						while (rs.next()) {
						%>
						<tr>
							<td><%=rs.getString("SalesDate")%></td>
							<td><%=rs.getString("price")%></td>
							<td><%=rs.getString("Buyingprice")%></td>
							<td><%=rs.getString("margin")%></td>
							<td><%=rs.getString("marginRate")%></td>
						</tr>
						<%
						}
						%>
					</tbody>
				</table>
			</div>

		</section>
	</div>
	<script src="jquery-3.7.1.min.js"></script>
	<script src="script.js"></script>
	<script>
		
	</script>
</body>
</html>
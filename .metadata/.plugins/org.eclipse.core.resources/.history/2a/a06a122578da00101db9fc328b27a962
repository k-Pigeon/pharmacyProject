<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ page import="java.sql.*"%>
<%@ page import="java.text.*" %>
<%@ page import="java.util.regex.*, java.util.*"%>
<%@ include file="sessionManager.jsp"%>
<%@ include file="DBconnection.jsp"%>
<%
String dbName = (session != null) ? (String) session.getAttribute("dbName") : null;
String id = (session != null) ? (String) session.getAttribute("id") : null;
String password = (session != null) ? (String) session.getAttribute("password") : null;

String idSortation = (session != null) ? (String) session.getAttribute("idSortation") : null; 
if (id == null || dbName == null) {
    response.sendRedirect("login.jsp");
    return;
}

jdbcDriver = dbName;
%>
<%
    String saleDate = request.getParameter("saleDate");
    PreparedStatement pstmt = null;
    ResultSet rs = null;
    int totalSum = 0;  // 총합계
    boolean hasRecords = false; // 레코드 유무
    String memberNameSummary = ""; // ✅ 루프 밖에서 쓸 구매자명 보관

    try {
        String sql = " SELECT saleDate, medicineName, memberName, " +
                     "        inventory, standard, price, " +
                     "        CASE " +
                     "          WHEN standard LIKE '%ml%' THEN (price * inventory) " +
                     "          WHEN standard LIKE '%l%'  THEN (price * inventory) " +
                     "          ELSE ((price/standard) * inventory) " +
                     "        END AS total " +
                     "   FROM SalesRecord"  + idSortation + 
                     "  WHERE saleDate = ?";
        
        pstmt = conn.prepareStatement(sql);
        pstmt.setString(1, saleDate);
        rs = pstmt.executeQuery();
%>

<table class="table_line"
    style="text-align: center; border: 1px solid black; width: calc(95%); margin: 0 auto;">
    <colgroup>
        <col width="40%">
        <col width="20%">
        <col width="20%">
        <col width="20%">
    </colgroup>
    <thead>
        <tr>
            <th>제품이름</th>
            <th>개수</th>
            <th>규격</th>
            <th>개당 가격</th>
        </tr>
    </thead>
    <tbody>
<%
DecimalFormat df = new DecimalFormat("###,###");

while (rs.next()) {
    hasRecords = true;

    // ✅ 루프에서 한 번만(또는 마지막 값으로) 구매자명 보관
    String memberName = rs.getString("memberName");
    if (memberName != null && memberNameSummary.isEmpty()) {
        memberNameSummary = memberName;
    }

    String medicineName = rs.getString("medicineName");
    int inventory = rs.getInt("inventory");
    String standard = rs.getString("standard");

    // 숫자 추출해 곱하는 factor (현재는 미사용)
    double factor = 1.0;
    try {
        Pattern pattern = Pattern.compile("(\\d+(\\.\\d+)?)");
        Matcher matcher = pattern.matcher(standard);

        List<Double> numbers = new ArrayList<>();
        while (matcher.find()) {
            numbers.add(Double.parseDouble(matcher.group()));
        }
        if (!numbers.isEmpty()) {
            factor = 1.0;
            for (double num : numbers) {
                factor *= num;
            }
        }
    } catch (Exception e) {
        factor = 1.0;
    }

    // ❗현재는 factor 미적용: 필요시 아래 주석 해제
    int finalInventory = inventory;
    // int finalInventory = (int)Math.round(inventory * factor); // ← 규격 숫자 곱 적용하려면 이 줄 사용

    int price = rs.getInt("price");
    int totalPrice = finalInventory * price;
    totalSum += totalPrice;
%>
    <tr>
        <td><%= medicineName %></td>
        <td><%= finalInventory %></td>
        <td><%= standard %></td>
        <td><%= df.format(price) %></td>
    </tr>
<%
} // end while

if (!hasRecords) {
%>
        <tr>
            <td colspan="4">해당 날짜에 대한 기록이 없습니다.</td> <!-- ✅ colspan 4로 수정 -->
        </tr>
<%
}
%>
    </tbody>
</table>

<%-- 총합계 표시 --%>
<% if (hasRecords) { %>
<table class="table_line"
    style="text-align: center; border: 1px solid black; width: calc(95%); margin: 0 auto;">
    <tr>
        <td>구매자명</td>
        <td><%= (memberNameSummary == null) ? "" : memberNameSummary %></td> <!-- ✅ rs 사용 금지 -->
        <td style="text-align: right; font-weight: bold;">총합계</td>
        <td><%= df.format(totalSum) %> 원</td>
    </tr>
</table>
<% } %>

<%
    } catch (SQLException se) {
        se.printStackTrace();
    } catch (Exception e) {
        e.printStackTrace();
    } finally {
        if (rs != null) try { rs.close(); } catch (SQLException ignore) {}
        if (pstmt != null) try { pstmt.close(); } catch (SQLException ignore) {}
        if (conn != null) try { conn.close(); } catch (SQLException ignore) {}
    }
%>

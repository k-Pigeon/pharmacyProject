<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<title>재고 부족 경고</title>
<style>
body {
    font-family: "Noto Sans KR", sans-serif;
    background: #f9f9f9;
    padding: 40px;
}
#warningBox {
    position: fixed;
    right: 20px;
    bottom: -400px;
    background: #fff8f8;
    border: 1px solid #ffb3b3;
    border-radius: 12px;
    width: 360px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    padding: 20px;
    opacity: 0;
    transition: all 0.6s ease;
}
#warningBox.show {
    bottom: 20px;
    opacity: 1;
}
#warningList div {
    background: #fff;
    border-left: 4px solid #ff6666;
    border-radius: 6px;
    margin-bottom: 10px;
    padding: 8px;
}
#closeWarning {
    background: #d60000;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 6px 10px;
    cursor: pointer;
    float: right;
}
#closeWarning:hover {
    background: #b30000;
}
</style>
</head>
<body>
<h2>⚠ 재고 부족 경고 시스템</h2>
<p>판매 후 재고 상태를 확인했습니다.</p>

<div id="warningBox">
    <h3>🚨 부족 재고 목록</h3>
    <div id="warningList"></div>
    <button id="closeWarning">닫기</button>
</div>

<script>
fetch("statistics.jsp", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify([]) // 필요 시 실제 데이터 전송
})
.then(res => res.json())
.then(data => {
    const warnings = data.warnings || [];
    const box = document.getElementById("warningBox");
    const list = document.getElementById("warningList");
    list.innerHTML = "";

    if (warnings.length === 0) {
        list.innerHTML = "<div>✅ 모든 재고가 충분합니다.</div>";
    } else {
        warnings.forEach(w => {
            list.innerHTML += `
                <div>
                    <b>${w.medicineName}</b> (${w.standard})<br>
                    남은 재고: <span style="color:red;">${w.realInv}</span> / 필요 수량: ${w.quantity}
                </div>`;
        });
    }

    box.classList.add("show");
    setTimeout(() => box.classList.remove("show"), 8000);
})
.catch(err => {
    alert("서버 통신 오류 발생: " + err);
});

document.getElementById("closeWarning").onclick = () =>
    document.getElementById("warningBox").classList.remove("show");
</script>
</body>
</html>

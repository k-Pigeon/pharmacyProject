	<script>
$(document).ready(function(){
	function loadDetailsDaily(saleDate, tbodySelector){
		  $.ajax({
		    url: 'salesDetails.jsp',
		    method: 'GET',
		    data: { saleDate: saleDate },   // ✅ day → saleDate 로 통일
		    success: function(res){
		      var data = (typeof res === 'string') ? JSON.parse(res) : res;
		      if (data.error){ alert(data.error); return; }
		      renderDetailRows(data.rows || [], tbodySelector);
		    },
		    error: function(xhr){ alert('상세 로드 실패: ' + xhr.status); }
		  });
		}

	// 월 상세 (YYYY-MM)
	function loadDetailsMonthly(month, tbodySelector){
	  $.ajax({
	    url: 'salesDetailsMonthly.jsp',
	    method: 'GET',
	    data: { month: month },
	    success: function(data){
	    	if (data.error){ alert(data.error); return; }
	    	renderDetailRows(data.rows || [], tbodySelector);
	    },
	    error: function(xhr){ alert('월 상세 로드 실패: ' + xhr.status); }
	  });
	}

	function renderDetailRows(rows, tbodySelector){
		  var $tbody = $(tbodySelector || '#detailTbody');
		  $tbody.empty();

		  if (!rows || rows.length === 0){
		    $tbody.html('<tr><td colspan="5">데이터 없음</td></tr>');
		    return;
		  }

		  rows.forEach(function(r){
		    var marginRateStr = (r.marginRate != null) ? r.marginRate + '%' : '';
		    var tr =
		      '<tr>' +
		        '<td>'+escapeHtml(r.medicineName || '')+'</td>' +
		        '<td style="text-align:right">'+fmtMoney(r.buyingPrice)+'</td>' +
		        '<td style="text-align:right">'+fmtMoney(r.price)+'</td>' +
		        '<td style="text-align:right">'+fmtMoney(r.margin)+'</td>' +
		        '<td style="text-align:right">'+marginRateStr+'</td>' +
		      '</tr>';
		    $tbody.append(tr);
		  });
		}

		function fmtMoney(v){ 
		  if (v == null) return '0';
		  return Number(v).toLocaleString(); 
		}

		function escapeHtml(s){
		  return String(s).replace(/[&<>"']/g, function(m){
		    return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]);
		  });
		}


	function loadDates(){
		  $.ajax({
		    url: 'salesDetailsMonthly.jsp',
		    method: 'GET',
		    dataType: 'json',
		    data: { month: "2025-03" },  // 원하는 월을 넘김
		    success: function(res){
		    	  try {
		    	    var data = (typeof res === 'string') ? JSON.parse(res) : res;
		    	    if(data.error){
		    	      alert(data.error);
		    	      return;
		    	    }
		    	    // 정상 처리
		    	  } catch(e){
		    	    console.error("JSON 파싱 오류:", res);
		    	    alert("데이터 오류 발생");
		    	  }
		    	},
		    error: function(xhr){ alert('날짜 목록 로드 실패: ' + xhr.status); }
		  });
		}
		// 헬퍼
		function fmtMoney(v){ return Number(v||0).toLocaleString(); }
	// 모달 닫기
	function closeDetailModal(){
	  $('#detailModal').fadeOut(120, function(){
	    $('#detailTbody').empty();
	    $('.modal-day').text('');
	  });
	}

	// 닫기 이벤트 (X 버튼/하단 버튼/배경 클릭/Esc)
	$(document).on('click', '.modal-close', function(){ closeDetailModal(); });
	$(document).on('mousedown', '#detailModal', function(e){
	  if (e.target === this) closeDetailModal();
	});
	$(document).on('keydown', function(e){
	  if (e.key === 'Escape' || e.keyCode === 27){
	    if ($('#detailModal').is(':visible')) closeDetailModal();
	  }
	});


	// ===== 4) 헬퍼 =====
	function fmtMoney(v){ var n = Number(v||0); return n.toLocaleString(); }
	function escapeHtml(s){
	  return String(s).replace(/[&<>"']/g, function(m){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]); });
	}

	// ===== 5) 페이지 로드시 날짜 목록 채우기 =====
	loadDates();

	//사입가 총합계
	$(".buyingTotal").on("click", function(){
		if($(".buyingList").is(":visible")){
			$(".buyingList").hide();
		}else{
		    $.ajax({
		        url: "sumBuyingPrice.jsp",   // DB 합계 구하는 JSP
		        method: "POST",
		        dataType: "json",
		        success: function (response) {
		            if (response && response.totalSum !== undefined) {
		                // 숫자를 3자리마다 콤마 찍어서 표시
		                $(".buyingList .totalPrice").text(
		                    Number(response.totalSum).toLocaleString() + " 원"
		                );
		            } else {
		                $(".buyingList .totalPrice").text("데이터 없음");
		            }
		        },
		        error: function (xhr, status, error) {
		            console.error("합계 불러오기 오류:", error);
		            $(".buyingList .totalPrice").text("오류 발생");
		        }
		    });
		    $(".buyingList").show();
		}
	});
	$("#wrap").on('dblclick', '.salesTable .totalSales tr', function(){
		//월별인 경우
		var checkToggle = $(".toggleSwitch").is(":checked");
		if(checkToggle == true){
			var saleDate = $(this).find("td:eq(0)").text().substr(0, 7);
			$.ajax({
				type: "POST",
				url: "salesDetails.jsp",
				data: {
				 	saleDate: saleDate // 날짜를 전송!
				},
				success: function (response) {
					$("#dayList").html(response);
					$("#detailModal").show();
				},
				error: function (xhr) {
				    console.error("AJAX 오류:", xhr.status);
				}
			});
		}
		//일별인 경우
		if(checkToggle == false){
			var saleDate = $(this).find("td:eq(0)").text();
			$.ajax({
				type: "POST",
				url: "daysDetails.jsp",
				data: {
				 	saleDate: saleDate // 날짜를 전송!
				},
				success: function (response) {
					$(".fotaTable #detailTbody").html(response);
					$("#detailModal").show();
				},
				error: function (xhr) {
				    console.error("AJAX 오류:", xhr.status);
				}
			});
		}
	});

	$("#dayList").on("click", ".salesCheck", function(){
		var detailDate = $(this).text();
		$.ajax({
			type: "POST",
			url: "salesRight.jsp",
			data: {
				detailDate: detailDate // 날짜를 전송!
			},
			success: function (response) {
				$(".fotaTable #detailTbody").html(response);
			},
			error: function (xhr) {
			    console.error("AJAX 오류:", xhr.status);
			}
		});
	});
	$(document).on("click", ".salesCheck", function () {
	    // 기존 선택 해제
	    $(".salesCheck").removeClass("active");
	    // 새로 선택
	    $(this).addClass("active");

	    // 여기서 클릭 이벤트 처리 (예: ajax 호출)
	    // doSomething($(this).text());
	});

	// 방향키로 이동
	$(document).on("keydown", function (e) {
	    let $current = $(".salesCheck.active");

	    if ($current.length === 0) return; // 아직 클릭한 게 없으면 무시

	    if (e.key === "ArrowUp") {
	        let $prev = $current.prev(".salesCheck");
	        if ($prev.length) {
	            $current.removeClass("active");
	            $prev.addClass("active").trigger("click");
	        }
	        e.preventDefault();
	    }

	    if (e.key === "ArrowDown") {
	        let $next = $current.next(".salesCheck");
	        if ($next.length) {
	            $current.removeClass("active");
	            $next.addClass("active").trigger("click");
	        }
	        e.preventDefault();
	    }
	});

	$(document).on("keydown", function(e){
		if((e.key === "Escape" || e.keyCode === 27)){
			e.preventDefault();
			if($(".salesDetail").is(":visible")){
				$(".salesDetail").hide();
			}
			if($(".buyingList").is(":visible")){
			    $(".buyingList").hide();
			}
		}
	});
	//짝홀수 tr 색상구분
	function classification(){
		var $trClassfication = $("#wrap #section").find(".salesTable tbody tr:visible");
		$trClassfication.each(function(index){
			if(index % 2 === 0){
				$(this).css("background-color", "#ddd");
			}else{
				$(this).css("background-color", "#bbb");
			}
		});
		$("#dayList").empty();
	}

	//토글 변함에 따라 표시값도 변화
	function applyView() {
		const grouped = $(".toggleSwitch").is(":checked");
		$(".glanceSummary").toggle(!grouped);
		$(".group-summary").toggle(grouped);
		classification();
	}

	//클릭한 날짜 변수 값에 따라 필터 날짜 변환
	function getDateRangeByValue(valueText){
		let months = 0, days = 0;
		if (valueText.includes("1주일")) days = 7;
		else if (valueText.includes("1개월")) months = 1;
		else if (valueText.includes("3개월")) months = 3;
		else if (valueText.includes("6개월")) months = 6;
		else if (valueText.includes("1년")) months = 12;
		let endDate = new Date();
		let startDate = new Date();
		if (months > 0) startDate.setMonth(startDate.getMonth() - months);
		else if (days > 0) startDate.setDate(startDate.getDate() - days);
		return {
			start: startDate.toISOString().split("T")[0],
			end: endDate.toISOString().split("T")[0],
			months: months
		};
	}

	//검색한 의약품 이름에 따라 토글 사용방식 변환
	function fetchData(opts){
		const isGrouped = $(".toggleSwitch").is(":checked") ? "1" : "0";
		const medicine = $(".medicineTotal").val().trim();
		const data = {
			startDate: opts.startDate,
			endDate: opts.endDate,
			checkedState: isGrouped,
			filterValue: opts.months || 0
		};
		if (medicine !== "") {
			data.medicineTotal = medicine;
			$.post("filterMedicine.jsp", data, function(resp){
				$(".totalSales").html(resp);
				applyView();
			});
		} else {
			$.post("filterSales.jsp", data, function(resp){
				$(".totalSales").html(resp);
				applyView();
			});
		}
	}

	$(".medicineTotal").on("keydown", function(e){
		if(e.key !== "Enter") return;
		e.preventDefault();
		const selected = $(".filterSelect").val() || "1개월";
		const range = getDateRangeByValue(selected);
		$(".startSales").val(range.start);
		$(".endSales").val(range.end);
		fetchData({startDate: range.start, endDate: range.end, months: range.months});
	});

	$(".dateBtnfilter").on("click", function(){
		$(".filterSelect").removeClass("filterSelect");
		$(this).addClass("filterSelect");
		const valueText = $(this).val();
		const range = getDateRangeByValue(valueText);
		$(".startSales").val(range.start);
		$(".endSales").val(range.end);
		fetchData({startDate: range.start, endDate: range.end, months: range.months});
	});

	$(".startSales, .endSales").on("change", function(){
		const start = $(".startSales").val();
		const end = $(".endSales").val();
		if(start && end) fetchData({startDate: start, endDate: end, months: 0});
	});

	$(".toggleSwitch").on("change", function(){
		const start = $(".startSales").val();
		const end = $(".endSales").val();
		if (start && end) fetchData({startDate: start, endDate: end, months: 0});
		$(".filterSelect").click();
	});

	$(".excelDownload").on("click", function(){
		var table = document.querySelector('.salesTable');
		var workbook = XLSX.utils.table_to_book(table, { sheet: "Sheet1" });
		let today = new Date();
		let year = today.getFullYear();
		let month = today.getMonth() + 1;
		let date = today.getDate();
		XLSX.writeFile(workbook, `${year}.${month}.${date}_판매매출현황.xlsx`);
	});

	$(".salesTable").on("mouseover", ".totalSales tr", function(){
		$(".salesTable tr").removeClass("detailTR");
		$(this).addClass("detailTR");
	}).on("mouseout", function(){
		$(".salesTable .totalSales tr").removeClass("detailTR");
	});

	let today = new Date();
	$(".startSales, .endSales").val(today.toISOString().substring(0, 10));
});
</script>


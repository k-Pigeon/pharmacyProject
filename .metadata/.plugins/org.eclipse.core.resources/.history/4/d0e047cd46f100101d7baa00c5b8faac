	<!-- xlsx 라이브러리 로드 (CDN 사용) -->
	<script type="text/javascript">
let currentPage = 1;
let totalPages = 0;
let changedData = {};
let showReturnHidden = false;
let toggleStates = {};

// 페이지 로드 후 실행
$(document).ready(function () {
    initLoad();
    bindEvents();
});

/** 첫 로드시 1페이지 불러오기 **/
function initLoad() {
    loadPage(1, true);
}

/** ======================== 이벤트 바인딩 ======================== **/
function bindEvents() {

    /** 숫자 3자리 콤마 */
    $("#wrap").on("input", ".price, .Buyingprice, .inventory", function () {
        const val = $(this).val().replace(/[^0-9]/g, "");
        $(this).val(val.replace(/\B(?=(\d{3})+(?!\d))/g, ","));
    });

    /** 수정 데이터 수집 */
    $(document).on("input", ".editable", function () {
        const key = $(this).closest("tr").data("key");
        const field = $(this).attr("name");
        const value = $(this).val();

        if (!changedData[key]) changedData[key] = {};
        changedData[key][field] = value;
    });

    /** 엔터 입력 시 바코드 submit */
    $(document).keydown(function (event) {
        if (event.key === "Enter" && $("#barcodeInput").val()) {
            event.preventDefault();
            $('#formTeg').submit();
        }
    });

    /** 저장 버튼 */
    $("#saveAll").click(function () {
        if (!Object.keys(changedData).length) {
            alert("변경된 데이터가 없습니다.");
            return;
        }

        $.ajax({
            url: "saveAll.jsp",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(changedData),
            success: () => {
                alert("저장 완료!");
                loadPage(currentPage, false);
            }
        });
    });

    /** 포커스 기반 행/열 강조 */
    $("#wrap").on("focus", ".table_line input", handleFocus);

    /** 방향키 이동 */
    $("#wrap .table_line").on("keydown", "input", arrowMove);

    /** 마우스 hover 효과 */
    $("#wrap .table_line").on("mouseover", "tr", hoverRow)
                          .on("mouseout", "tr", hoverRow);

    /** 우클릭 상세메뉴 */
    $("#wrap .table_line").on("contextmenu", "tr", showContextMenu);

    /** ESC → 설정창 토글 */
    $(document).keydown((e) => {
        if (e.key === "Escape") $("#coordinates").hide();
    });

    /** 페이지네이션 */
    $("#nextPage").click(() => { if (currentPage < totalPages) loadPage(currentPage + 1); });
    $("#prevPage").click(() => { if (currentPage > 1) loadPage(currentPage - 1); });

    /** 검색 필터 */
    $("#nameSearch").on("input", filterByName);
    $("#kindValue").on("change", filterByKind);

    /** 반품 토글 */
    $('#toggleButton').click(toggleReturnRows);

    /** 상세 팝업 닫기 */
    $("#detailInfo_popup, #paymentInto_popup").on("click", ".popupDown, .close-button", hidePopup);
    $("#wrap .table_line #inventory_list").on("click", "tr td input", function(){
    	(this).select();
    });
    
    $("#wrap").on("input",".table_line .deliveryDate, .table_line .receipDate", function () {
        $(this).val(formatDateInput($(this).val()));
    });

}

/** ======================== 기능 함수 ======================== **/
function formatDateInput(value) {
    // 숫자만 추출
    let v = value.replace(/[^0-9]/g, "");

    // 자리수 제한 (6자리)
    v = v.substring(0, 6);

    // 자동 슬래시 삽입
    if (v.length >= 5) {
        v = v.replace(/(\d{2})(\d{2})(\d{1,2})/, "$1/$2/$3");
    } else if (v.length >= 3) {
        v = v.replace(/(\d{2})(\d{1,2})/, "$1/$2");
    }

    return v;
}


function loadPage(page, updatePageInfo = true) {
    $.ajax({
        url: "getDatas.jsp",
        type: "GET",
        data: { page },
        dataType: "json",
        success: function (res) {
            $("#inventory_list").html(res.html);
            currentPage = page;
            totalPages = res.totalPages;
            if (updatePageInfo) $("#pageInfo").text(page + " / " + totalPages);

            showFirstToggleButton(); // 재고 그룹 초기화
        }
    });
}

function handleFocus() {
    $(".focusRow, .focusCol, .focusCell").removeClass("focusRow focusCol focusCell");

    const $tr = $(this).closest("tr");
    const col = $(this).closest("td").index();

    $tr.addClass("focusRow");
    $(".table_line tbody tr").each(function () {
        $(this).children("td").eq(col).addClass("focusCol");
    });
    $(this).closest("td").addClass("focusCell");
}

function arrowMove(e) {
    const dir = { ArrowUp: -1, ArrowDown: 1 };
    const key = e.key;
    if (!["ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight"].includes(key)) return;

    const td = $(this).closest("td");
    const tr = $(this).closest("tr");
    const col = td.index();
    let nextInput;

    if (key === "ArrowUp" || key === "ArrowDown") {
        const nextTr = key === "ArrowUp" ? tr.prev() : tr.next();
        nextInput = nextTr.children("td").eq(col).find("input");
    } else {
        const add = key === "ArrowLeft" ? -1 : 1;
        nextInput = tr.children("td").eq(col + add).find("input");
    }

    if (nextInput?.length) {
        e.preventDefault();
        nextInput.focus().select();
    }
}

function hoverRow() {
    if (!$("#coordinates").is(":visible")) $(this).toggleClass("selectDetail");
}

function showContextMenu(e) {
    e.preventDefault();
    const x = e.pageX, y = e.pageY;
    $("#coordinates").css({ top: y + 10, left: x + 10 }).show();
    $(this).addClass("selectDetail");
}

function hidePopup() {
    $(".selectDetail").removeClass("selectDetail");
    $("#coordinates").hide();
    $(this).hide();
}

function filterByName() {
    const search = $(this).val().toLowerCase();
    $(".table_line tbody tr").each(function () {
        $(this).toggle($(this).find("td:eq(1)").text().toLowerCase().includes(search));
    });
}

function filterByKind() {
    const val = $(this).val();
    if (val === "전체") return location.reload();

    $(".table_line tbody tr").hide().filter(function () {
        return $(this).find("td:eq(5)").text() === val;
    }).show();
}

function toggleReturnRows() {
    showReturnHidden = !showReturnHidden;
    $("#inventory_list tr").each(function () {
        const txt = $(this).find("td:nth-child(11) button").text();
        if (txt === "반품됨") $(this).toggle(!showReturnHidden);
    });
    $("#toggleText").text(showReturnHidden ? "반품 ON" : "반품 OFF");
}

function keyDetailAction(e) {
    const selected = $("#inventory_list tr.selectDetail");
    if (!selected.length) return;
    if (e.key.toUpperCase() === "D") requestSaleRecord();
    if (e.key.toUpperCase() === "E") requestPaymentRecord();
}

function requestSaleRecord() {
    const val = $(".selectDetail td:eq(1)").text();
    $.post("Respectively_saleRecord.jsp", { value: val }, function (res) {
        $("#detailInfo_popup").html(res).show();
    });
}

function requestPaymentRecord() {
    const val = $(".selectDetail td:eq(1)").text();
    $.post("Respectively_payment.jsp", { value: val }, function (res) {
        $("#paymentInto_popup").html(res).show();
    });
}

/** 동일 제품 접기 기능 초기 적용 */
function showFirstToggleButton() {
    const rows = $("#inventory_list tr").toArray();
    const group = {};

    rows.forEach(row => {
        const name = row.cells[1].textContent;
        if (!group[name]) group[name] = [];
        group[name].push(row);
    });

    // 첫 row에만 토글 버튼
    for (const name in group) {
        const arr = group[name];
        arr.forEach((r, i) => {
            const btn = $(r).find(".toggle-details");
            btn.toggle(i === 0);
        });
    }
}
</script>


@charset "UTF-8";

/* =========================
   기본 리셋
========================= */

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    font-size: 14px;
    background: #f0f0f0;
}

table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
}

/* =========================
   페이지 레이아웃
========================= */

.sale-body {
    overflow-x: hidden;
}

.wrap-container {
    text-align: center;
}

.sale-title-area {
    margin: 20px 0 30px 0;
}

.layout-grid {
    display: grid;
    grid-template-columns: 68% 32%;
    column-gap: 30px;
    align-items: start;
    padding: 10px;
}

.right-ui-area,
.left-ui-area {
    margin-top: 0;
}

/* =========================
   판매 테이블 공통
========================= */

.table_line {
    width: 100%;
    background: #f9f9f9;
}

.table_line th {
    background: #e0e0e0;
    font-weight: 600;
}

.table_line th,
.table_line td {
    padding: 8px 6px;
    height: 42px;
    text-align: center;
    border: 1px solid #ccc;
    white-space: nowrap;
}

/* =========================
   입력칸 통일
========================= */

.table_line input[type="text"] {
    width: 100%;
    height: 28px;
    padding: 2px 6px;
    font-size: 13px;
    text-align: center;
    border: 1px solid #bbb;
    border-radius: 4px;
    background: #fff;
}

.table_line input[type="text"]:focus {
    outline: none;
    border-color: #4CAF50;
}

/* =========================
   스크롤 테이블
========================= */

.scroll-table-area {
    max-height: 160px;
    overflow-y: auto;
    border: 1px solid #999;
    margin-bottom: 10px;
}

/* =========================
   세트 테이블
========================= */

.regularTable {
    width: 100%;
    border: 1px solid #F6C7C3;
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
}

.regularTable thead {
    background-color: #cdeed1;
}

.regularTable th,
.regularTable td {
    height: 42px;
    padding: 6px;
    font-size: 14px;
    border: 1px solid #F6C7C3;
    text-align: center;
}

.regularTable td:hover {
    background-color: #ffeceb;
    cursor: pointer;
}

/* =========================
   세트 뚜껑 효과
========================= */

.leftLid,
.rightLid {
    position: absolute;
    width: 50%;
    height: 50px;
    background-color: #C0E4C4;
    line-height: 50px;
    font-weight: bold;
    transition: 0.3s;
}

.leftLid { left: 0; }
.rightLid { right: 0; }

.regularTable thead th {
    position: relative;
}

/* =========================
   고객 입력 UI
========================= */

.consumerInfo {
    display: flex;
    gap: 15px;
    margin-bottom: 10px;
}

.coolinput label.text {
    font-size: 12px;
    color: #666;
}

.memberName,
.scheduleDate {
    height: 34px;
    padding: 4px 8px;
    border: 1px solid #aaa;
    border-radius: 5px;
}

/* =========================
   버튼
========================= */

button,
.discount-btn {
    padding: 6px 12px;
    font-size: 13px;
    border-radius: 5px;
    border: none;
    cursor: pointer;
}

#exhaustionInv {
    width: 100%;
    height: 45px;
    font-size: 16px;
    background: #4CAF50;
    color: #fff;
}

#preparations div {
    display: flex;
    justify-content: center;
    gap: 6px;
}

/* =========================
   경고 박스
========================= */

#warningBox {
    position: fixed;
    right: 20px;
    bottom: -300px;
    width: 360px;
    background: #fff8f8;
    border: 1px solid #ffb3b3;
    border-radius: 10px;
    padding: 15px;
    opacity: 0;
    transition: 0.5s;
    z-index: 9999;
}

#warningBox.show {
    bottom: 20px;
    opacity: 1;
}

/* =========================
   팝업
========================= */

.popup-window {
    display: none;
    position: fixed;
    inset: 10%;
    background: #fff;
    border: 1px solid #aaa;
    z-index: 1000;
    padding: 10px;
}

.popup-table {
    height: 100%;
    overflow-y: auto;
}

/* =========================
   기타
========================= */

.checkinv-box {
    display: none;
}

.medicineTable,
.statementTable {
    display: none;
}

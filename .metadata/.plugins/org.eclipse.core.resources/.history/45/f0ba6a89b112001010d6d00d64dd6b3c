	<script>
		$(document).ready(function(){
			$(".resultData tr.selectRegist").on("click", function() {
	    		var custnumber = $(".custnumber").val();  // 고객 번호
	    		var memo = $(".memoTextarea").val();  // 메모 값 (textarea 값)
			    console.log("고객 번호:", custnumber); // 고객 번호 확인
			    console.log("메모:", memo); // 메모 값 확인
		
				    // 서버로 AJAX 요청 보내기
			    $.ajax({
			        url: 'yourServerEndpoint.jsp',  // 서버로 요청할 JSP 엔드포인트 (위에서 작성한 JSP)
			        method: 'GET',  // GET 요청
			        data: { custnumber: custnumber, memo: memo },  // 고객 번호와 메모를 데이터로 전송
			        success: function(response) {
	  			        console.log("서버 응답: ", response);  // 서버에서 보내준 JSON 응답을 출력
	    	        if (response.error) {
	    	            console.error("오류: " + response.error);  // 오류 메시지 출력
	    	        } else {
    		            console.log("고객 번호: " + response.rowNumber);
       			        console.log("메모: " + response.memo);  // 메모 값 출력
       			        alert(response.message);  // 서버에서 응답한 메시지 출력
    			    }
       				},error: function(xhr, status, error) {
	    	        	console.error("AJAX 요청 실패: " + error);  // AJAX 오류 처리
       				}
    			});
			});
			$(".closeMedicine").on("click", function(){
				$("#medicinepopup").hide();
			});
		
			$(".resultData").on("click","tr", function() {
			    var selectedRow = $(".resultData tr");  // 선택된 tr (selectRegist 클래스가 추가된 tr)

			    if (selectedRow.length > 0) {
			        var custnumber = $(".custnumber").val();  // 고객 번호

			        console.log("고객 번호:", custnumber); // 고객 번호 확인

			        // AJAX 요청
			        $.ajax({
			            url: 'yourServerEndpoint.jsp',  // 서버로 요청할 JSP 엔드포인트
			            method: 'GET',
			            data: { custnumber: custnumber },
			            success: function(response) {
			                console.log("서버 응답: ", response);  // 서버에서 보내준 JSON 응답을 출력
			                if (response.error) {
			                    console.error("오류: " + response.error);  // 오류 메시지 출력
			                } else {
			                    console.log("고객 번호: " + response.rowNumber);
			                    console.log("메모: " + response.memo);  // 메모 값 출력
			                    $(".memoTextarea").val(response.memo);  // 텍스트에 메모 삽입
			                }
			            },
			            error: function(xhr, status, error) {
			                console.error("엑셀 검색 실패: " + error);  // AJAX 오류 처리
			            }
			        });
			    } else {
			        console.log("선택된 행이 없습니다.");
			    }
			});

			$(".saveBtn").on("click", function(){
				var memberName = $(".memberName").val();//고객 순 번호
				var memberPhone = $(".memberphone").val();//메모 정보
				var custnumber = $(".custnumber").val();//고객 순 번호
				var memo = $(".memoTextarea").val();//메모 정보
				
				$.ajax({
					url: 'saveMemo.jsp',
					method: 'POST',
					data:{
						memberName : memberName,
						memberPhone : memberPhone,
						custnumber : custnumber,
						memo : memo
					},
					success: function(response){
						alert("메모가 저장되었습니다!");
						location.href='salesRegistration.jsp';
					},
					error: function(xhr, status, error){
						alert("제정 오류!");
					}
				});
			});

			$("#section .searchUi .DorU .registUpdate").on("click", function(){
				var regiDate = $("#section .searchUi .resultData tr.selectRegist").find("td:eq(0)").text();
		        if ($(".custnumber").val() == "" || $(".custnumber").val() == null) {
		            return false;
		        }
		        var customerId = $(".custnumber").val(); // 고객번호
		        var discounted = $(".discounted").val() || 0; // 할인가격

		        var medicines = [];
		        $(".insertTR").each(function() {
		            var medicine = {
		                medicineName: $(this).find(".medicineName").val(),
		                inventory: $(this).find(".inventory").val(),
		                standard: $(this).find(".standard").val(),
		                price: $(this).find(".price").val(),
		                totalPrice: $(this).find(".totalPrice").val(),
		                customerId: customerId,
		                discounted: discounted,
		                regiDate : regiDate
		            };
		            medicines.push(medicine);
		            console.log(medicine);
		        });

		        // Ajax 요청
		        $.ajax({
		            url: 'saveSalesData.jsp',  // 데이터 처리할 JSP 페이지
		            method: 'POST',
		            data: {
		                customerId: customerId,
		                discounted: discounted,
		                regiDate: regiDate,
		                medicines: JSON.stringify(medicines)  // JSON 형식으로 보내기
		            },
		            success: function(response) {
		                alert('데이터가 저장되었습니다!');
		                console.log(response);  // 서버 응답 확인
		                location.href = 'salesRegistration.jsp';
		            },
		            error: function(xhr, status, error) {
		                alert('데이터 저장에 실패했습니다.');
		                console.log(error);  // 에러 확인
		            }
		        });
			});
			
			$("#section .searchUi .DorU .registDelete").on("click", function(){
				var regiDate = $("#section .searchUi .resultData tr.selectRegist").find("td:eq(0)").text();
				var Judgment = "2";
				var result = confirm("해낭 날짜의 정보를 삭제하시겠습니까?");
				if(result){
			        $.ajax({
			            url: 'DorU.jsp',  // 데이터 처리할 JSP 페이지
			            method: 'POST',
			            data: {
			            	regiDate: regiDate
			            },
			            success: function(response) {
			                alert('데이터가 저장되었습니다!');
			                console.log(response);  // 서버 응답 확인
			                location.href = 'salesRegistration.jsp';
			            },
			            error: function(xhr, status, error) {
			                alert('데이터 저장에 실패했습니다.');
			                console.log(error);  // 에러 확인
			            }
			        });
				} else{
					alert("삭제가 취소되었습니다.");
					return false;
				}
			});
			$(".removeTr").on("click", function(){
			    $(this).closest("tr").remove();
			});
			$(".copyright").on("click", function() {
			    if ($(".copyTable tbody tr").length == '0') {
			        return false;
			    }
			    // .copyTable의 tbody 안에 있는 모든 tr을 복제
			    var copiedRows = $(".copyTable tbody.registrationData tr").clone();
			    
			    // 복제한 행을 .registrationData에 추가
			    $(".membertable tbody.registrationData").prepend(copiedRows);
			    
			    // .copyTable의 tbody.registrationData의 모든 tr을 삭제
			    $(".copyTable tbody.registrationData").empty();
		        $(".discounted").val($(".saleD").val());
		        $(".saleD").empty();
			    
			    updateTotalCalcul(); // 합계 갱신
			});

			$(document).keydown(function(e) {
				if(e.keyCode == "27"){
					if($("#popup").is(":visible")){
						if(confirm("새 고객을 등록하시겠습니까?")){
							$("#wrap").addClass("newMem");
							$("#popup").hide();
						}
						else{
							alert("새 고객 등록을 취소합니다.");
							return false;
						}
					}
					else{
						return false;	
					}
				}
				if(e.key == "F6"){
					e.preventDefault();
					var regiDate = $("#section .searchUi .resultData tr.selectRegist").find("td:eq(0)").text();
					var Judgment = "2";
					var result = confirm("해낭 날짜의 정보를 삭제하시겠습니까?");
					if(result){
				        $.ajax({
				            url: 'DorU.jsp',  // 데이터 처리할 JSP 페이지
				            method: 'POST',
				            data: {
				            	regiDate: regiDate
				            },
				            success: function(response) {
				                alert('데이터가 저장되었습니다!');
				                console.log(response);  // 서버 응답 확인
				                location.href = 'salesRegistration.jsp';
				            },
				            error: function(xhr, status, error) {
				                alert('데이터 저장에 실패했습니다.');
				                console.log(error);  // 에러 확인
				            }
				        });
					} else{
						alert("삭제가 취소되었습니다.");
						return false;
					}
				}
				if(e.key == "F10"){
					var regiDate = $("#section .searchUi .resultData tr.selectRegist").find("td:eq(0)").text();
			        if ($(".custnumber").val() == "" || $(".custnumber").val() == null) {
			            return false;
			        }
			        var customerId = $(".custnumber").val(); // 고객번호
			        var discounted = $(".discounted").val() || 0; // 할인가격

			        var medicines = [];
			        $(".insertTR").each(function() {
			            var medicine = {
			                medicineName: $(this).find(".medicineName").val(),
			                inventory: $(this).find(".inventory").val(),
			                standard: $(this).find(".standard").val(),
			                price: $(this).find(".price").val(),
			                totalPrice: $(this).find(".totalPrice").val(),
			                customerId: customerId,
			                discounted: discounted,
			                regiDate : regiDate
			            };
			            medicines.push(medicine);
			            console.log(medicine);
			        });

			        // Ajax 요청
			        $.ajax({
			            url: 'saveSalesData.jsp',  // 데이터 처리할 JSP 페이지
			            method: 'POST',
			            data: {
			                customerId: customerId,
			                discounted: discounted,
			                regiDate: regiDate,
			                medicines: JSON.stringify(medicines)  // JSON 형식으로 보내기
			            },
			            success: function(response) {
			                alert('데이터가 저장되었습니다!');
			                console.log(response);  // 서버 응답 확인
			                location.href = 'salesRegistration.jsp';
			            },

<!DOCTYPE html>
<html>
<head>
<title>에스팜</title>
<style>
#header ul {
	display: block;
}

#wrap #section {
	display: block;
	width: 100%;
	height: 95vh;
	transform: translateY(5vh);
}

#wrap #section h1 {
	text-align: center;
}

.salesTable {
    width: 90%;
    margin: auto;
    border-collapse: collapse;
    table-layout: fixed;
    min-width: 700px; /* 필요시 최소 너비 설정 */
}

.salesTable thead th {
    position: sticky;
    top: 0;
    background-color: #eee;
    z-index: 2;
}

.salesTable th, .salesTable td {
    padding: 10px;
    text-align: center;
    border: 1px solid #ccc;
    word-wrap: break-word;
}

/* 열 비율 강제 조정 */
.salesTable th:nth-child(1),
.salesTable td:nth-child(1) {
    width: 20%;
}

.salesTable th:nth-child(2),
.salesTable td:nth-child(2),
.salesTable th:nth-child(3),
.salesTable td:nth-child(3),
.salesTable th:nth-child(4),
.salesTable td:nth-child(4),
.salesTable th:nth-child(5),
.salesTable td:nth-child(5) {
    width: 20%;
}


</style>
</head>
<body>
	<div id="wrap" style="display: block;">
		<header>
			<jsp:include page="header.jsp"></jsp:include>
		</header>
		<section id="section">
			<h1>매출</h1>
			<table border="1" class="salesTable">
				<thead>
					<tr>
						<th>날짜</th>
						<th>판매액</th>
						<th>사입가</th>
						<th>마진</th>
						<th>마진률</th>
					</tr>
				</thead>
				<tbody id="totalSales">
					<%
					PreparedStatement pstmt = null;
					ResultSet rs = null;

					String sql = "SELECT date(saleDate) AS SalesDate FROM salesRecord";
					pstmt = conn.prepareStatement(sql);
					rs = pstmt.executeQuery();

					while (rs.next()) {
					%>
					<tr>
						<td><%=rs.getString("SalesDate")%></td>
						<td></td>
						<td></td>
						<td></td>
						<td></td>
					</tr>
					<%
					}
					%>
				</tbody>
			</table>

		</section>
	</div>
	<script src="jquery-3.7.1.min.js"></script>
	<script src="script.js"></script>
	<script>
	</script>
</body>
</html>
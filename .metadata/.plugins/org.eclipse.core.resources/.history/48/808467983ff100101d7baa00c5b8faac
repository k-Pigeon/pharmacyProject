/* ==============================
   #wrap 외부 UI
============================== */

#coordinates {
    position: absolute;
    background: #ADD8E6;
    border: 2px solid #4682B4;
    width: 200px;
    height: 80px;
    border-radius: 5px;
    display: none;
}

#coordinates span {
    display: block;
    height: 50%;
    font-size: 20px;
    text-align: center;
    color: black;
}

#coordinates span:hover {
    background: #B0C4DE;
    color: white;
    cursor: pointer;
}

#detailInfo_popup,
#paymentInto_popup {
    display: none;
    width: 50vh;
    height: 40vh;
    border: 2px solid black;
    border-radius: 50px;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%,-50%);
    background: white;
    z-index: 3;
}

.settingPage {
    width: 100%;
    height: 100vh;
    position: absolute;
    background-color: #DCDCDC;
    z-index: 100;
    opacity: 0.8;
    display: none;
}

.settingPage.showSetting {
    display: block;
}

/* ==============================
   경고 애니메이션
============================== */

#wrap .alert-container {
    position: relative;
    width: 100px;
    height: 100px;
    transform: translate(40px,-30px);
    display: none;
}

#wrap .alert-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    border: 4px solid rgba(255,0,0,0.6);
    border-radius: 50%;
    animation: ripple 1.5s infinite;
}

#wrap .alert-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%,-50%);
    font-size: 24px;
    color: red;
}

@keyframes ripple {
    0% { width:10px; height:10px; opacity:1; }
    100% { width:100px; height:100px; opacity:0; }
}
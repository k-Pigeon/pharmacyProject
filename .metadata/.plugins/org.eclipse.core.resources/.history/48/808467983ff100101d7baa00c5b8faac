@charset "UTF-8";

* {
	padding: 0;
	margin: 0;
	box-sizing: border-box;
}

a {
	text-decoration: none;
}

ul {
	list-style: none;
}
@media screen and (max-width: 800px) {
    .table_line th,
    .table_line td {
        text-align: left;
    }
}
#header {
    width: 100%;
    height: auto;
    overflow-x: auto;
    overflow: visible; /* 드롭다운 표시 */
    color: white;
    line-height: 40px;
    position: fixed;
    z-index: 5000; /* wrap보다 위 */
    font-size: 20px;
}
.searchFocus{
	    box-shadow: 0px 10px 10px -10px;
}
#header ul li a.pageShow {
	color:red;
	border-bottom: 2px solid black;
}

#header ul li a {
	float: left;
	padding: 0 10px;
}

#userInfo {
    position: absolute;
    width: 250px;
    height: 150px;
    display: none;
    background-color: white;
    border: 1px solid black;
    z-index: 9999 !important; /* header 위에 떠야 표시됨 */
}


#wrap .table_line .dataSet{
	border: none;
    background: none;
    outline: none;
    color: black;
}

#wrap #header .btn-4 {
  width: 200px;
  font-size: 18px;
  position: relative;
  color: #000;
  z-index: 2;
  line-height: 40px;
  padding: 0;
}
#wrap #header .btn-4:hover{
  border: none;
}
#wrap #header .btn-4:before,
#wrap #header .btn-4:after {
  position: absolute;
  content: "";
  width: 0%;
  height: 0%;
  border: 2px solid;
  z-index: -1;
  transition: all 0.3s ease;
}

#wrap #header .btn-4:before {
   top: 0;
   left: 0;
   border-bottom-color: transparent;
   border-right-color: transparent;
   border-top-color: #000;
   border-left-color: #000;
}
#wrap #header .btn-4:after{
   bottom: 0;
   right: 0;
   border-top-color: transparent;
   border-left-color: transparent;
   border-bottom-color: #000;
   border-right-color: #000;
}
#wrap #header .btn-4:hover:before,
#wrap #header .btn-4:hover:after {
  border-color: #000;
  height: 100%;
  width: 100%;
}


.table_line th,
.table_line td {
    white-space: normal; /* 줄 바꿈 허용 */

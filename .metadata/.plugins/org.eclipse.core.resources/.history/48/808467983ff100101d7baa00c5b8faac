.container.addProduct {
    width: 100%;
    padding: 20px;
}
.container.addProduct #productForm input {
    margin-bottom: 10px;
    width: 23%;
    padding: 10px;
    font-size: 15px;
    border: 1px solid #ccc;
}
.container.addProduct #productForm #standardPriceContainer .standardPriceGroup {
    display: flex;
    gap: 10px;
    margin: 1% 0;
}
.container.addProduct #productForm #standardPriceContainer .standardPriceGroup input[type="text"] {
    border: 2px solid transparent;
    width: 15em;
    height: 2.5em;
    padding-left: 0.8em;
    outline: none;
    overflow: hidden;
    background-color: #DCDCDC;
    border-radius: 10px;
    transition: all 0.5s;
}

.container.addProduct #productForm #standardPriceContainer .standardPriceGroup input[type="text"]:focus {
    border: 2px solid #4A9DEC;
    box-shadow: 0px 0px 0px 7px rgb(74, 157, 236, 20%);
    background-color: white;
}
.container.addProduct #productForm #standardPriceContainer .standardPriceGroup .removeStandardPrice {
    background: red;
    color: white;
    border: none;
    cursor: pointer;
    width: 35px;
    height: 35px;
    line-height: 35px;
    border-radius: 100%;
    font-size: 30px;
}
.container.addProduct #productForm .submitNew,
.container.addProduct #productForm #addStandardPrice {
    position: absolute;
    color: #090909;
    padding: 0.7em 1.7em;
    font-size: 18px;
    border-radius: 0.5em;
    background: #e8e8e8;
    cursor: pointer;
    border: 1px solid #e8e8e8;
    transition: all 0.3s;
    box-shadow: 
        6px 6px 12px #c5c5c5,
       -6px -6px 12px #ffffff;
    left: 50%;
    transform: translateX(-50%);
}

.container.addProduct #productForm .submitNew:active,
.container.addProduct #productForm #addStandardPrice:active {
    color: #666;
    box-shadow:
        0px 0px 0px #c5c5c5,
        0px 0px 0px #ffffff,
        inset 4px 4px 12px #c5c5c5,
        inset -4px -4px 12px #ffffff;
}
.container.addProduct #productForm #addStandardPrice {
    position: relative;
    left: 10%;
}
.container.addProduct #productForm .closeAdd {
    height: 3em;
    width: 8em;
    border: none;
    border-radius: 10em;
    background: #016DD9;
    font-size: 17px;
    color: #ffffff;
    font-family: inherit;
    font-weight: 500;
    float: right;
}

.container.addProduct #productForm .closeAdd:hover {
    animation: shake3856 0.3s linear infinite both;
}
@keyframes shake3856 {
    0%   { transform: translate(0); }
    20%  { transform: translate(-2px, 2px); }
    40%  { transform: translate(-2px, -2px); }
    60%  { transform: translate(2px, 2px); }
    80%  { transform: translate(2px, -2px); }
    100% { transform: translate(0); }
}
.container.addProduct #productForm #standardPriceContainer .standardPriceGroup .removeStandardPrice {
    display: none;
}

/* salesRegistration.jsp */
/* =========================
   기본 레이아웃
========================= */

#wrap.salesRegistration {
    display: block;
}

#wrap.salesRegistration > h1 {
    width: 100%;
    height: 10px;
    text-align: center;
    transform: translateY(70px);
}

#wrap.salesRegistration > #section {
    display: grid;
    grid-template-columns: 6fr 4fr;
    width: 95%;
    height: 60vh;
    transform: translateY(25%);
    margin: 0 auto;
}

/* =========================
   공통 테이블
========================= */

#wrap.salesRegistration #section .RegistrationUi .membertable,
#wrap.salesRegistration #section .searchUi .membertable,
#wrap.salesRegistration #section .RegistrationUi .copyTable {
    font-size: 25px;
    border: 2px solid black;
    border-collapse: collapse;
    height: 35px;
    line-height: 35px;
    width: 95%;
    border-spacing: 0;
    backdrop-filter: blur(12px);
    background: rgba(255,255,255,0.15);
    border-radius: 12px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.1);
    color: #333;
    overflow: hidden;
}

#wrap.salesRegistration #section .RegistrationUi .membertable thead th,
#wrap.salesRegistration #section .searchUi .membertable thead th {
    background: rgba(255,255,255,0.25);
    color: #222;
    font-weight: bold;
    text-align: center;
}

#wrap.salesRegistration #section .RegistrationUi .membertable td,
#wrap.salesRegistration #section .searchUi .membertable td {
    text-align: center;
}

#wrap.salesRegistration #section .RegistrationUi .membertable tbody tr {
    height: 42px;
}

/* =========================
   입력 필드
========================= */

#wrap.salesRegistration #section .RegistrationUi input[type="text"],
#wrap.salesRegistration #section .searchUi input[type="text"] {
    width: 60%;
    border: none;
    border-radius: 8px;
    background: rgba(255,255,255,0.35);
    backdrop-filter: blur(8px);
    color: #111;
    font-size: 20px;
}

#wrap.salesRegistration #section .RegistrationUi .discounted,
#wrap.salesRegistration #section .RegistrationUi .totalCalcul,
#wrap.salesRegistration #section .RegistrationUi .maxTotal {
    background: rgba(255,255,255,0.3);
    border-radius: 8px;
    border: none;
}

/* =========================
   버튼
========================= */

#wrap.salesRegistration #section .RegistrationUi .memberDel {
    position: absolute;
    top: -50px;
    left: 0;
    border: none;
    background-color: #DC143C;
    padding: 10px 20px;
    font-size: 12px;
    font-weight: 700;
    color: #fff;
    border-radius: 5px;
    box-shadow: 0px 5px 0px 0px #A52A2A;
    cursor: pointer;
}

#wrap.salesRegistration #section .RegistrationUi .memberDel:active {
    transform: translateY(5px);
    box-shadow: none;
}

#wrap.salesRegistration #section .RegistrationUi .saveBtn {
    width: 10%;
    height: 30%;
    float: right;
    margin-right: 5%;
    font-size: 25px;
}

/* =========================
   메모 textarea
========================= */

#wrap.salesRegistration #section .RegistrationUi .memoTextarea {
    width: 85%;
    height: 30%;
    font-size: 25px;
}

/* =========================
   resultData 테이블 스크롤
========================= */

#wrap.salesRegistration #section .searchUi .resultData tbody {
    display: block;
    max-height: 300px;
    overflow-y: auto;
}

#wrap.salesRegistration #section .searchUi .resultData thead,
#wrap.salesRegistration #section .searchUi .resultData tbody tr {
    display: table;
    width: 100%;
    table-layout: fixed;
}

.selectRegist {

@charset "UTF-8";

* {
	padding: 0;
	margin: 0;
	box-sizing: border-box;
}

a {
	text-decoration: none;
}

ul {
	list-style: none;
}
@media screen and (max-width: 800px) {
    .table_line th,
    .table_line td {
        text-align: left;
    }
}
#header {
	width: 100%;
	height: 50px;
	overflow-x: auto;
	color: white;
	line-height: 40px;
	position:fixed;
	z-index: 200;
}
.searchFocus{
	    box-shadow: 0px 10px 10px -10px;
}
#header ul li a.pageShow {
	color:red;
	border-bottom: 2px solid black;
}

#header ul li a {
	float: left;
	padding: 0 10px;
}

#userInfo{
    width: 250px;
    height: 150px;
    position: absolute;
    border: 1px solid black;
    z-index: 100;
    background-color: white;
    display:none;
}


#wrap .table_line .dataSet{
	border: none;
    background: none;
    outline: none;
    color: black;
}

#wrap #header .btn-4 {
  width: 200px;
  font-size: 18px;
  position: relative;
  color: #000;
  z-index: 2;
  line-height: 40px;
  padding: 0;
}
#wrap #header .btn-4:hover{
  border: none;
}
#wrap #header .btn-4:before,
#wrap #header .btn-4:after {
  position: absolute;
  content: "";
  width: 0%;
  height: 0%;
  border: 2px solid;
  z-index: -1;
  transition: all 0.3s ease;
}

#wrap #header .btn-4:before {
   top: 0;
   left: 0;
   border-bottom-color: transparent;
   border-right-color: transparent;
   border-top-color: #000;
   border-left-color: #000;
}
#wrap #header .btn-4:after{
   bottom: 0;
   right: 0;
   border-top-color: transparent;
   border-left-color: transparent;
   border-bottom-color: #000;
   border-right-color: #000;
}
#wrap #header .btn-4:hover:before,
#wrap #header .btn-4:hover:after {
  border-color: #000;
  height: 100%;
  width: 100%;
}


.table_line th,
.table_line td {
    white-space: normal; /* 줄 바꿈 허용 */
    line-height: 40px; /* 셀 높이 조정 */
}
#wrap {
	display: flex;
    width: 100%;
    min-height: 100vh;
    background-color: RGBA(127, 127, 127, 0.2);
    overflow-x: auto; /* 수정: 가로 스크롤 추가 */
    font-size: 20px;
}

#wrap #data, #wrap #setData{
	flex: 1;
}



#wrap #barcodeInput {
	float: right;
}

#wrap #formTeg {
    height: 25px;
    margin: 0 auto;
    padding: 15px;
    max-width: 1000px;
}

#wrap #formTeg #barcodeInput {
	float: right;
    opacity: 0;
    position:fixed;
	transform: translateX(410%);
}

#wrap .table_line {
    width: 1000px;
    table-layout: fixed;
    border: 1px solid black;
    margin: 0 auto;
    text-align: center;
    margin-top: 5%;
    max-width: 1200px;
}

#wrap #table_input {
    min-width: 1000px;
    table-layout: fixed;
    border: 1px solid black;
    margin: 0 auto;
    text-align: center;
    margin-top: 5%;
    max-width: 1000px;
}

#wrap .table_line colgroup{
	width: auto;
}
#wrap .table_line th{
	background-color: RGBA(127,127,127,0.3);
}
#wrap #table_input th{
	background-color: RGBA(127,127,127,0.3);
}
#wrap .indexTable th,
#wrap #inventory_list{
	border:1px solid white !important;
	box-shadow: 5px 5px 10px;
}
#wrap #inventory_list tr.recordList td{
    background-color: #F0F8FF;
}
#wrap #inventory_list .evenTR{
	background-color: #F0F8FF !important;
}
#wrap .indexTable td{
	border:1px solid white !important;
}
#wrap .indexTable #inventory_list tr:nth-child(even){
	background-color: #F0F8FF;
}
#wrap .table_line th {
	border: 1px solid black;
	border-collapse: collapse;
	height: 40px;
	line-height:30px;
	white-space: nowrap;
    overflow: hidden; /* 수정: 텍스트 넘침 처리 */
    text-align: center;
}
#wrap .table_line td {
	border: 1px solid black;
	border-collapse: collapse;
	height: 40px;
	line-height:40px;
	white-space: nowrap;
    overflow: hidden; /* 수정: 텍스트 넘침 처리 */
    text-align: center;
}

#wrap #table_input th,
#wrap #table_input td {
	border: 1px solid black;
	border-collapse: collapse;
	height: 40px;
	line-height:40px;
	white-space: nowrap;
    overflow: hidden; /* 수정: 텍스트 넘침 처리 */
    text-align: center;
    padding: 10px;
}

#listWrap {
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: rgba(255, 255, 255, 1);
    padding: 20px;
    border-radius: 10px;
    z-index: 1000;
    max-width: 90%;
    overflow-x: scroll;
}

#listWrap .table_line th,
#listWrap .table_line td {
	border:1px solid black;
    width: auto; /* 수정: 테이블 너비를 자동으로 조정 */
}
#listWrap .table_line input{
	border: none;
	background: transparent;
}
.ascendingOrder,
.descendingOrder {
    cursor: pointer;
    font-size: 12px;
}

.ascendingOrder:hover,
.descendingOrder:hover {
    background-color: rgba(0, 0, 0, 0.1);
}

.ascendingOrder:active,
.descendingOrder:active {
    color: blue;
}
.wrap .table_line,
.listWrap .table_line{
	text-align: center;
}
.set_line td{
	line-height:20px;
}
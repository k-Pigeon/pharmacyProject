@charset "UTF-8";

/* ================================
   RESET
================================ */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body.sale-body {
    overflow: hidden;
    font-family: "Noto Sans KR", sans-serif;
    font-size: 14px;
}

/* ================================
   PAGE LAYOUT
================================ */

.wrap-container {
    text-align: center;
}

.sale-title-area {
    position: relative;
    margin: 20px 0 30px;
}

.layout-grid {
    display: grid;
    grid-template-columns: 68% 32%;
    column-gap: 30px;
    align-items: flex-start;
    margin: 10px;
}

.right-ui-area,
.left-ui-area {
    margin-top: 0;
    height: auto;
}

/* ================================
   TABLE COMMON
================================ */

table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
}

.table_line {
    background: #f9f9f9;
}

.table_line th,
.table_line td {
    padding: 8px 6px;
    height: 42px;
    text-align: center;
    vertical-align: middle;
    white-space: nowrap;
    font-size: 14px;
    border: 1px solid #ccc;
}

.table_line thead th {
    background: #e0e0e0;
    font-weight: 600;
}

/* ================================
   INPUTS
================================ */

.table_line input[type="text"] {
    width: 100%;
    height: 28px;
    padding: 2px 6px;
    font-size: 13px;
    text-align: center;
    border: 1px solid #bbb;
    border-radius: 4px;
    background: #fff;
}

/* ================================
   SCROLL TABLE
================================ */

.scroll-table-area {
    max-height: 160px;
    overflow-y: auto;
    border: 1px solid #999;
}

/* ================================
   SET TABLES
================================ */

.regularTable {
    width: 100%;
    border: 1px solid #F6C7C3;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 20px;
}

.regularTable thead {
    background: #CDEFD5;
}

.regularTable th,
.regularTable td {
    height: 42px;
    padding: 6px;
    font-size: 14px;
    border: 1px solid #F6C7C3;
}

/* ================================
   LID ANIMATION
================================ */

.leftLid,
.rightLid {
    position: absolute;
    width: 50%;
    height: 42px;
    line-height: 42px;
    background: #C0E4C4;
    font-weight: bold;
    transition: 0.4s;
}

.leftLid { left: 0; text-align: right; padding-right: 10px; }
.rightLid { right: 0; text-align: left; padding-left: 10px; }

.regularTable thead th:hover .leftLid {
    transform: translateX(-120%);
}
.regularTable thead th:hover .rightLid {
    transform: translateX(120%);
}

/* ================================
   CUSTOMER INPUT AREA
================================ */

.consumerInfo {
    display: flex;
    gap: 10px;
    margin-bottom: 15px;
}

.coolinput {
    display: flex;
    flex-direction: column;
}

.coolinput label {
    font-size: 12px;
    color: #5b6cff;
    margin-left: 6px;
}

.coolinput input.memberName,
.scheduleDate {
    height: 36px;
    padding: 6px 10px;
    border: 1px solid #aaa;
    border-radius: 6px;
}

/* ================================
   BUTTONS
================================ */

button {
    padding: 6px 14px;
    font-size: 13px;
    border-radius: 6px;
    border: none;
    cursor: pointer;
}

.table_line button {
    background: #9aa7b1;
    color: #fff;
}

#exhaustionInv {
    font-size: 16px;
    padding: 10px 0;
}

#preparations div {
    display: flex;
    justify-content: center;
    gap: 6px;
}

/* ================================
   WARNING BOX
================================ */

#warningBox {
    position: fixed;
    right: 20px;
    bottom: -400px;
    width: 360px;
    padding: 20px;
    border-radius: 12px;
    background: #fff8f8;
    border: 1px solid #ffb3b3;
    opacity: 0;
    transition: 0.5s;
    z-index: 9999;
}

#warningBox.show {
    bottom: 20px;
    opacity: 1;
}

/* ================================
   POPUP
================================ */

.popup-window {
    display: none;
    position: fixed;
    inset: 10%;
    background: #fff;
    border: 1px solid #ccc;
    box-shadow: 0 0 10px rgba(0,0,0,.3);
    z-index: 1000;
}

.popup-table {
    height: 80%;
    overflow: auto;
}

/* ================================
   CHECK INV
================================ */

.checkinv-box {
    display: none;
}

/* ================================
   MEDICINE TABLE
================================ */

.medicineTable,
.statementTable {
    display: none;
}

<!DOCTYPE html>
<html>
<head>
<title>에스팜</title>
<style>
#header ul {
	display: block;
}

#wrap #section {
	display: block;
	width: 100%;
	height: 95vh;
	transform: translateY(5vh);
}

#wrap #section h1 {
	text-align: center;
}

#wrap #section .tableWrapper {
	height: 75%;
	overflow-y: auto;
	margin: auto;
	width: 90%;
	border: 1px solid #ccc;
}

#wrap #section .salesTable {
	border-collapse: separate;
	border-spacing: 0;
	width: 100%;
	table-layout: fixed;
}

#wrap #section .salesTable thead th {
	position: sticky;
	top: 0;
	background-color: #6c4ba0;
	z-index: 1;
	color: white;
}

#wrap #section .salesTable th, #wrap #section .salesTable td {
	text-align: center;
	padding: 8px;
	border: 1px solid #ccc;
}

#wrap #section .salesTable td:nth-child(1) {
	background-color: #c6aef0;
	color: white;
}

#wrap #section .salesfilter {
	width: 90%;
	height: 100px;
	margin: 0 auto;
}

#wrap #section .salesfilter .startSales, #wrap #section .salesfilter .endSales
	{
	width: 120px;
	height: 35px;
}

#wrap #section .salesfilter .dateBtn {
	margin-top: 5px;
}

#wrap #section .salesfilter .dateBtn .dateBtnfilter {
	color: #090909;
	padding: 0.7em 1.7em;
	font-size: 18px;
	border-radius: 0.5em;
	background: #e8e8e8;
	cursor: pointer;
	border: 1px solid #e8e8e8;
	transition: all 0.3s;
	box-shadow: 6px 6px 12px #c5c5c5, -6px -6px 12px #ffffff;
}

#wrap #section .salesfilter .dateBtn .dateBtnfilter:active {
	color: #666;
	box-shadow: inset 4px 4px 12px #c5c5c5, inset -4px -4px 12px #ffffff;
}

#wrap #section .salesfilter .excelDownload {
	position: absolute;
	top: 7%;
	right: 5%;
	font-weight: 600;
	color: white;
	text-transform: uppercase;
	padding: 1em 2em;
	background-color: #00bcd4; /* 시원한 바다색 (cyan 계열) */
	border: 2px solid #008ba3;
	border-radius: 10px;
	cursor: pointer;
	box-shadow: 0 8px 12px rgba(0, 128, 192, 0.3);
	transition: background-color 0.2s ease, transform 0.2s ease;
}

#wrap #section .salesfilter .excelDownload:hover {
	background-color: #008ba3;
	transform: translateY(-2px);
	box-shadow: 0 12px 18px rgba(0, 128, 192, 0.4);
}

#wrap #section .salesfilter .excelDownload:active {
	background-color: #006978;
	transform: translateY(1px);
	box-shadow: 0 4px 8px rgba(0, 128, 192, 0.2);
}

#wrap #section .salesfilter .datePicker .toggleSwitch {
	position: relative;
	top: 5px;
	left: 5%;
	height: 2rem;
	width: 100px;
	cursor: pointer;
	appearance: none;
	-webkit-appearance: none;
	border-radius: 9999px;
	background-color: rgba(100, 116, 139, 0.377);
	transition: all .3s ease;
	left: 5%;
}

#wrap #section .salesfilter .datePicker .toggleSwitch:checked {
	background-color: rgba(236, 72, 153, 1);
}

#wrap #section .salesfilter .datePicker .toggleSwitch::after {
	position: absolute;
	width: 95%;
	content: "일별";
	text-align: center;
}

#wrap #section .salesfilter .datePicker .toggleSwitch::before {
	position: absolute;
	content: "";
	left: -20px;
	top: -7px;
	display: block;
	height: 45px;
	width: 45px;
	cursor: pointer;
	border: 1px solid rgba(100, 116, 139, 0.527);
	border-radius: 9999px;
	background-color: rgba(255, 255, 255, 1);
	box-shadow: 0 3px 10px rgba(100, 116, 139, 0.327);
	transition: all .3s ease;
}

#wrap #section .salesfilter .datePicker .toggleSwitch:checked::before {
	transform: translateX(85px);
	border-color: rgba(236, 72, 153, 1);
}

#wrap #section .salesfilter .datePicker .toggleSwitch:checked::after {
	position: absolute;
	width: 95%;
	content: "월별";
	text-align: center;
}
</style>
</head>
<body>
	<div id="wrap" style="display: block;">
		<header>
			<jsp:include page="header.jsp"></jsp:include>
		</header>
		<section id="section">
			<h1>매출</h1>
			<div class="salesfilter">
				<div class="datePicker">
					결재일 : <input type="date" class="startSales"> ~ <input
						type="date" class="endSales"> <input class="toggleSwitch"
						type="checkbox" checked>
				</div>
				<div class="dateBtn">
					<input type="button" class="dateBtnfilter week" value="1주일">
					<input type="button" class="dateBtnfilter month" value="1개월">
					<input type="button" class="dateBtnfilter 3month" value="3개월">
					<input type="button" class="dateBtnfilter 6month" value="6개월">
					<input type="button" class="dateBtnfilter 1year" value="1년">
				</div>
				<button type="button" class="excelDownload">Excel 다운로드</button>
			</div>
			<div class="tableWrapper">
				<table class="salesTable">
					<thead>
						<tr>
							<th>날짜</th>
							<th>판매액</th>
							<th>사입가</th>
							<th>마진</th>
							<th>마진률</th>
						</tr>
					</thead>
					<tbody class="totalSales">

					</tbody>
				</table>
			</div>
		</section>
	</div>
	<script src="jquery-3.7.1.min.js"></script>
	<script
		src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
	<script src="script.js"></script>
	<script>
		$(document).ready(function(){
			function classification(){
				var $trClassfication = $("#wrap #section");
				$trClassfication.find("tr:even").css("background-color", "#ddd");
			}
			classification();
			//날짜 필터링 함수[input date 사용]
			let today = new Date();
			$(".toggleSwitch").on("change", function() {
				let $startInput = $(".startSales");
				let $endInput = $(".endSales");

				let originalStart = new Date($startInput.val());
				let originalEnd = new Date($endInput.val());

				let prevStart = new Date(originalStart);
				prevStart.setDate(prevStart.getDate() - 1);

				let prevEnd = new Date(originalEnd);
				prevEnd.setDate(prevEnd.getDate() - 1);

				const formatDate = date => date.toISOString().split("T")[0];

				$startInput.val(formatDate(prevStart));
				$endInput.val(formatDate(prevEnd));
				$startInput.trigger("change");
				$endInput.trigger("change");

				setTimeout(function() {
					$startInput.val(formatDate(originalStart)).trigger("change");
					$endInput.val(formatDate(originalEnd)).trigger("change");
				}, 100);
			});

			$("#wrap #section .salesfilter").find(".startSales, .endSales").val(today.toISOString().substring(0, 10));
			//input date가 변경 될 경우, 필터링 사용
			$("#wrap #section .salesfilter").find(".startSales, .endSales").on("change", function(){
				const startDate = $(".startSales").val();
				const endDate = $(".endSales").val();
				let checkedState;
				if($(".toggleSwitch").is(":checked")){
					checkedState = "1";
				}else{
					checkedState = "0";	
				}
				if (!startDate || !endDate) return;
				$.ajax({
					url: "filterDate.jsp",
					type: "POST",
					data: { startDate: startDate, endDate: endDate, checkedState: checkedState },
					success: function (response) {
						$(".totalSales").html(response);
				 		if($(".toggleSwitch").is(":checked")){
							$(".totalSales").find(".glanceSummary").hide();
							$(".totalSales").find(".group-summary").show();
						}else{
							$(".totalSales").find(".glanceSummary").show();
							$(".totalSales").find(".group-summary").hide();
						}
					},
					error: function (xhr, status, error) {
						alert("날짜 필터링 실패: " + status);
					}
				});
			});

			//
			function formatDate(date) {
				let yyyy = date.getFullYear();
				let mm = String(date.getMonth() + 1).padStart(2, '0');
				let dd = String(date.getDate()).padStart(2, '0');
				return '${yyyy}-${mm}-${dd}';
			}
			$("#wrap #section .salesfilter .dateBtn .dateBtnfilter").on("click", function(){
				const valueText = $(this).val(); // 예: "1개월"
				let months = 0;
				let days = 0;

				if (valueText.includes("1주일")) {
					days = 7;
				} else if (valueText.includes("1개월")) {
					months = 1;
				} else if (valueText.includes("3개월")) {
					months = 3;
				} else if (valueText.includes("6개월")) {
					months = 6;
				} else if (valueText.includes("1년")) {
					months = 12;
				}

				// 날짜 계산
				let endDate = new Date();
				let startDate = new Date();

				if (months > 0) {
					endDate.setMonth(startDate.getMonth() - months);
				} else if (days > 0) {
					endDate.setDate(startDate.getDate() - days);
				}

				// YYYY-MM-DD 포맷
				const formatDate = date => date.toISOString().split("T")[0];

				// input에 날짜 설정
				$(".startSales").val(formatDate(startDate)).trigger("change");
				$(".endSales").val(formatDate(endDate)).trigger("change");

				// Ajax 요청
				$.ajax({
					url: "filterSales.jsp",
					type: "POST",
					data: { filterValue: months },
					success: function (response) {
						$(".totalSales").html(response); // 결과 삽입
			 			if($(".toggleSwitch").is(":checked")){
							$(".totalSales").find(".glanceSummary").hide();
							$(".totalSales").find(".group-summary").show();
						}else{
							$(".totalSales").find(".glanceSummary").show();
							$(".totalSales").find(".group-summary").hide();
						}
					},
					error: function (xhr, status, error) {
						alert("요청 실패: " + status);
					}
				});
			});

			//Excel download
			$("#wrap #section .salesfilter .excelDownload").on("click", function(){
	            // HTML 테이블 가져오기
	            var table = document.querySelector('.salesTable');
	            var workbook = XLSX.utils.table_to_book(table, { sheet: "Sheet1" });

	            //날짜를 가져올 변수 기둥
	            let today = new Date();   
	            let year = today.getFullYear(); // 년도
	            let month = today.getMonth() + 1;  // 월
	            let date = today.getDate();  // 날짜
	            
	            // 엑셀 파일 다운로드
	            XLSX.writeFile(workbook, year + '.' + month + '.' + date + '_판매매출현황.xlsx');
			});
		});
	</script>
</body>
</html>
		 // мһ…л Ҙ н•„л“ңм—җ лҚ°мқҙн„° мұ„мҡ°кё°
function populateFields(data) {
    currentRow.find(".medicineName").val(data.medicinename);
    currentRow.find(".standard").val(data.standard);
    currentRow.find(".inventory").val("1");

    const addComma = num => num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");

    let buyingPriceRaw = (data.buyingprice ?? "0").toString().replace(/[^0-9]/g, '');
    let priceRaw = (data.price ?? "0").toString().replace(/[^0-9]/g, '');
    let lowerAndHigestRaw = (data.lowerandhigest ?? "0").toString().replace(/[^0-9]/g, '');

    currentRow.find(".Buyingprice").val(addComma(buyingPriceRaw));
    currentRow.find(".price").val(addComma(priceRaw));
    currentRow.find(".lowerAndHigest").val(data.lowerandhigest ?? "");

    currentRow.find(".copyPrice").val(priceRaw);

    let inventory = 1;
    let totalPrice = inventory * parseFloat(priceRaw || 0);

    currentRow.find(".copytotal").val(totalPrice);
    currentRow.find(".totalPrice").val(addComma(totalPrice));

    updateTotalCalcul();
    $("#popup").hide();
    currentRow.find(".DeliveryDate").focus();
}




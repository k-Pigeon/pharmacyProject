		        let formattedTotal = total.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
		        let formattedMaxTotal = maxTotal.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");

		        // 5. кІ°кіј л°ҳмҳҒ
		        $(".totalCalcul").val(formattedTotal);
		        $(".CopytotalCalcul").val(total); // мҲ«мһҗл§Ң


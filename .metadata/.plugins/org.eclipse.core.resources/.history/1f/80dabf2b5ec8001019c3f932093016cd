<%@ page import="java.sql.*, java.util.*, java.util.regex.*"%>
<%@ include file="sessionManager.jsp"%>
<%@ include file="DBconnection.jsp"%>

<%!
double parseStandard(String str) {
    if (str == null) return 1;
    Matcher m = Pattern.compile("\\d+(\\.\\d+)?").matcher(str);
    double result = 1;
    boolean matched = false;
    while (m.find()) {
        matched = true;
        result *= Double.parseDouble(m.group());
    }
    return matched ? result : 1;
}
%>

<%
response.setContentType("application/json; charset=UTF-8");
out.clear();

String idSortation = (String) session.getAttribute("idSortation");

// 모든 행을 조회
String sql = "SELECT medicineName, DeliveryDate, inventory, price, standard, kind, companyName, receiptDate, quantity "
           + "FROM testTable" + idSortation + " WHERE returnInv='0'";

PreparedStatement ps = conn.prepareStatement(sql);
ResultSet rs = ps.executeQuery();

// 이름별 합산 저장할 Map
class Info {
    double totalRealInventory = 0; // inventory / standard 합계
    double totalQuantity = 0;      // quantity 합계
    String DeliveryDate, price, standard, kind, companyName, receiptDate;
}

Map<String, Info> map = new HashMap<>();

// 1. 모든 row 읽어서 map에 합산
while (rs.next()) {
    String name = rs.getString("medicineName");

    double inventory = rs.getDouble("inventory");
    double quantity  = rs.getDouble("quantity");
    String standard  = rs.getString("standard");

    double realInv = inventory / parseStandard(standard);

    Info data = map.getOrDefault(name, new Info());

    // 합산
    data.totalRealInventory += realInv;
    data.totalQuantity      += quantity;

    // 대표 데이터 저장 (아무거나 1개)
    data.DeliveryDate = rs.getString("DeliveryDate");
    data.price        = rs.getString("price");
    data.standard     = standard;
    data.kind         = rs.getString("kind");
    data.companyName  = rs.getString("companyName");
    data.receiptDate  = rs.getString("receiptDate");

    map.put(name, data);
}

rs.close();
ps.close();
conn.close();

// 2. 합산된 데이터 기준으로 부족 여부 판단
StringBuilder html = new StringBuilder();
boolean found = false;

for (String name : map.keySet()) {
    Info d = map.get(name);

    if (d.totalRealInventory < d.totalQuantity) {
        found = true;

        html.append("<tr>");
        html.append("<td>").append(name).append("</td>");
        html.append("<td>").append(d.DeliveryDate).append("</td>");
        html.append("<td>").append(d.totalRealInventory).append("</td>");
        html.append("<td>").append(d.price).append("</td>");
        html.append("<td>").append(d.standard).append("</td>");
        html.append("<td>").append(d.kind).append("</td>");
        html.append("<td>").append(d.companyName).append("</td>");
        html.append("<td>").append(d.receiptDate).append("</td>");
        html.append("<td>").append(d.totalQuantity).append("</td>");
        html.append("</tr>");
    }
}

// 3. JSON 출력
out.print("{");
out.print("\"found\": " + found + ",");
out.print("\"html\": \"" + html.toString().replace("\"", "\\\"") + "\"");
out.print("}");
%>

<%
    String period = request.getParameter("period"); // 'week' 또는 'month' 값을 받음
    Statement stmt = null;
    ResultSet rs = null;
    String query = "";

    // period에 따라 다른 쿼리 실행
    if ("week".equals(period)) {
        query = "SELECT DATE(saleDate) AS saleDate, price, inventory, standard " +
                "FROM SalesRecord " +
                "WHERE saleDate >= CURDATE() - INTERVAL 7 DAY";
    }
    else if ("month1".equals(period)) {
        query = "SELECT DATE(saleDate) AS saleDate, price, inventory, standard " +
                "FROM SalesRecord " +
                "WHERE saleDate >= CURDATE() - INTERVAL 1 MONTH";
    }
    else if ("month3".equals(period)) {
        query = "SELECT DATE(saleDate) AS saleDate, price, inventory, standard " +
                "FROM SalesRecord " +
                "WHERE saleDate >= CURDATE() - INTERVAL 3 MONTH";
    }
    else if ("month6".equals(period)) {
        query = "SELECT DATE(saleDate) AS saleDate, price, inventory, standard " +
                "FROM SalesRecord " +
                "WHERE saleDate >= CURDATE() - INTERVAL 6 MONTH";
    }

    try {
        conn = DriverManager.getConnection(jdbcDriver, dbUser, dbPwd);
        stmt = conn.createStatement();
        rs = stmt.executeQuery(query);

        List<String> data = new ArrayList<>();
        data.add("[\"Date\", \"Profit\"]"); // 헤더 추가

        while (rs.next()) {
            String saleDate = rs.getString("saleDate");
            double price = rs.getDouble("price");
            double inventory = rs.getDouble("inventory");
            String standard = rs.getString("standard");

            double profit = 0;
            
            // standard가 'ml' 또는 'l'을 포함하면 inventory 그대로 사용
            if (standard != null && (standard.contains("ml") || standard.contains("l"))) {
                profit = price * inventory;
            } else {
                // 'ml'이나 'l'이 아닌 경우, standard에서 숫자만 추출하여 나누기
                try {
                    double standardValue = Double.parseDouble(standard.replaceAll("[^0-9.]", ""));
                    profit = price * (inventory / standardValue);
                } catch (NumberFormatException e) {
                    profit = 0;  // 숫자가 아닐 경우 처리
                }
            }

            // 날짜와 이익을 배열 형식으로 추가
            data.add("[\"" + saleDate + "\", " + profit + "]");
        }

        // 배열 형식으로 데이터를 JSON 형태로 변환하여 출력
        String jsonResponse = String.join(",", data);
        out.print("[" + jsonResponse + "]");
    } catch (SQLException e) {
        e.printStackTrace();
    } catch (Exception e) {
        e.printStackTrace();
    } finally {
        try {
            if (rs != null) rs.close();
            if (stmt != null) stmt.close();
            if (conn != null) conn.close();
        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
%>

@charset "UTF-8";

/* =============================
   기본 리셋
============================= */
* {
	padding: 0;
	margin: 0;
	box-sizing: border-box;
}

a {
	text-decoration: none;
}

ul {
	list-style: none;
}

body.sale-body {
    background: #efefef;
    overflow: hidden;
    font-family: "Noto Sans KR", sans-serif;
}

#wrap {
    width: 100%;
    height: 100vh;
    text-align: center;
    position: relative;
}

/* =============================
   제목 영역
============================= */

.sale-title-area {
    margin-top: 25px;
    margin-bottom: 30px;
}

.sale-title-area h1 {
    font-size: 26px;
    margin-bottom: 6px;
}

#downloadStatement {
    padding: 5px 10px;
    font-size: 13px;
}

/* =============================
   메인 레이아웃
============================= */
#data {
    display: grid;
    grid-template-columns: 65% 35%;
    gap: 30px;
    padding: 0 25px;
    align-items: start;
}

/* =============================
   고객 입력
============================= */
.consumerInfo {
    display: flex;
    gap: 12px;
    margin-bottom: 10px;
}

.coolinput label {
    font-size: 12px;
}

.memberName,
.scheduleDate {
    height: 34px;
    padding: 4px 8px;
    border-radius: 6px;
    border: 1px solid #bbb;
}

/* =============================
   판매 테이블 공통
============================= */
.table_line {
    width: 100%;
    border-collapse: collapse;
    background: #fff;
    table-layout: fixed;
    font-size: 13px;
}

.table_line th {
    background: #b8c7da;
    border: 1px solid #666;
    height: 42px;
}

.table_line td {
    border: 1px solid #666;
    height: 42px;
    padding: 3px;
    text-align: center;
}

.table_line input[type="text"] {
    width: 100%;
    height: 26px;
    border: 1px solid #aaa;
    text-align: center;
}

/* =============================
   스크롤 테이블
============================= */
#scrollTable {
    max-height: 160px;
    overflow-y: auto;
    border: 1px solid #777;
}

/* =============================
   하단 금액 테이블
============================= */
#generalMedicine td,
#preparations td,
#dbInsert td {
    font-weight: bold;
}

.discount-btn {
    height: 32px;
    width: 100%;
    font-size: 12px;
}

#exhaustionInv {
    width: 100%;
    height: 50px;
    font-size: 18px;
    background: #bfbfbf;
    border: none;
    border-radius: 5px;
}

/* =============================
   세트 테이블
============================= */
.leftUI {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 25px;
}

.regularTable {
    width: 100%;
    border-collapse: collapse;
    border-radius: 12px;
    overflow: hidden;
}

.regularTable thead {
    background: #cdeed1;
    height: 45px;
}

.regularTable th {
    height: 45px;
    position: relative;
}

.regularTable td {
    height: 48px;
    border: 1px solid #f2b7b7;
    background: #fffafa;
    cursor: pointer;
}

.regularTable td:hover {
    background: #ffeaea;
}

/* 뚜껑 애니메이션 */
.leftLid,
.rightLid {
    position: absolute;
    top: 0;
    width: 50%;
    height: 100%;
    background: #c0e4c4;
    font-weight: bold;
    line-height: 45px;
}

.leftLid { left: 0; text-align: right; padding-right: 10px; }
.rightLid { right: 0; text-align: left; padding-left: 10px; }

.regularTable th:hover .leftLid {
    transform: translateX(-120%);
}

.regularTable th:hover .rightLid {
    transform: translateX(120%);
}

/* =============================
   팝업
============================= */
#popup {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 85%;
    max-width: 1500px;
    height: 65%;
    background: white;
    border: 2px solid #777;
    box-shadow: 0 0 15px rgba(0,0,0,0.4);
    display: none;
    z-index: 3000;
}

#popup h3 {
    text-align: center;
    margin: 10px 0;
}

#popup-table {
    width: 100%;
    height: calc(100% - 50px);
    overflow-y: auto;
    display: block;
}

/* =============================
   재확인 창
============================= */
#checkInv {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: white;
    width: 80%;
    height: 70%;
    box-shadow: 0 0 20px rgba(0,0,0,0.5);
    display: none;
    z-index: 4000;
}

/* =============================
   경고창
============================= */
#warningBox {
    position: fixed;
    right: 20px;
    bottom: -300px;
    width: 360px;
    background: #fff8f8;
    border: 1px solid #ffb3b3;
    border-radius: 10px;
    padding: 15px;
    opacity: 0;
    transition: 0.5s;
    z-index: 5000;
}

#warningBox.show {
    bottom: 20px;
    opacity: 1;
}

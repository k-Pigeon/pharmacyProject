<%@ page language="java" contentType="application/json; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="java.io.*, java.util.*, java.sql.*,
                 javax.servlet.*, javax.servlet.http.*,
                 org.json.JSONArray, org.json.JSONObject,
                 java.util.regex.Pattern, java.util.regex.Matcher" %>
<%@ include file="sessionManager.jsp"%>
<%@ include file="DBconnection.jsp"%>   <!-- 여기서 Connection conn 이 생성·주입된 상태 -->

<%
/* ─────────────────────────── 기본 설정 ─────────────────────────── */
String dbName   = (session != null) ? (String) session.getAttribute("dbName") : null;
String id       = (session != null) ? (String) session.getAttribute("id")     : null;

if (id == null || dbName == null) {   // 세션 만료 시 로그인 페이지 이동
    response.sendRedirect("login.jsp");
    return;
}

request.setCharacterEncoding("UTF-8");
java.sql.Timestamp now = new java.sql.Timestamp(System.currentTimeMillis());

/* ─────────────────────────── 트랜잭션 시작 ─────────────────────────── */
conn.setAutoCommit(false);            // 이미 열린 conn 사용

try {
    /* ---------- ① 클라이언트 요청 JSON 파싱 ---------- */
    StringBuilder sb = new StringBuilder();
    try (BufferedReader br = request.getReader()) {
        String line;
        while ((line = br.readLine()) != null) sb.append(line);
    }
    JSONArray jsonArr = new JSONArray(sb.toString());
    JSONObject meta   = jsonArr.getJSONObject(jsonArr.length() - 1);  // 마지막 객체 = 메타정보

    String medicinePrice = meta.getString("medicinePrice");
    String generalPrice  = meta.getString("generalPrice");
    String clientName    = meta.getString("discounted");

    /* ---------- ② 가격·할인 기록 ---------- */
    try (PreparedStatement ps = conn.prepareStatement(
         "INSERT INTO priceRecord (saleDate, maxmedicinePrice, generalPrice) VALUES (?, ?, ?)")) {
        ps.setTimestamp(1, now);
        ps.setString   (2, medicinePrice);
        ps.setString   (3, generalPrice);
        ps.executeUpdate();
    }

    try (PreparedStatement ps = conn.prepareStatement(
         "INSERT INTO discountedDB (sale_date, discounted) VALUES (?, ?)")) {
        ps.setTimestamp(1, now);
        ps.setString   (2, clientName);
        ps.executeUpdate();
    }

    /* ---------- ③ 재고 차감용 공통 SQL ------------ */
    final String selBySerial =
        "SELECT DeliveryDate, inventory FROM testTable " +
        "WHERE SerialNumber = ? AND medicineName = ? AND returnInv='0' AND inventory>0 " +
        "ORDER BY DeliveryDate ASC LIMIT 1";

    final String selByName =
        "SELECT DeliveryDate, inventory FROM testTable " +
        "WHERE medicineName = ? AND returnInv='0' AND inventory>0 " +
        "ORDER BY DeliveryDate ASC LIMIT 1";

    final String updBySerial =
        "UPDATE testTable SET inventory = inventory - ? " +
        "WHERE SerialNumber = ? AND medicineName = ? AND DeliveryDate = ? AND returnInv='0'";

    final String updByName =
        "UPDATE testTable SET inventory = inventory - ? " +
        "WHERE medicineName = ? AND DeliveryDate = ? AND returnInv='0'";

    /* ---------- ④ 미리 준비해 두는 PreparedStatement 네트워크 ---------- */
    try (PreparedStatement psSelSerial = conn.prepareStatement(selBySerial);
         PreparedStatement psSelName   = conn.prepareStatement(selByName);
         PreparedStatement psUpdSerial = conn.prepareStatement(updBySerial);
         PreparedStatement psUpdName   = conn.prepareStatement(updByName)) {

        /* ---------- ⑤ 판매 항목 루프 ---------- */
        for (int i = 0; i < jsonArr.length() - 1; i++) { // 마지막은 메타니까 제외
            JSONObject item = jsonArr.getJSONObject(i);

            String serial   = item.optString("serialNumber", "").trim();
            String medName  = item.optString("medicineName", "").trim();
            double qtySale  = item.optDouble("inventory", 0);   // 판매 수량
            String priceStr = item.optString("price", "0").replaceAll("[^0-9.]", "");
            String buyStr   = item.optString("Buyingprice", "0").replaceAll("[^0-9.]", "");
            boolean bySerial = !serial.isEmpty();

            double salePrice = 0, buyPrice = 0;
            try { salePrice = Double.parseDouble(priceStr); } catch (NumberFormatException ignore) {}
            try { buyPrice  = Double.parseDouble(buyStr);   } catch (NumberFormatException ignore) {}

            /* --- standardFactor 계산 (예: '10*2' → 20) --- */
            double factor = 1.0;
            try {
                Matcher m = Pattern.compile("\\d+(\\.\\d+)?").matcher(item.optString("standard", ""));
                double n1 = 1.0, n2 = 1.0;
                if (m.find()) n1 = Double.parseDouble(m.group());
                if (m.find()) n2 = Double.parseDouble(m.group());
                factor = n1 * n2;
            } catch (Exception ignore) {}

            /* ---------- ⑤-1. 세트 상품인지 확인 ---------- */
            boolean isSet = false;
            try (PreparedStatement ck = conn.prepareStatement(
                 "SELECT 1 FROM productSet WHERE medicineName = ? LIMIT 1")) {
                ck.setString(1, medName);
                try (ResultSet rs = ck.executeQuery()) { if (rs.next()) isSet = true; }
            }

            /* ---------- ⑤-2. 재고 차감 ---------- */
            if (isSet) {    // (가) 세트일 경우
                try (PreparedStatement setQ = conn.prepareStatement(
                     "SELECT medicineName_1, medicineName_2, medicineName_3, medicineName_4 " +
                     "FROM productSet WHERE medicineName = ?")) {
                    setQ.setString(1, medName);
                    try (ResultSet rsSet = setQ.executeQuery()) {
                        if (rsSet.next()) {
                            for (int idx = 1; idx <= 4; idx++) {
                                String inner = rsSet.getString("medicineName_" + idx);
                                if (inner == null || inner.trim().isEmpty()) continue;

                                /* 구성품 재고 차감 루프 */
                                double remain = qtySale;   // 세트 수량만큼 구성품도 차감
                                while (remain > 0) {
                                    psSelName.setString(1, inner);
                                    try (ResultSet rs = psSelName.executeQuery()) {
                                        if (!rs.next()) break;      // 재고 더 없음

                                        String dDate  = rs.getString("DeliveryDate");
                                        double stock  = rs.getDouble("inventory");
                                        double needDb = remain * factor;            // 판매→DB 단위
                                        double useDb  = Math.min(needDb, stock);    // 실제 뺄 양
                                        double usedSaleUnit = useDb / factor;      // 판매 단위 환산

                                        psUpdName.setDouble(1, useDb);
                                        psUpdName.setString(2, inner);
                                        psUpdName.setString(3, dDate);
                                        if (psUpdName.executeUpdate() == 0)
                                            throw new SQLException("세트 구성품 차감 실패");

                                        remain -= usedSaleUnit;
                                    }
                                }
                            }
                        }
                    }
                }

            } else if (!"일반세트".equals(serial) && !"한약세트".equals(serial)) {   // (나) 일반 단품
                double remain = qtySale;
                while (remain > 0) {
                    PreparedStatement sel = bySerial ? psSelSerial : psSelName;
                    if (bySerial) {
                        sel.setString(1, serial);
                        sel.setString(2, medName);
                    } else sel.setString(1, medName);

                    try (ResultSet rs = sel.executeQuery()) {
                        if (!rs.next()) break;   // 더 이상 재고가 없음

                        String dDate  = rs.getString("DeliveryDate");
                        double stock  = rs.getDouble("inventory");
                        double needDb = remain * factor;
                        double useDb  = Math.min(needDb, stock);
                        double usedSaleUnit = useDb / factor;

                        PreparedStatement upd = bySerial ? psUpdSerial : psUpdName;
                        int p = 1;
                        upd.setDouble(p++, useDb);
                        if (bySerial) upd.setString(p++, serial);
                        upd.setString(p++, medName);
                        upd.setString(p  , dDate);

                        if (upd.executeUpdate() == 0)
                            throw new SQLException("단품 재고 차감 실패");

                        remain -= usedSaleUnit;
                    }
                }
            }

            /* ---------- ⑤-3. 판매 기록 저장 ---------- */
            try (PreparedStatement ps = conn.prepareStatement(
                 "INSERT INTO SalesRecord " +
                 "(saleDate, medicineName, Buyingprice, price, inventory, SerialNumber, DeliveryDate, standard) " +
                 "VALUES (?, ?, ?, ?, ?, ?, ?, ?)")) {
                ps.setTimestamp(1, now);
                ps.setString   (2, medName);
                ps.setDouble   (3, buyPrice);
                ps.setDouble   (4, salePrice);
                ps.setString   (5, item.optString("inventory", ""));
                ps.setString   (6, serial);
                ps.setString   (7, item.optString("deliveryDate", ""));
                ps.setString   (8, item.optString("standard", ""));
                ps.executeUpdate();
            }
        } // end-for 판매 항목
    }     // end-try PreparedStatement 묶음

    /* ---------- ⑥ 커밋 & 응답 ---------- */
    conn.commit();
    out.println("{\"result\":\"success\"}");

} catch (Exception ex) {
    if (conn != null) try { conn.rollback(); } catch (SQLException ignore) {}
    ex.printStackTrace();
    out.println("{\"result\":\"error\",\"message\":\"" + ex.getMessage().replace("\"","'") + "\"}");
} finally {
    /* 필요 시 여기서 conn.close(); 하지만 DBconnection.jsp 가 공용 연결을 관리한다면 생략 */
    // try { if (conn != null) conn.close(); } catch (SQLException ignore) {}
}
%>

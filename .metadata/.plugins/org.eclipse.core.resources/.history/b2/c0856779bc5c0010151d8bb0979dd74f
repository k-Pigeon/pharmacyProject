<%@ page language="java" contentType="application/json; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="java.io.*, java.util.*, java.sql.*,
                 javax.servlet.*, javax.servlet.http.*,
                 org.json.JSONArray, org.json.JSONObject,
                 java.util.regex.Pattern, java.util.regex.Matcher" %>
<%@ include file="sessionManager.jsp"%>
<%@ include file="DBconnection.jsp"%>

<%
String dbName = (session != null) ? (String) session.getAttribute("dbName") : null;
String id = (session != null) ? (String) session.getAttribute("id") : null;
String password = (session != null) ? (String) session.getAttribute("password") : null;

if (id == null || dbName == null) {
    response.sendRedirect("login.jsp");
    return;
}

jdbcDriver = dbName;
request.setCharacterEncoding("UTF-8");
java.sql.Timestamp sqlDate = new java.sql.Timestamp(new java.util.Date().getTime());

try (conn = DriverManager.getConnection(jdbcDriver, id, password)) {
    conn.setAutoCommit(false);

    StringBuilder sb = new StringBuilder();
    try (BufferedReader reader = request.getReader()) {
        String line;
        while ((line = reader.readLine()) != null) sb.append(line);
    }

    JSONArray jsonArray = new JSONArray(sb.toString());
    JSONObject paramObj = jsonArray.getJSONObject(jsonArray.length() - 1);
    String medicinePrice = paramObj.getString("medicinePrice");
    String generalPrice = paramObj.getString("generalPrice");
    String clientName = paramObj.getString("discounted");

    // 가격 기록
    try (PreparedStatement pstmt = conn.prepareStatement(
        "INSERT INTO priceRecord (saleDate, maxmedicinePrice, generalPrice) VALUES (?, ?, ?)")) {
        pstmt.setTimestamp(1, sqlDate);
        pstmt.setString(2, medicinePrice);
        pstmt.setString(3, generalPrice);
        pstmt.executeUpdate();
    }

    // 할인 기록
    try (PreparedStatement pstmt = conn.prepareStatement(
        "INSERT INTO discountedDB (sale_date, discounted) VALUES (?, ?)")) {
        pstmt.setTimestamp(1, sqlDate);
        pstmt.setString(2, clientName);
        pstmt.executeUpdate();
    }

    final String selBySerial =
        "SELECT DeliveryDate, inventory FROM testTable " +
        "WHERE SerialNumber = ? AND medicineName = ? AND returnInv = '0' AND inventory > 0 " +
        "ORDER BY DeliveryDate ASC LIMIT 1";

    final String selByName =
        "SELECT DeliveryDate, inventory FROM testTable " +
        "WHERE medicineName = ? AND returnInv = '0' AND inventory > 0 " +
        "ORDER BY DeliveryDate ASC LIMIT 1";

    final String updBySerial =
        "UPDATE testTable SET inventory = inventory - ? " +
        "WHERE SerialNumber = ? AND medicineName = ? AND DeliveryDate = ? AND returnInv = '0'";

    final String updByName =
        "UPDATE testTable SET inventory = inventory - ? " +
        "WHERE medicineName = ? AND DeliveryDate = ? AND returnInv = '0'";

    try (
        PreparedStatement psSelSerial = conn.prepareStatement(selBySerial);
        PreparedStatement psSelName   = conn.prepareStatement(selByName);
        PreparedStatement psUpdSerial = conn.prepareStatement(updBySerial);
        PreparedStatement psUpdName   = conn.prepareStatement(updByName)
    ) {
        for (int i = 0; i < jsonArray.length() - 1; i++) {
            JSONObject obj = jsonArray.getJSONObject(i);
            String serial = obj.optString("serialNumber", "").trim();
            String medName = obj.optString("medicineName", "").trim();
            double inventoryAdjustment = obj.optDouble("inventory", 0.0);
            String priceStr = obj.optString("price", "0").replaceAll("[^0-9.]", "");
            String buyingPriceStr = obj.optString("Buyingprice", "0").replaceAll("[^0-9.]", "");
            boolean bySerial = !serial.isEmpty();

            double priceVal = 0.0, buyVal = 0.0;
            try { priceVal = Double.parseDouble(priceStr); } catch (NumberFormatException ignore) {}
            try { buyVal   = Double.parseDouble(buyingPriceStr); } catch (NumberFormatException ignore) {}

            // standardFactor 계산
            double standardFactor = 1.0;
            try {
                Matcher matcher = Pattern.compile("\\d+(\\.\\d+)?").matcher(obj.optString("standard", ""));
                double num1 = 1.0, num2 = 1.0;
                if (matcher.find()) num1 = Double.parseDouble(matcher.group());
                if (matcher.find()) num2 = Double.parseDouble(matcher.group());
                standardFactor = num1 * num2;
            } catch (Exception ignore) {}

            // 세트 상품인지 확인
            boolean isSet = false;
            try (PreparedStatement checkSet = conn.prepareStatement(
                "SELECT * FROM productSet WHERE medicineName = ?")) {
                checkSet.setString(1, medName);
                ResultSet rs = checkSet.executeQuery();
                if (rs.next()) isSet = true;
            }

            // 재고 차감 (세트면 구성품 기준)
            if (isSet) {
                try (PreparedStatement setQuery = conn.prepareStatement(
                    "SELECT medicineName_1, medicineName_2, medicineName_3, medicineName_4 FROM productSet WHERE medicineName = ?")) {
                    setQuery.setString(1, medName);
                    ResultSet rs = setQuery.executeQuery();
                    if (rs.next()) {
                        for (int idx = 1; idx <= 4; idx++) {
                            String innerMed = rs.getString("medicineName_" + idx);
                            if (innerMed != null && !innerMed.trim().isEmpty()) {
                                double remain = inventoryAdjustment;
                                while (remain > 0) {
                                    PreparedStatement sel = psSelName;
                                    sel.setString(1, innerMed);
                                    try (ResultSet rs2 = sel.executeQuery()) {
                                        if (!rs2.next()) break;
                                        String deliveryDate = rs2.getString("DeliveryDate");
                                        double stock = rs2.getDouble("inventory");

                                        double reqDbUnit = remain * standardFactor;
                                        double deductDbUnit = Math.min(reqDbUnit, stock);
                                        double deductSale = deductDbUnit / standardFactor;

                                        PreparedStatement upd = psUpdName;
                                        upd.setDouble(1, deductDbUnit);
                                        upd.setString(2, innerMed);
                                        upd.setString(3, deliveryDate);

                                        int affected = upd.executeUpdate();
                                        if (affected == 0)
                                            throw new SQLException("세트 구성품 재고 차감 실패");

                                        remain -= deductSale;
                                    }
                                }
                            }
                        }
                    }
                }
            } else if (!"일반세트".equals(serial) && !"한약세트".equals(serial)) {
                double remain = inventoryAdjustment;
                while (remain > 0) {
                    PreparedStatement sel = bySerial ? psSelSerial : psSelName;
                    if (bySerial) {
                        sel.setString(1, serial);
                        sel.setString(2, medName);
                    } else sel.setString(1, medName);

                    try (ResultSet rs = sel.executeQuery()) {
                        if (!rs.next()) break;

                        String deliveryDate = rs.getString("DeliveryDate");
                        double stock = rs.getDouble("inventory");

                        double reqDbUnit = remain * standardFactor;
                        double deductDbUnit = Math.min(reqDbUnit, stock);
                        double deductSale = deductDbUnit / standardFactor;

                        PreparedStatement upd = bySerial ? psUpdSerial : psUpdName;
                        int idx = 1;
                        upd.setDouble(idx++, deductDbUnit);
                        if (bySerial) upd.setString(idx++, serial);
                        upd.setString(idx++, medName);
                        upd.setString(idx, deliveryDate);

                        int affected = upd.executeUpdate();
                        if (affected == 0)
                            throw new SQLException("단품 재고 차감 실패");

                        remain -= deductSale;
                    }
                }
            }

            // 판매 기록 저장 (세트도 기록은 함)
            try (PreparedStatement salesStmt = conn.prepareStatement(
                "INSERT INTO SalesRecord (saleDate, medicineName, Buyingprice, price, inventory, SerialNumber, DeliveryDate, standard) " +
                "VALUES (?, ?, ?, ?, ?, ?, ?, ?)")) {
                salesStmt.setTimestamp(1, sqlDate);
                salesStmt.setString(2, medName);
                salesStmt.setDouble(3, buyVal);
                salesStmt.setDouble(4, priceVal);
                salesStmt.setString(5, obj.optString("inventory", ""));
                salesStmt.setString(6, serial);
                salesStmt.setString(7, obj.optString("deliveryDate", ""));
                salesStmt.setString(8, obj.optString("standard", ""));
                salesStmt.executeUpdate();
            }
        }
    }

    conn.commit();
    out.println("{\"result\":\"success\"}");

} catch (Exception e) {
    if (conn != null) try { conn.rollback(); } catch (SQLException ex) { ex.printStackTrace(); }
    e.printStackTrace();
    out.println("{\"result\":\"error\", \"message\":\"" + e.getMessage().replace("\"", "'") + "\"}");
}
%>

<%@ page language="java" contentType="text/html; charset=UTF-8"
	pageEncoding="UTF-8"%>
<%@ page import="java.sql.*, java.text.*, java.util.*"%>
<%@ include file="sessionManager.jsp"%>
<%@ include file="DBconnection.jsp"%>
<%
request.setCharacterEncoding("UTF-8");

String dbName = (String) session.getAttribute("dbName");
String id = (String) session.getAttribute("id");
String password = (String) session.getAttribute("password");

if (id == null || dbName == null) {
    response.setStatus(HttpServletResponse.SC_UNAUTHORIZED);
    return;
}

String startDate = request.getParameter("startDate");
String endDate = request.getParameter("endDate");
String checkedState = request.getParameter("checkedState");

if (startDate == null || endDate == null) {
    response.setStatus(HttpServletResponse.SC_BAD_REQUEST);
    return;
}

PreparedStatement pstmt = null;
ResultSet rs = null;
System.out.println("checkedState: " + checkedState);


try {
	String sql = "";
	if ("1".equals(checkedState)) {
	    System.out.println("==> 월별 쿼리 실행");
	    sql = "SELECT DATE_FORMAT(saleDate, '%Y-%m') AS SalesDate, " +
	          "FORMAT(SUM(price), 0) AS totalPrice, " +
	          "FORMAT(SUM(Buyingprice), 0) AS totalBuyingprice, " +
	          "FORMAT(SUM(price) - SUM(Buyingprice), 0) AS margin, " +
	          "CONCAT(ROUND((SUM(price) - SUM(Buyingprice)) / SUM(price) * 100, 2), '%') AS marginRate " +
	          "FROM salesRecord " +
	          "WHERE saleDate >= ? AND saleDate <= ? " +
	          "GROUP BY DATE_FORMAT(saleDate, '%Y-%m') " +
	          "ORDER BY DATE_FORMAT(saleDate, '%Y-%m') DESC";
	} else if ("0".equals(checkedState)) {
	    System.out.println("==> 일별 쿼리 실행");
	    sql = "SELECT DATE(saleDate) AS SalesDate, " +
	          "FORMAT(SUM(price), 0) AS totalPrice, " +
	          "FORMAT(SUM(Buyingprice), 0) AS totalBuyingprice, " +
	          "FORMAT(SUM(price) - SUM(Buyingprice), 0) AS margin, " +
	          "CONCAT(ROUND((SUM(price) - SUM(Buyingprice)) / SUM(price) * 100, 2), '%') AS marginRate " +
	          "FROM salesRecord " +
	          "WHERE saleDate >= ? AND saleDate <= ? " +
	          "GROUP BY DATE(saleDate) " +
	          "ORDER BY DATE(saleDate) DESC";
	} else {
	    System.out.println("❗ checkedState 값이 예상과 다름: " + checkedState);
	    return;
	}



    pstmt = conn.prepareStatement(sql);
    pstmt.setString(1, endDate + " 23:59:59");
    pstmt.setString(2, startDate + " 00:00:00");
    rs = pstmt.executeQuery();

    while (rs.next()) {
%>
<tr>
	<td><%= rs.getString("SalesDate") %></td>
	<td><%= rs.getString("totalPrice") %></td>
	<td><%= rs.getString("totalBuyingprice") %></td>
	<td><%= rs.getString("margin") %></td>
	<td><%= rs.getString("marginRate") %></td>
</tr>
<%
    }
} catch (Exception e) {
	e.printStackTrace();
	response.setStatus(HttpServletResponse.SC_INTERNAL_SERVER_ERROR);
} finally {
	if (rs != null) try { rs.close(); } catch (SQLException e) {}
	if (pstmt != null) try { pstmt.close(); } catch (SQLException e) {}
	if (conn != null) try { conn.close(); } catch (SQLException e) {}
}
%>

		 // н…Ңмқҙлё”м—җм„ң н–ү нҒҙлҰӯ мӢң, н•ҙлӢ№ лҚ°мқҙн„°лҘј нҸјм—җ мұ„мҡ°лҠ” мҪ”л“ң
		    $("#popup #popupContent").on("click", ".table_line tbody tr", function() {
		        // нҒҙлҰӯн•ң trмқҳ к°Ғ td к°’мқ„ ліҖмҲҳм—җ м ҖмһҘ
		        var memberName = $(this).find("td:nth-child(1)").text();  // нҡҢмӣҗ мқҙлҰ„
		        var memberPhone = $(this).find("td:nth-child(2)").text();  // м „нҷ”лІҲнҳё

/* ===============================
   Index Page 전용 스타일
================================ */

#wrap.index .index-form {
    min-width: 85%;
    max-width: 85%;
}

/* 제목 */
#wrap.index .index-title {
    text-align: center;
    margin-top: 40px;
}

/* 필터 전체 */
#wrap.index .index-filter {

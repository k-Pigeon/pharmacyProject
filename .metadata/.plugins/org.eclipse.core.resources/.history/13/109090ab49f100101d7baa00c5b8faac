/* ===============================
   기본 테이블 스크롤 구조
================================ */

#wrap .table_line {
    width: 100%;
    min-width: 100%;
    max-width: 100%;
    height: calc(70vh);
    display: block;
    overflow: auto;
    padding: 0;
    margin: 0 auto;
    border-radius: 20px;
    box-shadow: 5px 5px 5px -5px #333;
    border-collapse: collapse;
}

#wrap .table_line thead {
    position: sticky;
    top: 0;
    z-index: 2;
    width: 960px;
    color: black;
    border-bottom: 5px solid #5F9EA0;
    display: table;
    table-layout: fixed;
}

#wrap .table_line tbody {
    display: block;
    max-height: 300px;
    overflow-y: scroll;
    width: 100%;
    min-width: 960px;
    background-color: rgba(255,255,255,0.8);
}

#wrap .table_line thead,
#wrap .table_line tbody {
    display: table;
    width: 100%;
    table-layout: fixed;
}

/* 스크롤바 숨김 */
#wrap .table_line tbody::-webkit-scrollbar {
    display: none;
}
#wrap .table_line tbody {
    -ms-overflow-style: none;
    scrollbar-width: none;
}

#wrap .table_line thead th,
#wrap .table_line tbody td {
    width: 150px;
}


/* ===============================
   컬럼 너비
================================ */

#wrap .table_line th:nth-child(1),
#wrap .table_line td:nth-child(1) {
    width: 350px;
}

#wrap .table_line th:nth-child(2),
#wrap .table_line td:nth-child(2) {
    width: 150px;
}


/* ===============================
   페이지 레이아웃
================================ */

#wrap #formTeg {
    min-width: 90%;
}

#wrap #formTeg > h1 {
    text-align: center;
    margin-top: 40px;
}


/* ===============================
   상단 필터 라인
================================ */

#wrap .filterLine {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
}

#wrap .filterLine #pageControl {
    position: relative;
    display: block;
    width: 200px;
    text-align: center;
}

#wrap .filterLine #pageControl #prevPage,
#wrap .filterLine #pageControl #nextPage {
    width: 60px;
    height: 35px;
    font-size: 20px;
}

#wrap .filterLine #saveAll {
    width: 150px;
    height: 50px;
    font-size: 25px;
    margin-left: auto;
}


/* ===============================
   검색 필터 영역
================================ */

#wrap .filterLine .filter {
    display: flex;
    width: auto;
    height: 40px;
    float: left;
    margin-right: auto;
}

#wrap .filterLine .filter #nameSearch {
    position: relative;
    top: 5%;
    height: 40px;
}

#wrap .filterLine .filter #deliveryDateCh {
    position: relative;
    top: 5%;
    height: 40px;
}


/* ===============================
   알림 UI
================================ */

.alert-container {
    position: relative;
    width: 100px;
    height: 100px;
    transform: translate(40px, -30px);
    display: none;
}

.alert-container:hover {
    cursor: pointer;
}

.alert-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 10px;
    height: 10px;
    border: 4px solid rgba(255,0,0,0.6);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    animation: ripple 1.5s infinite ease-out;
}

.alert-ring:nth-child(2) { animation-delay: 0.5s; }
.alert-ring:nth-child(3) { animation-delay: 1s; }

.alert-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 24px;
    color: #ff0000;
}

@keyframes ripple {
    0% { width: 10px; height: 10px; opacity: 1; }
    100% { width: 100px; height: 100px; opacity: 0; }
}


/* ===============================
   우클릭 메뉴
================================ */

#coordinates {
    position: absolute;
    background: #ADD8E6;
    border: 2px solid #4682B4;
    width: 200px;
    height: 80px;
    color: white;
    border-radius: 5px;
    display: none;
}



	outline: none;
	background-color: transparent;
	color: black;
	transition: 1s;
	border-radius: 0.3em;
	font-size: 16px;
	font-weight: bold;
	cursor: pointer;
}

.registDelete::after, .registUpdate::after, .registReset::after {
	content: "";
	position: absolute;
	top: -10px;
	left: 3%;
	width: 95%;
	height: 40%;
	background-color: #212121;
	transition: 0.5s;
	transform-origin: center;
}

.registDelete::before, .registUpdate::before, .registReset::before {
	content: "";
	transform-origin: center;
	position: absolute;
	top: 80%;
	left: 3%;
	width: 95%;
	height: 40%;
	background-color: #212121;
	transition: 0.5s;
}

.registDelete:hover::before, .registUpdate:hover::before, .registReset:hover::before,
	.registDelete:hover::after, .registUpdate:hover::after, .registReset:hover::after
	{
	transform: scale(0)
}

.registDelete:hover, .registUpdate:hover, .registReset:hover {

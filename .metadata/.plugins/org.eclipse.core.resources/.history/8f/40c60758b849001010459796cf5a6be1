			// 할인가격 변경 시 총합 업데이트
			$(".discounted").on("input", function() {
			    let total = parseFloat($(".CopytotalCalcul").val().replace(/,/g, '')) || 0;
			    let discount = parseFloat($(".copydiscounted").val().replace(/,/g, '')) || 0;

			    let maxTotal = total - discount;
			    let formattedMax = maxTotal.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");

			    $(".maxTotal").val(formattedMax);
			});


			function updateTotalPrice(row) {
			    let inventory = parseFloat($(row).find(".inventory").val()) || 0;
			    let price = parseFloat($(row).find(".copyPrice").val()) || 0;
			    let totalPrice = inventory * price;

			    // 쉼표 붙이기
			    let formattedTotal = totalPrice.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");

			    $(row).find(".totalPrice").val(formattedTotal);
			    $(row).find(".copytotal").val(totalPrice); // 계산용은 원본 숫자로
			    
			    updateTotalCalcul();
			}


		    // 전체 합계 계산
		    function updateTotalCalcul() {
		    	let total = 0;

		        // 1. 모든 copytotal 합산
		        $(".copytotal").each(function() {
		            let value = parseFloat($(this).val()) || 0;
		            total += value;
		        });

		        // 2. discount 값 숫자 추출
		        let discount = parseFloat($(".copydiscounted").val()) || 0;

		        // 3. 총합에서 할인 빼기
		        let maxTotal = total - discount;

		        // 4. 보기용 쉼표 붙이기
		        let formattedTotal = total.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
		        let formattedMaxTotal = maxTotal.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");

		        // 5. 결과 반영
		        $(".totalCalcul").val(formattedTotal);
		        $(".CopytotalCalcul").val(total); // 숫자만

		        $(".maxTotal").val(formattedMaxTotal); // 쉼표 붙은 최종 합계
		    }


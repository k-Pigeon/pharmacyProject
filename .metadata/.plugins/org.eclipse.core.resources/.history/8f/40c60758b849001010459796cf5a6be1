		        var memberPhone = $(this).find("td:nth-child(2)").text();  // 전화번호
		        var jumin = $(this).find("td:nth-child(3)").text().split("-");  // 주민등록번호
		        var custnumber = $(this).find("td:nth-child(5)").text();  // 고객 번호

		        // 값을 #updatesection 내의 입력 필드에 설정
		        $(".searchUi .membertable .memberName").val(memberName);
		        $(".searchUi .membertable .memberphone").val(memberPhone);
		        $(".searchUi .membertable .jumin1").val(jumin[0]);
		        $(".searchUi .membertable .jumin2").val(jumin[1]);
		        $(".searchUi .membertable .custnumber").val(custnumber);
		        
		        $.ajax({
		            url: "fetchSalesData.jsp",  // 판매 데이터를 조회할 서버 페이지
		            type: "GET",
		            data: { custnumber: custnumber },  // 고객 번호를 서버로 전달
		            success: function(response) {
		                $(".resultData").html(response);  // 서버에서 받은 HTML 테이블을 resultData 요소에 삽입
		            },
		            error: function() {
		                alert("판매 데이터를 불러오는 데 실패했습니다.");
		            }
		        });
		        
		        // 팝업 닫기
		        $("#popup").hide();
		    });

		    $(document).on("click", function (e) {
		    	if (!$(e.target).closest("#popup, .medicineName").length) {
		            $("#popup").hide();
		        }
		    });

		    // 테이블 행 클릭 시 데이터 입력
		    $(document).on("click", ".result-row", function () {
		        let data = $(this).data(); // 선택된 데이터 가져오기

		        // 입력 필드에 값 채우기
		        populateFields(data);
		        $(".blackBG").hide();
		    });

		 // 입력 필드에 데이터 채우기
function populateFields(data) {
    currentRow.find(".medicineName").val(data.medicinename);
    currentRow.find(".standard").val(data.standard);
    currentRow.find(".inventory").val("1");

    const addComma = num => num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");

    let buyingPriceRaw = (data.buyingprice ?? "0").toString().replace(/[^0-9]/g, '');
    let priceRaw = (data.price ?? "0").toString().replace(/[^0-9]/g, '');
    let lowerAndHigestRaw = (data.lowerandhigest ?? "0").toString().replace(/[^0-9]/g, '');

    currentRow.find(".Buyingprice").val(addComma(buyingPriceRaw));
    currentRow.find(".price").val(addComma(priceRaw));
    currentRow.find(".lowerAndHigest").val(data.lowerandhigest ?? "");

    currentRow.find(".copyPrice").val(priceRaw);

    let inventory = 1;
    let totalPrice = inventory * parseFloat(priceRaw || 0);

    currentRow.find(".copytotal").val(totalPrice);
    currentRow.find(".totalPrice").val(addComma(totalPrice));

    updateTotalCalcul();
    $("#popup").hide();
    currentRow.find(".DeliveryDate").focus();
}



		 // inventory와 price가 변경될 때마다 totalPrice 업데이트
		    $(document).on("input", ".inventory, .copyPrice", function () {
		        let row = $(this).closest('tr'); // 현재 행 찾기
		        let inventory = parseFloat(row.find(".inventory").val()) || 0;
		        let price = parseFloat(row.find(".copyPrice").val()) || 0;
		        row.find(".copytotal").val((inventory * price)); // totalPrice 계산
		    });

private String formatDate(String inputDate) {
    if (inputDate == null || inputDate.trim().isEmpty()) return null;
    inputDate = inputDate.trim();

    try {
        // 이미 "20yy-mm-dd" 형태면 그대로 반환
        if (inputDate.matches("^20\\d{2}-\\d{2}-\\d{2}$")) {
            return inputDate;
        }

        // yy/mm/dd 형태면 변환
        if (inputDate.matches("^\\d{2}/\\d{2}/\\d{2}$")) {
            String[] parts = inputDate.split("/");
            String year = "20" + parts[0];
            String month = String.format("%02d", Integer.parseInt(parts[1]));
            String day = String.format("%02d", Integer.parseInt(parts[2]));
            return year + "-" + month + "-" + day;
        }

        // 위 두 가지 외에는 원본 유지
        return inputDate;
    } catch (Exception e) {
        System.err.println("formatDate 변환 오류: " + inputDate + " → " + e.getMessage());
        return inputDate;
    }
}

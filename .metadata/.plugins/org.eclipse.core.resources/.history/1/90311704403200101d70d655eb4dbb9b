		<div style="width: 100%;height: 40px;">
			<button class="custom-btn btn-6 downloadExcel" style="float: right;">엑셀 다운로드</button>
		</div>


		<div id="chart_div" style="width: 85%; height: 400px;margin:0 auto;padding:0;"></div>
	</div>
	<div id="popup_chart" style="display: block;width: 80vh;height: 65vh;overflow: scroll;"></div>
<!-- 모달 -->

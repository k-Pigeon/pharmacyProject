// standard 값이 단위를 포함하면 inventory 그대로, 아니면 inventory * standard 값 반환
private Double parseStandardOrMultiply(String standard, Double inventory) {
    if (standard != null && !standard.trim().isEmpty()) {
        // 단위 확인 (g, ml, l, cm)
        if (standard.matches(".*\\b(g|ml|l|cm)\\b.*")) {
            return inventory; // 단위 포함이면 inventory 그대로 사용
        }

        // 숫자만 추출하여 곱셈 진행
        Double standardValue = parseDoubleOrExtractNumbers(standard, 1.00);
        return inventory * standardValue;
    }
    return inventory;
}

// 날짜 형식을 YYYY-MM-DD로 변환
private String formatDate(String inputDate) {
 try {

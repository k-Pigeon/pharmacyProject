--set들 수정
drop table productSet;
drop table productSet_detail;

CREATE TABLE productSet (
  id INT AUTO_INCREMENT PRIMARY KEY,
  buyingprice VARCHAR(10),
  price VARCHAR(10),
  inventory VARCHAR(3)
);

CREATE TABLE productSet_detail (
  id INT AUTO_INCREMENT PRIMARY KEY,
  productSet_id INT,                  -- productSet 테이블의 외래키
  medicineName VARCHAR(255),
  standard VARCHAR(255),

  FOREIGN KEY (productSet_id) REFERENCES productSet(id)
    ON DELETE CASCADE
);

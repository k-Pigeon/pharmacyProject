<%-- 데이터베이스 연결용 JSP --%>
<%
	request.setCharacterEncoding("UTF-8");
    // 세션에서 데이터베이스 연결 정보를 가져오기
    String dbUser = (String) session.getAttribute("id");
    String jdbcDriver = (String) session.getAttribute("dbName");
    String dbPwd = (String) session.getAttribute("password");
    String programID = (String) session.getAttribute("programID");

    System.out.println(programID);
    
    Connection conn = null;

    try {
        // JDBC 드라이버 로드
        Class.forName("com.mysql.cj.jdbc.Driver");
		
        // 데이터베이스 연결
        conn = DriverManager.getConnection(jdbcDriver, dbUser, dbPwd);

        // 연결 성공 메시지 (테스트용, 실제 배포 시에는 제거 권장)
/*         out.println("<p>데이터베이스 연결 성공!</p>"); */
    } catch (Exception e) {
        // 연결 실패 메시지
        //out.println("<p>데이터베이스 연결 실패: " + e.getMessage() + "</p>");
        e.printStackTrace();
    }
%>
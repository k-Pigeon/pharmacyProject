<%@ page contentType="application/json; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="java.sql.*, org.json.*, java.util.regex.*" %>
<%@ include file="sessionManager.jsp" %>
<%@ include file="DBconnection.jsp" %>

<%
String dbName = (session != null) ? (String) session.getAttribute("dbName") : null;
String id = (session != null) ? (String) session.getAttribute("id") : null;
String idSortation = (session != null) ? (String) session.getAttribute("idSortation") : null;

if (id == null || dbName == null) {
    response.sendRedirect("login.jsp");
    return;
}
jdbcDriver = dbName;

int pages = 1;
int limit = 100;
if (request.getParameter("page") != null) {
    pages = Integer.parseInt(request.getParameter("page"));
}
int offset = (pages - 1) * limit;

// 전체 행 개수
PreparedStatement countStmt = conn.prepareStatement("SELECT COUNT(*) FROM testTable" + idSortation);
ResultSet countRs = countStmt.executeQuery();
countRs.next();
int totalRows = countRs.getInt(1);
int totalPages = (int) Math.ceil((double) totalRows / limit);

// 실제 데이터 조회
String sql = "SELECT *, format(price, 0) AS realPrice FROM testTable" + idSortation +
             " ORDER BY medicineName ASC, DeliveryDate ASC LIMIT ? OFFSET ?";
PreparedStatement pstmt = conn.prepareStatement(sql);
pstmt.setInt(1, limit);
pstmt.setInt(2, offset);
ResultSet rs = pstmt.executeQuery();

// HTML 조립
StringBuilder html = new StringBuilder();

while (rs.next()) {

    // ----- 표준계수 및 재고 계산 -----
    String standard = rs.getString("standard");
    double inventory = rs.getDouble("inventory");
    double calcInventory = inventory;

    if (standard != null && !standard.trim().isEmpty()) {
        try {
            Matcher m = Pattern.compile("\\d+(\\.\\d+)?").matcher(standard);
            double result = 1.0;
            int count = 0;

            while (m.find()) {
                result *= Double.parseDouble(m.group());
                count++;
                if (count == 2) break;
            }
            if (count > 0) calcInventory = inventory / result;
        } catch (Exception e) {
            calcInventory = inventory;
        }
    }

    // ----- HTML append (input 제거, 순수 텍스트) -----
    html.append("<tr data-key='")
        .append(rs.getString("medicineName")).append("|")
        .append(rs.getString("DeliveryDate")).append("|")
        .append(standard == null ? "" : standard)
        .append("'>");

    html.append("<td>").append(rs.getString("medicineName")).append("</td>");
    html.append("<td>").append(rs.getString("DeliveryDate")).append("</td>");
    html.append("<td>").append(String.format("%.2f", calcInventory)).append("</td>");
    html.append("<td>").append(rs.getString("realPrice")).append("</td>");
    html.append("<td>").append(standard == null ? "" : standard).append("</td>");
    html.append("<td>").append(rs.getString("kind")).append("</td>");
    html.append("<td>").append(rs.getString("companyName")).append("</td>");
    html.append("<td>").append(rs.getString("receiptDate")).append("</td>");
    html.append("<td>").append(rs.getString("quantity")).append("</td>");
    html.append("</tr>");
}

JSONObject result = new JSONObject();
result.put("html", html.toString());
result.put("totalPages", totalPages);
out.print(result.toString());
%>

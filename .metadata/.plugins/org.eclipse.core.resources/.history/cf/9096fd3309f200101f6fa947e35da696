/* ===== 판매 페이지 전체 ===== */
body.sale-body {
    background: #f0f0f0;
    overflow-x: hidden;
}

/* 메인 컨테이너 */
body.sale-body #wrap.wrap-container {
    width: 100%;
    margin: 0 auto;
    text-align: center;
}

/* 제목 영역 */
body.sale-body #wrap .sale-title-area {
    margin: 20px 0 30px 0;
}

body.sale-body #wrap .sale-title-area h1 {
    font-size: 24px;
    margin-bottom: 8px;
}

/* 메인 2열 레이아웃 */
body.sale-body #wrap #data.layout-grid {
    display: grid;
    grid-template-columns: 70% 30%;
    column-gap: 32px;
    align-items: start;
    padding: 0 20px 40px;
}

/* 좌측 판매 영역 */
body.sale-body #wrap #data .rightUI.right-ui-area {
    width: 100%;
}

/* 우측 세트 영역 */
body.sale-body #wrap #data .leftUI.left-ui-area {
    width: 100%;
}
/* 모든 판매 테이블 공통 */
body.sale-body #wrap #data .rightUI table.table_line {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    background: #ffffff;
}

/* 컬럼 셀 */
body.sale-body #wrap #data .rightUI table.table_line th,
body.sale-body #wrap #data .rightUI table.table_line td {
    border: 1px solid #cfcfcf;
    padding: 6px 4px;
    height: 40px;
    text-align: center;
    font-size: 13px;
    white-space: nowrap;
}

/* 헤더 색상 */
body.sale-body #wrap #data .rightUI table.table_line thead th {
    background: #e6e6e6;
    font-weight: 600;
}

/* 스크롤 테이블 영역 */
body.sale-body #wrap #data .rightUI .scroll-table-area {
    max-height: 170px;
    overflow-y: auto;
    border: 1px solid #aaa;
    margin-bottom: 12px;
}

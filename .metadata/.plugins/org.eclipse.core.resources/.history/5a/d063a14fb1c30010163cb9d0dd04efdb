<%@ page language="java" contentType="application/json; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="java.sql.*, org.json.*, java.io.*"%>
<%@ include file="sessionManager.jsp"%>
<%@ include file="DBconnection.jsp"%>

<%
    request.setCharacterEncoding("UTF-8");

    // JSON 데이터 받기
    StringBuilder sb = new StringBuilder();
    BufferedReader reader = request.getReader();
    String line;
    while ((line = reader.readLine()) != null) {
        sb.append(line);
    }

    JSONArray items = new JSONArray(sb.toString());

    String idSortation = (session != null) ? (String) session.getAttribute("idSortation") : "";
    String sql = "UPDATE testTable" + idSortation + " SET isOrdered = 1 WHERE medicineName=? AND DeliveryDate=? AND standard=?";

    PreparedStatement pstmt = null;

    try {
        pstmt = conn.prepareStatement(sql);

        for (int i = 0; i < items.length(); i++) {
            JSONObject obj = items.getJSONObject(i);

            String medicineName = obj.getString("medicineName");
            String DeliveryDate = obj.getString("DeliveryDate");
            String standard = obj.getString("standard");

            pstmt.setString(1, medicineName);
            pstmt.setString(2, DeliveryDate);
            pstmt.setString(3, standard);

            pstmt.addBatch();
        }

        pstmt.executeBatch();

        out.print("{\"status\":\"success\"}");

    } catch (Exception e) {
        e.printStackTrace();
        out.print("{\"status\":\"error\"}");
    } finally {
        if (pstmt != null) pstmt.close();
        if (conn != null) conn.close();
    }
%>

			</colgroup>
			<thead>
				<tr style="background-color: #f0f0f0;">
					<th style="border: 1px solid #ccc; padding: 5px;">제품명</th>
					<th style="border: 1px solid #ccc; padding: 5px;">회사명</th>
					<th style="border: 1px solid #ccc; padding: 5px;">재고</th>
					<th style="border: 1px solid #ccc; padding: 5px;">종류</th>
					<th style="border: 1px solid #ccc; padding: 5px;">일련번호</th>
					<th style="border: 1px solid #ccc; padding: 5px;">입고 날짜</th>
					<th style="border: 1px solid #ccc; padding: 5px;">유통기한</th>
					<th style="border: 1px solid #ccc; padding: 5px;">사입가격</th>
					<th style="border: 1px solid #ccc; padding: 5px;">구매가격</th>
				</tr>
			</thead>
			<tbody id="popup-content"></tbody>
		</table>
	</div>
	<script src="jquery-3.7.1.min.js"></script><script src="script.js"></script>
	<script>
		$(document).ready(function(){
			function parseNum(v) {
				if (v == null) return 0;
				const raw = String(v).replace(/,/g, "").trim();
				return raw === "" ? 0 : (isNaN(raw) ? 0 : parseFloat(raw));
			}
			$(".setMakeAjax").on("click").on("click", function () {
			    const setName = $("#setName").val().trim();
			    const medicineName = $("#productName1").val().trim();
			    const buyingPrice = parseNum($("#buyingPrice1").val());
			    const sellingPrice = parseNum($(".price").val());
			    const inventory = parseNum($(".inventory").val());

			    $.ajax({
			        type: "POST",
			        url: "insertSet.jsp",
			        data: {
			            medicineName: medicineName,
			            buyingPrice: buyingPrice,
			            price: sellingPrice,
			            inventory:     inventory,
			            saleInventory: 0
			        },
			        success: function (res) {
			            alert("세트가 성공적으로 추가되었습니다.");
			            location.reload();
			        },
			        error: function () {
			            alert("오류가 발생했습니다.");
			        }
			    });
			});
			$(".table_line").on("keydown", ".medicineName", function (e) {
		        if (e.key === "Enter") { // Enter 키 감지
		            e.preventDefault(); // 폼 제출 방지
		            let medicineName = $(this).val();
		            currentRow = $(this).closest('tr');

		            // 현재 포커스가 있는 행을 추적
		            currentRow = $(this).closest('tr'); // 현재 입력 필드가 속한 행

		            if (medicineName.trim() !== "") {
		                // Ajax 요청
		                $.ajax({
		                    url: "searchMedicine.jsp", // 데이터 검색 JSP
		                    method: "POST",
		                    data: { medicineName: medicineName }, // LIKE 검색 조건
		                    success: function (response) {
		                        $("#popup-content").html(response); // 결과를 테이블에 표시
		                        $("#popup").show(); // 팝업 표시
		                        currentRowIndex = -1;
		                    },
		                    error: function () {
		                        return false;
		                    }
		                });
		            }
		        }
		    });
			
		    $(document).on("click", function (e) {
		        if (!$(e.target).closest("#popup, .medicineName").length) {
		            $("#popup").hide();
		        }
		    });
		    $(document).on("keydown", function (e) {
		        if ($("#popup").is(":visible")) { // 팝업이 열려 있을 때만 동작
		            const rows = $("#popup-content .result-row");

		            if (e.key === "ArrowDown") { // ↓ 키
		                e.preventDefault();
		                if (currentRowIndex < rows.length - 1) {
		                    currentRowIndex++;
		                }
		            } else if (e.key === "ArrowUp") { // ↑ 키
		                e.preventDefault();
		                if (currentRowIndex > 0) {
		                    currentRowIndex--;
		                }
		            } else if (e.key === "Enter" && currentRowIndex >= 0) { // Enter 키로 선택된 행 처리
		                e.preventDefault();
		                const selectedRow = $(rows[currentRowIndex]); // 현재 강조된 행
		                populateFields(selectedRow.data()); // 선택된 데이터 채우기
		            }

		            // 강조 효과 업데이트
		            rows.removeClass("highlight"); // 모든 행의 강조 제거
		            if (currentRowIndex >= 0) {
		                $(rows[currentRowIndex]).addClass("highlight"); // 현재 선택된 행에 강조 추가
		            }
		        }
		    });
		    $(document).on("click", "#popup-content tr", function () {
		        let selectedRow = $(this);
		        let medicineName = selectedRow.find("td:eq(0)").text().trim(); // 첫 번째 컬럼 (제품명)
		        let buyingPrice = selectedRow.find("td:eq(7)").text().trim(); // 두 번째 컬럼 (사입 가격)
		        let sellingPrice = selectedRow.find("td:eq(8)").text().trim(); // 세 번째 컬럼 (판매 가격)

		        console.log(medicineName);
		        console.log(buyingPrice);
		        console.log(sellingPrice);
		        
		        
		        // 현재 입력 중이던 행에 값 채우기
		        currentRow.find(".medicineName").val(medicineName);
		        currentRow.find(".buyingPrice").val(buyingPrice);
		        currentRow.find(".price").val(sellingPrice);

		        $("#popup").hide(); // 팝업 숨기기
		    });
		    
		    $(document).on("keyup", ".buyingPrice, .price", function () {
		    	  const raw = $(this).val().replace(/,/g, "");
		    	  const num = raw === "" ? "" : String(parseFloat(raw) || 0);
		    	  $(this).val(num === "" ? "" : Number(num).toLocaleString());
		    	  calculateTotal();
		    	});
		    $(document).on("keyup", ".inventory", function () {
		    	  const qty = Math.max(0, Math.floor(parseNum($(this).val())));
		    	  $(this).val(qty === 0 ? "" : String(qty)); // 0이면 빈칸, 원하면 "0" 유지해도 됨
		    	  calculateTotal();
		    	});
	        function calculateTotal() {
	        	  let totalBuying = 0;
	        	  let totalSelling = 0;

	        	  $(".table_line tr").each(function () {
	        	    const $row = $(this);
	        	    if ($row.find(".medicineName").length === 0) return; // 제품 행만

	        	    const buyingPrice = parseNum($row.find(".buyingPrice").val());
	        	    const sellingPrice = parseNum($row.find(".price").val());
	        	    const qty = Math.max(0, Math.floor(parseNum($row.find(".inventory").val()))); // 음수/소수 방지

	        	    totalBuying  += buyingPrice  * qty;
	        	    totalSelling += sellingPrice * qty;
	        	  });

	        	  $("#totalBuyingPrice").val(totalBuying.toLocaleString());
	        	  $("#totalSellingPrice").val(totalSelling.toLocaleString());
	        	}

	        $(document).on("click", "#popup-content tr", function () {
	            let selectedRow = $(this);
	            let buyingPrice = selectedRow.find("td:eq(7)").text().trim().replace(/,/g, "");
	            let sellingPrice = selectedRow.find("td:eq(8)").text().trim().replace(/,/g, "");

	            currentRow.find(".buyingPrice").val((parseFloat(buyingPrice) || 0).toLocaleString());
	            currentRow.find(".price").val((parseFloat(sellingPrice) || 0).toLocaleString());

	            $("#popup").hide();
	            calculateTotal();
	        });
	        

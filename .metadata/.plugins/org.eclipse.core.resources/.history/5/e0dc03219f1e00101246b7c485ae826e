<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="java.sql.*" %>
<%@ page import="org.json.JSONArray" %>
<%@ page import="org.json.JSONObject" %>
<%@ include file="sessionManager.jsp"%>
<%@ include file="DBconnection.jsp"%>
<%
String dbName = (session != null) ? (String) session.getAttribute("dbName") : null;
String id = (session != null) ? (String) session.getAttribute("id") : null;
String password = (session != null) ? (String) session.getAttribute("password") : null;

if (id == null || dbName == null) {
    response.sendRedirect("login.jsp");
    return;
}

jdbcDriver = dbName;
request.setCharacterEncoding("UTF-8");
String saleDate = request.getParameter("saleDate");  // 클라이언트에서 전달된 날짜
JSONArray resultArray = new JSONArray();

PreparedStatement ps = null;
ResultSet rs = null;

try {
    String query = "SELECT medicine_name, discounted, inventory, standard, price, total_price, lowerAndHigest FROM SalesData WHERE sale_date = ?";
    ps = conn.prepareStatement(query);
    ps.setString(1, saleDate);
    rs = ps.executeQuery();

    while (rs.next()) {
        JSONObject saleData = new JSONObject();
        saleData.put("medicine_name", rs.getString("medicine_name"));
        saleData.put("inventory", rs.getInt("inventory"));
        saleData.put("standard", rs.getString("standard"));

        // ✨ 천단위 쉼표를 붙인 문자열로 변환
        saleData.put("price", String.format("%,d", (int)rs.getDouble("price")));
        saleData.put("total_price", String.format("%,d", (int)rs.getDouble("total_price")));
        saleData.put("discounted", String.format("%,d", (int)rs.getDouble("discounted")));

        // lowerAndHigest는 그대로 문자열로 출력
        saleData.put("lowerAndHigest", rs.getString("lowerAndHigest"));

        resultArray.put(saleData);
    }

    response.setContentType("application/json; charset=UTF-8");
    response.getWriter().write(resultArray.toString());

} catch (Exception e) {
    e.printStackTrace();
    response.getWriter().write("{\"error\": \"" + e.getMessage() + "\"}");
} finally {
    try {
        if (rs != null) rs.close();
        if (ps != null) ps.close();
        if (conn != null) conn.close();
    } catch (SQLException e) {
        e.printStackTrace();
    }
}
%>

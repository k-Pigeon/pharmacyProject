if (id == null || dbName == null) {
    response.sendRedirect("login.jsp");
    return;
}

jdbcDriver = dbName;

String selectSQL = "select (max(customerNumber) + 1) AS custNum from members";
PreparedStatement pstmt = conn.prepareStatement(selectSQL);

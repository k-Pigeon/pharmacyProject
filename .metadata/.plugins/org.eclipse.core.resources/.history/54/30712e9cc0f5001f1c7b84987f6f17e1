%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Insert title here</title>
<link rel="stylesheet" href="style.css">
<style>
	#wrap{
		font-size:25px;
	}
	#wrap h1{
		width: 100%;
    	height: 10px;
    	text-align: center;
   	    transform: translateY(50px);
    }
    #wrap .Warning,
    #wrap hr{
   	    display: block;
	    width: 60vh;
	    margin: 10px auto;
	    text-align: right;
	    transform: translateY(130px);
    }
    #wrap #section, #wrap #updatesection{
    	display: block;
	    width: 60vh;
	    height: 50vh;
	    margin: 0 auto;
	    transform: translateY(140px);
    }
    #wrap #section input[type="text"],
    #wrap #updatesection input[type="text"]{
    	width: 200px;
	    height: 50px;
	    border: 1px dashed;
	    border-radius: 10px;
	    width:75%;
    }
    #wrap #section .lineSorting,
    #wrap #updatesection .lineSorting{
        display: flex;
	    align-items: center; /* 수직 정렬 */
	    justify-content: space-between;
    	margin:30px 0;
    }
    .essential{
    	color:red;
    }
    .checkbox-container {
    	display: flex;
   		gap: 10px;
	}
	#wrap #section .lingSorting .membership,
	#wrap #updatesection .lingSorting .membership{
	    position: absolute;
	    left: 50%;
	    transform: translateX(-50%);
	    width: 150px;
	    height: 50px;
	    font-size: 20px;
	    border-radius: 10px;
	}
	#wrap .registrationUI,
	#wrap .updateUI{
		flex:1;
		text-align:center;
		border:1px;
	}
	#wrap .registrationUI{
		border: 1px solid;
	    border-radius: 20px 0 0 20px;
	}
	
	#wrap .updateUI{
		border: 1px solid;
	    border-radius: 0 20px 20px 0;
	}
	.selectUi{
		border: 1px solid #4682B4;
    	background: #e0ffff;
    	color: #483D8B;
    	font-weight: bold;
	}
	.closePopup{
	    position: absolute;
	    left: 95%;
	    top: 5%;
	}
	.overDetail{
	    background-color: #FAFAD2;
	    color: #000080;
	    font-weight: bold;
	}
</style>
</head>
<body>
	<div id="wrap" style="display: block;">
		<header>
			<jsp:include page="header.jsp"></jsp:include>
		</header>
		<div style="display: flex;position: relative;left: 20%;top: 10vh;width: 200px;height: 40px;line-height: 40px;border: 1px solid black;border-radius: 20px;cursor:pointer;">
			<span class="registrationUI selectUi">등록</span>
			<span class="updateUI">수정</span>
		</div>
		
		<div class="dataInsert">
			<h1>고객등록</h1>
			<div class="Warning"><span class="essential">&nbsp;*&nbsp;</span>필수 요소</div>
			<hr>
			<section id="section">
				<div class="lineSorting">
					<span class="name"><span class="essential">&nbsp;*&nbsp;</span>성함</span>
						&nbsp;&nbsp;<input type="text" class="memberName" placeholder="&nbsp;Name">
				</div>
				<div class="lineSorting">
					<span class="name"><span class="essential">&nbsp;*&nbsp;</span>전화번호</span>
						&nbsp;&nbsp;<input type="text" class="memberphone" placeholder="phoneNumber [- 없이 입력]">
				</div>
				<div class="lineSorting">
					<span class="name"><span class="essential">&nbsp;&nbsp;&nbsp;</span>주민등록번호</span>
						<input type="text" class="jumin1" placeholder="주민등록번호 앞 6자리" style="width:35%;">
						<span>-</span>
						<input type="text" class="jumin2" placeholder="주민등록번호 뒤 7자리" style="width:35%;">
				</div>
				<div class="lineSorting">
					<span class="name"><span class="essential">&nbsp;*&nbsp;</span>성별</span>
					<div class="checkbox-container">
        			    <label><input type="radio" name="1" value="1"> 남자</label>
        			    <label><input type="radio" name="1" value="2"> 여자</label>
        			</div>
				</div>
				<div class="lineSorting">
					<span class="name"><span class="essential">&nbsp;&nbsp;&nbsp;</span>고객번호</span>
       			    <input type="text" placeholder="절대 수정하지 마시오" readonly="readonly" value="<%= custNum%>">
				</div>
				<div class="lingSorting">
					<button class="membership">고객 수정</button>
				</div>
			</section>
		</div>
		<div class="dataUpdate" style="display:none;">
			<h1>고객수정</h1>
			<div class="Warning"><span class="essential">&nbsp;*&nbsp;</span>필수 요소</div>
			<hr>
			<section id="updatesection">
				<div class="lineSorting">
					<span class="name"><span class="essential">&nbsp;*&nbsp;</span>성함</span>
							&nbsp;&nbsp;<input type="text" class="memberName" placeholder="&nbsp;Name">
			</div>
				<div class="lineSorting">
					<span class="name"><span class="essential">&nbsp;*&nbsp;</span>전화번호</span>
						&nbsp;&nbsp;<input type="text" class="memberphone" placeholder="phoneNumber [- 없이 입력]">
				</div>
				<div class="lineSorting">
					<span class="name"><span class="essential">&nbsp;&nbsp;&nbsp;</span>주민등록번호</span>
						<input type="text" class="jumin1" placeholder="주민등록번호 앞 6자리" style="width:35%;">
						<span>-</span>
						<input type="text" class="jumin2" placeholder="주민등록번호 뒤 7자리" style="width:35%;">
				</div>
				<div class="lineSorting">
					<span class="name"><span class="essential">&nbsp;*&nbsp;</span>성별</span>
					<div class="checkbox-container">
        			    <label><input type="radio" name="1" value="1"> 남자</label>
        			    <label><input type="radio" name="1" value="2"> 여자</label>
        			</div>
				</div>
				<div class="lineSorting">
					<span class="name"><span class="essential">&nbsp;&nbsp;&nbsp;</span>고객번호</span>
       			    <input type="text" class="custnumber" placeholder="절대 수정하지 마시오" readonly="readonly" value="<%= custNum%>">
				</div>
				<div class="lingSorting">
					<button class="membership">고객 등록</button>
				</div>
			</section>
		</div>
	</div>
	<div id="popup" style="width: 85vh;height: 50vh;display:none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); padding: 20px; background-color: white; border: 1px solid #ccc; border-radius: 5px;    box-shadow: 0px 0px 30px 0px;">
	   	<div id="popupContent"></div>
	   	<button class="closePopup">닫기</button>
	</div>
	
	<script src="jquery-3.7.1.min.js"></script>
	<script>
		$(document).ready(function(){
			var Sortation = "1";
			
			$("#popup #popupContent").on("mouseover", " .table_line tbody tr", function(){
				$(this).addClass("overDetail");
			}).on("mouseout", "tr", function(){
				$(this).removeClass("overDetail");
			});
			//유효성 검사
			$("#wrap #section .lingSorting .membership").on("click", function(){
				//검사 기준 변수
				var findVal = $("#wrap #section .lineSorting");
				
				//성함이 비어있을 경우
				if(findVal.find(".memberName").val() == "" || findVal.find(".memberName").val() == null){
					alert("성함을 입력해주세요");
					findVal.find(".memberName").focus();
					return false;
				}
				//전화번호가 비어있을 경우
				if(findVal.find(".memberphone").val() == "" || findVal.find(".memberphone").val() == null){
					alert("전화번호 입력해주세요");
					findVal.find(".memberphone").focus();
					return false;
				}

				//성별을 선택하지 않은 경우
				if(!findVal.find("input[name='1']:checked").val()){
					alert("성별을 선택해주세요");
					return false;
				}
				
				else{
					// 입력값 가져오기
			        var memberName = $(".memberName").val();
			        var memberPhone = $(".memberphone").val();
			        var jumin1 = $(".jumin1").val();
			        var jumin2 = $(".jumin2").val();
			        var gender = $("input[name='1']:checked").val(); // 성별 (남자: 1, 여자: 2)
			        var customerNumber = $("input[readonly]").val(); // 고객번호는 읽기 전용

			        // AJAX 요청 보내기
			        $.ajax({
			            url: 'registerMember.jsp',  // 서버에서 처리할 JSP 파일 경로
			            type: 'POST',
			            data: {
			            	Sortation : Sortation,
			                memberName: memberName,
			                memberPhone: memberPhone,
			                jumin1: jumin1,
			                jumin2: jumin2,
			                gender: gender,
			                customerNumber: customerNumber
			            },
			            success: function(response) {
			                alert(response);  // 서버에서의 응답
			                location.href="customerRegistration.jsp";
			            },
			            error: function(xhr, status, error) {
			                alert("오류 발생: " + error);
			            }
			        });
				}
			});
			
			//고객 수정 유효성 검사
			$("#wrap #section .lingSorting .membership").on("click", function(){
				//검사 기준 변수
				var findVal = $("#wrap #section .lineSorting");
				
				//성함이 비어있을 경우
				if(findVal.find(".memberName").val() == "" || findVal.find(".memberName").val() == null){
					alert("성함을 입력해주세요");
					findVal.find(".memberName").focus();
					return false;
				}
				//전화번호가 비어있을 경우
				if(findVal.find(".memberphone").val() == "" || findVal.find(".memberphone").val() == null){
					alert("전화번호 입력해주세요");
					findVal.find(".memberphone").focus();
					return false;
				}

				//성별을 선택하지 않은 경우
				if(!findVal.find("input[name='1']:checked").val()){
					alert("성별을 선택해주세요");
					return false;
				}
				
				else{
					// 입력값 가져오기
			        var memberName = $(".memberName").val();
			        var memberPhone = $(".memberphone").val();
			        var jumin1 = $(".jumin1").val();
			        var jumin2 = $(".jumin2").val();
			        var gender = $("input[name='1']:checked").val(); // 성별 (남자: 1, 여자: 2)
			        var customerNumber = $("input[readonly]").val(); // 고객번호는 읽기 전용

			        // AJAX 요청 보내기
			        $.ajax({
			            url: 'registerMember.jsp',  // 서버에서 처리할 JSP 파일 경로
			            type: 'POST',
			            data: {
			            	Sortation : Sortation,
			                memberName: memberName,
			                memberPhone: memberPhone,
			                jumin1: jumin1,
			                jumin2: jumin2,
			                gender: gender,
			                customerNumber: customerNumber
			            },
			            success: function(response) {
			                alert(response);  // 서버에서의 응답
			                location.href="customerRegistration.jsp";
			            },
			            error: function(xhr, status, error) {
			                alert("오류 발생: " + error);
			            }
			        });
				}
			});
			
			//전화번호, 주민번호에 숫자만 입력
			$(".memberphone, .jumin1, .jumin2").on("input", function() {
				$(this).val($(this).val().replace(/[^0-9]/g, ""));
		    });
			
			$(".registrationUI").click(function() {
		        // "등록" 클릭 시
		        $(this).addClass("selectUi");  // "등록"에 selectUi 추가
		        $(".updateUI").removeClass("selectUi");  // "수정"에서 selectUi 제거
		        $(".dataUpdate").hide();
		        $(".dataInsert").show();
		    });

		    $(".updateUI").click(function() {
		        // "수정" 클릭 시
		        $(this).addClass("selectUi");  // "수정"에 selectUi 추가
		        $(".registrationUI").removeClass("selectUi");  // "등록"에서 selectUi 제거
		        $(".dataUpdate").show();
		        $(".dataInsert").hide();
		    });

		    $(".closePopup").on("click", function(){
		        $('#popup').hide();  // 팝업 숨기기
		    });
		    
		    $("#wrap .dataUpdate #updatesection .lineSorting .memberName").on("keydown", function(e){
		        if (e.key === "Enter") {  // Enter 키를 눌렀을 때
		            var memberName = $(this).val();  // 입력한 회원 이름 값 가져오기

		            if (memberName) {
		                $.ajax({
		                    url: 'searchMember.jsp',  // 백엔드 처리할 JSP 파일
		                    type: 'GET',
		                    data: { memberName: memberName },  // 입력 값 보내기
		                    success: function(response) {
		                        $('#popupContent').html(response);  // 서버에서 받은 테이블 HTML을 팝업에 삽입
		                        $('#popup').show();  // 팝업 보이기
		                    },
		                    error: function(xhr, status, error) {
		                        alert("서버와의 통신 오류가 발생했습니다.");
		                    }
		                });
		            } else {
		                $('#popup').hide();  // 입력이 비어 있으면 팝업 숨기기
		            }
		        }
		    });
		    
		 	// 테이블에서 행 클릭 시, 해당 데이터를 폼에 채우는 코드
		    $("#popup #popupContent").on("click", ".table_line tbody tr", function() {
		    	alert("구");
		        // 클릭한 tr의 각 td 값을 변수에 저장
		        var memberName = $(this).find("td:nth-child(1)").text();  // 회원 이름
		        var memberPhone = $(this).find("td:nth-child(2)").text();  // 전화번호
		        var jumin = $(this).find("td:nth-child(3)").text().split("-");  // 주민등록번호
		        var gender = $(this).find("td:nth-child(4)").text();  // 성별
		        var custnumber = $(this).find("td:nth-child(5)").text();  // 성별

		        // 값을 #updatesection 내의 입력 필드에 설정
		        $("#updatesection .memberName").val(memberName);
		        $("#updatesection .memberphone").val(memberPhone);
		        $("#updatesection .jumin1").val(jumin[0]);
		        $("#updatesection .jumin2").val(jumin[1]);
		        $("#updatesection .custnumber").val(custnumber);
		        
		        // 성별 라디오 버튼 값 설정
		        if (gender === "1") {
		            $("input[name='1'][value='1']").prop("checked", true);
		        } else if (gender === "2") {
		            $("input[name='1'][value='2']").prop("checked", true);
		        }
		        
		        $("#popup").hide();
		    });
		});
	</script>
</body>
</html>
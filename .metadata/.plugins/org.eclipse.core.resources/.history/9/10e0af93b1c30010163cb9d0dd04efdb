<%
request.setCharacterEncoding("UTF-8");

PreparedStatement pstmt = null;
ResultSet rs = null;

try {
    String sql = "SELECT medicineName, price, quantity, inventory, companyName, standard, receiptDate, DeliveryDate, returnInv "
               + "FROM testTable"  + idSortation + " ORDER BY medicineName ASC";

    pstmt = conn.prepareStatement(sql);
    rs = pstmt.executeQuery();

    while (rs.next()) {
        String standardStr = rs.getString("standard");
        double inventory = rs.getDouble("inventory");
        double quantity = rs.getDouble("quantity");
        double standardFactor = 1.0;

        try {
            Pattern numberPattern = Pattern.compile("\\d+(\\.\\d+)?");
            Matcher matcher = numberPattern.matcher(standardStr);
            List<Double> numbers = new ArrayList<Double>();

            while (matcher.find()) {
                numbers.add(Double.parseDouble(matcher.group()));
            }

            if (numbers.size() >= 2) {
                standardFactor = 1.0;
                for (double num : numbers) standardFactor *= num;
            } else if (numbers.size() == 1) {
                standardFactor = numbers.get(0);
            }
        } catch (Exception e) {
            standardFactor = 1.0;
        }

        // 실제 재고 환산
        double realInv = inventory / standardFactor;
        realInv = Math.round(realInv * 100.0) / 100.0;

        // 🚨 여기서 필터링: 재고가 수량보다 부족한 경우만 출력
        if (realInv < quantity) {
%>
            <tr>
                <td><input type="checkbox" class="isOrdered"></td>
                <td>
                    <button type="button" class="updateInfo">수정</button>
                    <button class="deleteInfo">삭제</button>
                </td>
                <td><%= rs.getString("medicineName") %></td>
                <td><%= rs.getString("DeliveryDate") %></td>
                <td><%= rs.getString("quantity") %></td>
                <td><%= realInv %></td>
                <td><%= rs.getString("standard") %></td>
                <td><%= rs.getString("price") %></td>
                <td><%= rs.getString("companyName") %></td>
                <td><%= rs.getString("receiptDate") %></td>
                <td>
                    <input type="button" value="<%= rs.getInt("returnInv") == 1 ? "반품됨" : "반품하기" %>">
                </td>
            </tr>
<%
        } // if 끝
    }
} catch (Exception e) {
    e.printStackTrace();
} finally {
    if (rs != null) try { rs.close(); } catch (SQLException e) {}
    if (pstmt != null) try { pstmt.close(); } catch (SQLException e) {}
    if (conn != null) try { conn.close(); } catch (SQLException e) {}
}
%>

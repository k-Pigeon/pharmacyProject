<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Insert title here</title>
</head>
<body>
<%
int page = Integer.parseInt(request.getParameter("page"));
int limit = 50;
int offset = (page - 1) * limit;
String sql = "SELECT * FROM medicineTable ORDER BY id DESC LIMIT ? OFFSET ?";
PreparedStatement pstmt = conn.prepareStatement(sql);
pstmt.setInt(1, limit);
pstmt.setInt(2, offset);
ResultSet rs = pstmt.executeQuery();

while(rs.next()) {
%>
<tr data-id="<%=rs.getInt("id")%>">
  <td><input class="editable" name="medicineName" value="<%=rs.getString("medicineName")%>"></td>
  <td><input class="editable" name="quantity" value="<%=rs.getInt("quantity")%>"></td>
</tr>
<%
}
%>

</body>
</html>
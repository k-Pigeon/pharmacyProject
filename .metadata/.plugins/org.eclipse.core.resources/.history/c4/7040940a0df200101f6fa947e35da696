@charset "UTF-8";

/* =============================
   기본 리셋
============================= */
* {
    padding: 0;
    margin: 0;
    box-sizing: border-box;
}

a { text-decoration: none; }
ul { list-style: none; }

/* =============================
   Body
============================= */
body.sale-body {
    background: #efefef;
    overflow: hidden;
    font-family: "Noto Sans KR", sans-serif;
}

/* =============================
   Header
============================= */
#header {
    width: 100%;
    height: auto;
    overflow-x: auto;
    overflow: visible;
    color: white;
    line-height: 40px;
    position: fixed;
    z-index: 5000;
    font-size: 20px;
}

#header ul li a {
    float: left;
    padding: 0 10px;
}

#header ul li a.pageShow {
    color: red;
    border-bottom: 2px solid black;
}

.searchFocus {
    box-shadow: 0px 10px 10px -10px;
}

#userInfo {
    position: absolute;
    width: 250px;
    height: 150px;
    display: none;
    background-color: white;
    border: 1px solid black;
    z-index: 9999;
}

#wrap #header .btn-4 {
    width: 200px;
    font-size: 18px;
    position: relative;
    color: #000;
    z-index: 2;
    line-height: 40px;
    padding: 0;
}

#wrap #header .btn-4:before,
#wrap #header .btn-4:after {
    position: absolute;
    content: "";
    width: 0%;
    height: 0%;
    border: 2px solid;
    z-index: -1;
    transition: all 0.3s ease;
}

#wrap #header .btn-4:before {
    top: 0;
    left: 0;
    border-top-color: #000;
    border-left-color: #000;
    border-bottom-color: transparent;
    border-right-color: transparent;
}

#wrap #header .btn-4:after {
    bottom: 0;
    right: 0;
    border-bottom-color: #000;
    border-right-color: #000;
    border-top-color: transparent;
    border-left-color: transparent;
}

#wrap #header .btn-4:hover:before,
#wrap #header .btn-4:hover:after {
    width: 100%;
    height: 100%;
}

/* =============================
   Wrap
============================= */
#wrap {
    width: 100%;
    min-height: 100vh;
    background-color: rgba(127,127,127,0.2);
    position: relative;
    overflow-x: auto;
    z-index: 1;
}

/* =============================
   판매 제목
============================= */
.sale-title-area {
    margin-top: 25px;
    margin-bottom: 30px;
}

.sale-title-area h1 {
    font-size: 26px;
    margin-bottom: 6px;
}

#downloadStatement {
    padding: 5px 10px;
    font-size: 13px;
}

/* =============================
   메인 레이아웃
============================= */
#data {
    display: grid;
    grid-template-columns: 65% 35%;
    gap: 30px;
    padding: 0 25px;
    align-items: start;
}

/* =============================
   고객 입력
============================= */
.consumerInfo {
    display: flex;
    gap: 12px;
    margin-bottom: 10px;
}

.coolinput {
    display: flex;
    flex-direction: column;
}

.coolinput label {
    font-size: 12px;
    color: #818CF8;
    font-weight: bold;
    margin-left: 5px;
}

.memberName,
.scheduleDate {
    height: 34px;
    padding: 4px 8px;
    border-radius: 6px;
    border: 1px solid #bbb;
}

/* =============================
   테이블 공통
============================= */
.table_line {
    width: 100%;
    border-collapse: collapse;
    background: #fff;
    table-layout: fixed;
    font-size: 13px;
}

.table_line th,
.table_line td {
    border: 1px solid #666;
    height: 42px;
    padding: 3px;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
}

.table_line th {
    background: #b8c7da;
}

.table_line input[type="text"] {
    width: 100%;
    height: 26px;
    border: 1px solid #aaa;
    text-align: center;
    background: transparent;
}

/* =============================
   스크롤 테이블
============================= */
#scrollTable {
    max-height: 160px;
    overflow-y: auto;
    border: 1px solid #777;
}

/* =============================
   금액 테이블
============================= */
#generalMedicine td,
#preparations td,
#dbInsert td {
    font-weight: bold;
}

.discount-btn {
    height: 32px;
    width: 100%;
    font-size: 12px;
}

#exhaustionInv {
    width: 100%;
    height: 50px;
    font-size: 18px;
    background: #bfbfbf;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}

/* =============================
   세트 테이블
============================= */
.leftUI {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 25px;
}

.regularTable {
    width: 100%;
    border-collapse: collapse;
    border-radius: 12px;
    overflow: hidden;
}

.regularTable thead {
    background: #cdeed1;
    height: 45px;
}

.regularTable th {
    position: relative;
    height: 45px;
}

.regularTable td {
    height: 48px;
    border: 1px solid #f2b7b7;
    background: #fffafa;
    cursor: pointer;
    transition: 0.2s;
}

.regularTable td:hover {
    background: #ffeaea;
}

/* Lid */
.leftLid,
.rightLid {
    position: absolute;
    top: 0;
    width: 50%;
    height: 100%;
    background: #c0e4c4;
    font-weight: bold;
    line-height: 45px;
    transition: 0.4s;
}

.leftLid { left: 0; text-align: right; padding-right: 10px; }
.rightLid { right: 0; text-align: left; padding-left: 10px; }

.regularTable th:hover .leftLid { transform: translateX(-120%); }
.regularTable th:hover .rightLid { transform: translateX(120%); }

/* =============================
   팝업
============================= */
#popup {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%,-50%);
    width: 85%;
    max-width: 1500px;
    height: 65%;
    background: white;
    border: 2px solid #777;
    box-shadow: 0 0 15px rgba(0,0,0,0.4);
    display: none;
    z-index: 3000;
}

#popup h3 {
    text-align: center;
    margin: 10px 0;
}

#popup-table {
    width: 100%;
    height: calc(100% - 50px);
    overflow-y: auto;
    display: block;
}

/* =============================
   재확인 창
============================= */
#checkInv {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%,-50%);
    width: 80%;
    height: 70%;
    background: white;
    box-shadow: 0 0 20px rgba(0,0,0,0.5);
    display: none;
    z-index: 4000;
}

/* =============================
   경고창
============================= */
#warningBox {
    position: fixed;
    right: 20px;
    bottom: -300px;
    width: 360px;
    background: #fff8f8;
    border: 1px solid #ffb3b3;
    border-radius: 10px;
    padding: 15px;
    opacity: 0;
    transition: 0.5s;
    z-index: 5000;
}

#warningBox.show {
    bottom: 20px;
    opacity: 1;
}

/* =============================
   context menu
============================= */
#customContextMenu {
    display: none;
    position: absolute;
    z-index: 9999;
    list-style: none;
    background: #fff;
    border: 1px solid #ccc;
    padding: 5px;
    border-radius: 5px;
}

#customContextMenu li {
    padding: 5px 10px;
    cursor: pointer;
}

#customContextMenu li:hover {
    background: #eee;
}

/* =============================
   standardDetail
============================= */
.standardDetail {
    display: none;
    width: 100px;
    border: 1px solid black;
    background: white;
    font-size: 25px;
    box-shadow: 5px 5px 10px 2px;
    cursor: pointer;
}

.standardDetail div:hover {
    background: #4B0082;
    color: white;
}

/* =============================
   focus style
============================= */
.inputCheckStyle,
.selectCheck {
    box-shadow: 0 0 10px 2px;
    border: 3px solid green;
}

/* =============================
   반응형 최소
============================= */
@media screen and (max-width: 800px) {
    #data {
        grid-template-columns: 1fr;
    }

    .table_line th,
    .table_line td {
        text-align: left;
    }
}

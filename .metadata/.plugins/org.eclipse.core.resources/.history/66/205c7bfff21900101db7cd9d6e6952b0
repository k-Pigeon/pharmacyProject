			// 이벤트 핸들러를 다시 적용하는 함수
			function applyEventHandlers() {
			    $(".removeTr").off("click").on("click", function() {
			        var rowCount = $("#section .RegistrationUi .membertable .registrationData tr").length;
			        
			        if (rowCount <= 2) {  // 숫자로 비교
			            return false;  // 마지막 행이면 삭제하지 않음
			        }
			        
			        $(this).closest("tr").remove();
			    });

	<script>
		$(document).ready(function(){
			$("#wrap #section .RegistrationUi membertable .price").on("keyup", function(){
				var commaVal = $(this).val().replace(/[^0-9]/g, "");
			    if (commaVal === "") {
			        $(this).val("");
			        return;
			    }
			    var formatted = commaVal.replace(/\B(?=(\d{3})+(?!\d))/g, ",");
			    $(this).val(formatted);
			});
			document.addEventListener("input", function (event) {
			    if (event.target.classList.contains("dateSystem")) {
			        let input = event.target.value.replace(/[^0-9]/g, ""); // 숫자 외 제거
			        let formatted = "";

			        if (input.length > 2) {
			            formatted += input.substring(0, 2) + "/"; // 첫 번째 슬래시 추가
			        } else {
			            formatted += input;
			        }

			        if (input.length > 4) {
			            formatted += input.substring(2, 4) + "/"; // 두 번째 슬래시 추가
			            formatted += input.substring(4, 6); // 나머지 추가
			        } else if (input.length > 2) {
			            formatted += input.substring(2); // 첫 슬래시 뒤 나머지 추가
			        }
			        event.target.value = formatted.slice(0, 8); // 최대 8자리 유지
			    }
			});
			  $('#copyRow').click(function() {
				    copySecondRow();
				  });

				  $('#removeRow').click(function() {
				    deleteLastRow();
				  });
			// 복사해서 붙여넣기
			function copySecondRow() {
			  let $secondRow = $("#editModalContent table tbody tr:eq(1)").clone();
			  $("#editModalContent table tbody").append($secondRow);
			  $("#editModalContent table tbody tr:last").find('input').val('');
			  if($("#editModalContent table tbody tr").length <= 2){
				  return false;
			  }
			}

			// 마지막 행 삭제
			function deleteLastRow() {
			  $("#editModalContent table tbody tr:last").remove();
			}

			$('#saveChanges').on('click', function () {
				  const rows = $('#editModalContent tr');
				  const medicineName = $(".udpateMedicineName").val();

				  const rowData = [];

				  // 각 tr마다 입력값 수집
				  rows.each(function () {
				    const standard = $(this).find('.standards').val();
				    const buyingPrice = $(this).find('.buyingPrice').val();
				    const price = $(this).find('.price').val();
				    const lowerAndHigest = $(this).find('.lowerAndHigest').val();

				    if (standard && buyingPrice && price) {
				      rowData.push({
				        standard: standard,
				        buyingPrice: buyingPrice,
				        price: price,
				        lowerAndHigest: lowerAndHigest
				      });
				    }
				  });

				  const payload = {
				    medicineName: medicineName,
				    productList: rowData
				  };

				  $.ajax({
				    url: 'updateProductInfo.jsp',
				    method: 'POST',
				    contentType: 'application/json',
				    data: JSON.stringify(payload),
				    success: function (res) {
				      alert("수정 성공!");
				      $('#editModal').hide();
				      location.reload();
				    },
				    error: function () {
				      alert("수정 실패!");
				    }
				  });
				});


			
			let selectedRowData = null;

			$(document).on("contextmenu", "#popup-content tr", function (e) {
			    e.preventDefault();
			    selectedRowData = $(this);

			    // 컨텍스트 메뉴 위치 지정 및 표시
			    $("#customContextMenu")
			        .css({ top: e.pageY + "px", left: e.pageX + "px" })

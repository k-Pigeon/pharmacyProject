			$(".resultData").on("click", "tr", function() {
			    var saleDate = $(this).find("td:nth-child(1)").text(); // 클릭한 행의 날짜를 가져옴
			    $(".saleResult").val(saleDate);
			    $(".resultData tr").removeClass("selectRegist");
			    $(this).addClass("selectRegist");

			    // AJAX로 서버에 날짜를 전송
			    $.ajax({
			        url: "getSaleData.jsp", // 서버에서 데이터를 받는 JSP 파일
			        type: "GET",
			        data: { saleDate: saleDate }, // 선택한 날짜를 전달
			        success: function(response) {
			            var data = JSON.parse(response); // JSON으로 변환
			            let rows = $(".membertable tbody.registrationData tr"); // 기존 테이블의 행들 가져오기

			            // 기존 테이블 행 개수와 받아온 데이터 개수를 비교하여 입력
			            for (let i = 0; i < rows.length; i++) {
			                let row = $(rows[i]); // 현재 행

			                if (i < data.length) {
			                    row.find(".medicineName").val(data[i].medicine_name);
			                    row.find(".inventory").val(data[i].inventory);
			                    row.find(".standard").val(data[i].standard);
			                    row.find(".price").val(data[i].price);
			                    row.find(".totalPrice").val(data[i].total_price);
			                    row.find(".lowerAndHigest").val(data[i].lowerAndHigest);
			                } else {
			                    // 남은 행들은 빈값으로 설정
			                    row.find("input").val("");
			                }
			            }

			            // 할인가격 입력
			            $(".discounted").val(data.length > 0 ? data[0].discounted : 0);

			            // 총합 계산
			            let total = 0;
			            $(".membertable tbody.registrationData .totalPrice").each(function() {
			                let value = parseFloat($(this).val());
			                if (!isNaN(value)) {
			                    total += value;
			                }
			            });

			            $(".totalCalcul").val(total); // 합계 반영
			            $(".maxTotal").val(total - $(".discounted").val()); // 총합 반영

			        },
			        error: function(xhr, status, error) {
			            console.log("Error: " + error);
			        }
			    });
			});

			// 할인가격 변경 시 총합 업데이트
			$(".discounted").on("input", function() {
			    let total = parseFloat($(".totalCalcul").val()) || 0;
			    let discount = parseFloat($(this).val()) || 0;
			    $(".maxTotal").val(total - discount);
			});


		    function updateTotalPrice(row) {
		        let inventory = parseFloat($(row).find(".inventory").val()) || 0;
		        let price = parseFloat($(row).find(".price").val()) || 0;
		        let totalPrice = inventory * price;
		        $(row).find(".totalPrice").val(totalPrice); // totalPrice 계산 후 입력
		        updateTotalCalcul(); // 합계 자동 갱신
		    }

		    // 전체 합계 계산
		    function updateTotalCalcul() {
		        let total = 0;
		        $(".totalPrice").each(function() {
		            let value = parseFloat($(this).val());
		            if (!isNaN(value)) {
		                total += value;
		            }
		        });
		        $(".totalCalcul").val(total); // totalCalcul에 합계 업데이트
		        $(".maxTotal").val($(".totalCalcul").val() - $(".discounted").val());
		    }

		    // 수량과 단가가 변경될 때마다 totalPrice와 totalCalcul 갱신
		    $(".registrationData").on("input", ".inventory, .price", function() {
		        var row = $(this).closest('tr');
		        updateTotalPrice(row);  // 해당 행에서 가격 업데이트
		    });

		    // 행 삭제 후 합계 다시 계산
		    $(".registrationData").on("click", ".removeTr", function() {
		        $(this).closest('tr').remove();  // 행 삭제

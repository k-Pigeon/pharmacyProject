<%@ page language="java" contentType="application/json; charset=UTF-8"
	pageEncoding="UTF-8"%>
<%@ page import="java.sql.*"%>
<%@ include file="DBconnection.jsp"%>
<%
String dbName = (session != null) ? (String) session.getAttribute("dbName") : null;
String id = (session != null) ? (String) session.getAttribute("id") : null;
String password = (session != null) ? (String) session.getAttribute("password") : null;

String idSortation = (session != null) ? (String) session.getAttribute("idSortation") : null; if (id == null || dbName == null) {
	response.sendRedirect("login.jsp");
	return;
}

response.setContentType("application/json");
response.setCharacterEncoding("UTF-8");

PreparedStatement pstmt = null;
ResultSet rs = null;

try {
	String serialNumber = request.getParameter("serialNumber");
	if (serialNumber == null || serialNumber.isEmpty()) {
		out.println("{\"error\":\"serialNumber is missing\"}");
		return;
	}

	String sql = " select medicineName, Buyingprice, price, inventory, kind, standard, companyName, DeliveryDate "
	+ " from testTable"  + idSortation + "  " + " where SerialNumber = ? ";
	pstmt = conn.prepareStatement(sql);
	pstmt.setString(1, serialNumber);
	rs = pstmt.executeQuery();

	if (rs.next()) {

		String medicineNames = rs.getString("medicineName");
		String deliveryDate = rs.getString("DeliveryDate");
		String buyingPrice = rs.getString("Buyingprice");
		String price = rs.getString("price");
		String kind = rs.getString("kind");
		String companyName = rs.getString("companyName");
		String standard = rs.getString("standard");

		double inventory = rs.getDouble("inventory"); // 원래 inventory 값
		double calculatedInventory = inventory; // 기본적으로 inventory 유지

		// 🔹 standard 값에 따라 inventory 조정
		if (standard != null && !standard.trim().isEmpty()) {
	if (standard.contains("g") || standard.contains("포")) {
		// "ml", "g", "포" 포함된 경우 → inventory 그대로 유지
		calculatedInventory = inventory;
	} else {
		String[] parts = standard.split(" "); // 공백으로 나누기
		double standardValue = 1.0; // 기본값

		try {
			if (parts.length == 2) {
				// 예: "20g 4포" → 20 * 4
				double num1 = Double.parseDouble(parts[0].replaceAll("[^0-9]", ""));
				double num2 = Double.parseDouble(parts[1].replaceAll("[^0-9]", ""));
				standardValue = num1 * num2;
			} else if (parts.length == 1) {
				// 숫자 하나만 있는 경우
				standardValue = Double.parseDouble(standard.replaceAll("[^0-9]", ""));
			}

			if (standardValue > 0) {
				calculatedInventory = inventory / standardValue;
			}
		} catch (NumberFormatException e) {
			System.err.println("NumberFormatException 발생: " + e.getMessage());
			calculatedInventory = inventory; // 변환 실패 시 원래 값 유지
		}
	}
		}

		String jsonData = "{" + "\"medicineName\":\"" + rs.getString("medicineName") + "\"," + "\"Buyingprice\":\""
		+ rs.getString("Buyingprice") + "\"," + "\"price\":\"" + rs.getString("price") + "\","
		+ "\"inventory\":\"" + calculatedInventory + "\"," + "\"standard\":\"" + rs.getString("standard")
		+ "\"," + "\"kind\":\"" + rs.getString("kind") + "\"," + "\"companyName\":\""
		+ rs.getString("companyName") + "\"," + "\"DeliveryDate\":\"" + rs.getString("DeliveryDate") + "\""
		+ "}";
		out.print(jsonData);
	} else {
		out.println("{\"error\":\"No data found for SerialNumber: " + serialNumber + "\"}");
	}
} catch (SQLException e) {
	e.printStackTrace();
	out.println("{\"error\":\"Database error: " + e.getMessage() + "\"}");
} finally {
	try {
		if (rs != null)
	rs.close();
		if (pstmt != null)
	pstmt.close();
		if (conn != null)
	conn.close();
	} catch (SQLException e) {
		e.printStackTrace();
	}
}
%>

te = ? AND returnInv='0'"; final String updByName = "UPDATE testTable" + idSortation + " SET inventory = inventory - ? WHERE medicineName = ? AND DeliveryDate = ? AND returnInv='0'"; for (int i = 0; i < jsonArr.length() - 1; i++) { JSONObject item = jsonArr.getJSONObject(i); String serial = item.optString("serialNumber", "").trim(); String medName = item.optString("medicineName", "").trim(); int qtySale = item.optInt("inventory"); String priceStr = item.optString("price", "0").replaceAll("[^\\d.]", ""); String buyStr = item.optString("Buyingprice", "0").replaceAll("[^\\d.]", ""); boolean bySerial = !serial.isEmpty(); double salePrice = 0.0, buyPrice = 0.0; try { salePrice = Double.parseDouble(priceStr); } catch (NumberFormatException ignore) {} try { buyPrice = Double.parseDouble(buyStr); } catch (NumberFormatException ignore) {} double factor = 1.0; try { Matcher m = Pattern.compile("\\d+(\\.\\d+)?").matcher(item.optString("standard", "")); double n1 = 1.0, n2 = 1.0; if (m.find()) n1 = Double.parseDouble(m.group()); if (m.find()) n2 = Double.parseDouble(m.group()); factor = n1 * n2; } catch (Exception ignore) {} boolean isSet = false; try (PreparedStatement ck = conn.prepareStatement("SELECT 1 FROM productSet WHERE setName = ? LIMIT 1")) { ck.setString(1, medName); try (ResultSet rs = ck.executeQuery()) { if (rs.next()) isSet = true; } } if (isSet) { try (PreparedStatement setQ = conn.prepareStatement( "SELECT psd.medicineName, psd.standard " + "FROM productSet_detail psd " + "JOIN productSet ps ON ps.id = psd.productSet_id " + "WHERE ps.setName = ?" )) { setQ.setString(1, medName); try (ResultSet rsSet = setQ.executeQuery()) { while (rsSet.next()) { String inner = rsSet.getString("medicineName"); String standard = rsSet.getString("standard"); if (inner == null || inner.trim().isEmpty()) continue; double innerFactor = 1.0; try { Matcher m = Pattern.compile("\\d+(\\.\\d+)?").matcher(standard); double n1 = 1.0, n2 = 1.0; if (m.find()) n1 = Double.parseDouble(m.group(
<%@ page language="java" contentType="text/plain; charset=UTF-8" pageEncoding="UTF-8" %>
<%
response.setContentType("text/plain; charset=UTF-8");
response.setCharacterEncoding("UTF-8");
%>
<%@ include file="sessionManager.jsp" %>
<%@ include file="DBconnection.jsp" %>
<%
    // ---- 출력 버퍼 비우기 ----
    out.clear();

    boolean warningFound = false;

    String sql = "SELECT inventory, standard, quantity FROM testTable" + idSortation + " WHERE returnInv='0'";
    PreparedStatement ps = conn.prepareStatement(sql);
    ResultSet rs = ps.executeQuery();

    while (rs.next()) {
        double inv = rs.getDouble("inventory");
        String standard = rs.getString("standard");
        double qty = rs.getDouble("quantity");

        double std = 1;
        if (standard != null) {
            java.util.regex.Matcher m = java.util.regex.Pattern
                .compile("\\d+(\\.\\d+)?").matcher(standard);
            while (m.find()) std *= Double.parseDouble(m.group());
        }

        if (qty > inv * std) {
            warningFound = true;
            break;
        }
    }

    rs.close();
    ps.close();

    // ---- 최종 출력 Y or N ----
    out.print(warningFound ? "Y" : "N");

    // ---- JSP 자동 개행 방지 ----
    out.flush();
%>

            ps.setDouble(3, buyPrice);
            ps.setDouble(4, salePrice);
            ps.setString(5, item.optString("inventory", ""));
            ps.setString(6, serial);
            ps.setString(7, item.optString("deliveryDate", ""));
            ps.setString(8, item.optString("standard", ""));
            ps.setString(9, item.optString("memberName", ""));
            ps.executeUpdate();
        }

        String deleteQuery = "DELETE FROM SalesRecord" + idSortation + " WHERE medicineName = ''";
        try (PreparedStatement deleteTmt = conn.prepareStatement(deleteQuery)) {
            deleteTmt.executeUpdate();
        }
    }

    conn.commit();
    out.println("{\"result\":\"success\"}");

} catch (Exception e) {
    if (conn != null) try { conn.rollback(); } catch (SQLException ignore) {}
    e.printStackTrace();
    out.println("{\"result\":\"error\", \"message\":\"" + e.getMessage().replace("\"", "'") + "\"}");
}

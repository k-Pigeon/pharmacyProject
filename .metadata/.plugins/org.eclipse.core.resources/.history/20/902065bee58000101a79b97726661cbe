try {
    StringBuilder sb = new StringBuilder();
    try (BufferedReader br = request.getReader()) {
        String line;
        while ((line = br.readLine()) != null) sb.append(line);
    }

    JSONArray jsonArr = new JSONArray(sb.toString());
    JSONObject meta = jsonArr.getJSONObject(jsonArr.length() - 1);
    System.out.println(meta);

    String medicinePrice = meta.getString("medicinePrice");
    String generalPrice  = meta.getString("generalPrice");
    String clientName    = meta.getString("discounted");

    String raw = meta.has("ScheduleDate")
            ? meta.optString("ScheduleDate", "")
            : meta.optString("scheduleDate", "");
    raw = (raw == null) ? "" : raw.trim();

    // "yyyy-MM-dd HH:mm:ss" 또는 "yyyy-MM-dd" 또는 "yy/MM/dd" → 표준화
    String formatted = formatDate(raw);

    // 기본 now: 포맷 불가/빈 값이면 현재시각, 아니면 주어진 시각(종종 00:00:00)
    Timestamp baseNow = (formatted == null || formatted.isEmpty())
            ? new Timestamp(System.currentTimeMillis())
            : Timestamp.valueOf(formatted);

    // ★ 충돌 방지: 필요한 경우 1ms씩 증가하여 유일한 saleDate 확보
    Timestamp now = findUniqueSaleDate(conn, idSortation, baseNow);

    System.out.println("now(final) : " + now + " \nraw : " + raw + " \nformatted : " + formatted);

    // 1) priceRecord
    try (PreparedStatement ps = conn.prepareStatement(
        "INSERT INTO priceRecord" + idSortation + " (saleDate, maxmedicinePrice, generalPrice) VALUES (?, ?, ?)"
    )) {
        ps.setTimestamp(1, now);
        ps.setString(2, medicinePrice);
        ps.setString(3, generalPrice);
        ps.executeUpdate();
    }

    // 2) discountedDB
    try (PreparedStatement ps = conn.prepareStatement(
        "INSERT INTO discountedDB (sale_date, discounted) VALUES (?, ?)"
    )) {
        ps.setTimestamp(1, now);
        ps.setString(2, clientName);
        ps.executeUpdate();
    }

    final String selBySerial = "SELECT DeliveryDate, inventory FROM testTable"  + idSortation + "  WHERE SerialNumber = ? AND medicineName = ? AND returnInv='0' AND inventory>0 ORDER BY DeliveryDate ASC LIMIT 1";
    final String selByName   = "SELECT DeliveryDate, inventory FROM testTable"  + idSortation + "  WHERE medicineName = ? AND returnInv='0' AND inventory>0 ORDER BY DeliveryDate ASC LIMIT 1";
    final String updBySerial = "UPDATE testTable"  + idSortation + "  SET inventory = inventory - ? WHERE SerialNumber = ? AND medicineName = ? AND DeliveryDate = ? AND returnInv='0'";
    final String updByName   = "UPDATE testTable"  + idSortation + "  SET inventory = inventory - ? WHERE medicineName = ? AND DeliveryDate = ? AND returnInv='0'";

    for (int i = 0; i < jsonArr.length() - 1; i++) {
        JSONObject item = jsonArr.getJSONObject(i);

        String serial   = item.optString("serialNumber", "").trim();
        String medName  = item.optString("medicineName", "").trim();
        double qtySale  = item.optDouble("inventory", 0.0);
        String priceStr = item.optString("price", "0").replaceAll("[^\\d.]", "");
        String buyStr   = item.optString("Buyingprice", "0").replaceAll("[^\\d.]", "");
        boolean bySerial = !serial.isEmpty();

        double salePrice = 0.0, buyPrice = 0.0;
        try { salePrice = Double.parseDouble(priceStr); } catch (NumberFormatException ignore) {}
        try { buyPrice  = Double.parseDouble(buyStr);   } catch (NumberFormatException ignore) {}

        double factor = 1.0;
        try {
            Matcher m = Pattern.compile("\\d+(\\.\\d+)?").matcher(item.optString("standard", ""));
            double n1 = 1.0, n2 = 1.0;
            if (m.find()) n1 = Double.parseDouble(m.group());
            if (m.find()) n2 = Double.parseDouble(m.group());
            factor = n1 * n2;
        } catch (Exception ignore) {}

        boolean isSet = false;
        try (PreparedStatement ck = conn.prepareStatement("SELECT 1 FROM productSet WHERE setName = ? LIMIT 1")) {
            ck.setString(1, medName);
            try (ResultSet rs = ck.executeQuery()) {
                if (rs.next()) isSet = true;
            }
        }

        if (isSet) {
            try (PreparedStatement setQ = conn.prepareStatement(
                "SELECT psd.medicineName, psd.standard " +
                "FROM productSet_detail psd " +
                "JOIN productSet ps ON ps.id = psd.productSet_id " +
                "WHERE ps.setName = ?"
            )) {
                setQ.setString(1, medName);
                try (ResultSet rsSet = setQ.executeQuery()) {
                    while (rsSet.next()) {
                        String inner = rsSet.getString("medicineName");
                        String standard = rsSet.getString("standard");
                        if (inner == null || inner.trim().isEmpty()) continue;

                        double innerFactor = 1.0;
                        try {
                            Matcher m = Pattern.compile("\\d+(\\.\\d+)?").matcher(standard);
                            double n1 = 1.0, n2 = 1.0;
                            if (m.find()) n1 = Double.parseDouble(m.group());
                            if (m.find()) n2 = Double.parseDouble(m.group());
                            innerFactor = n1 * n2;
                        } catch (Exception ignore) {}

                        double remain = qtySale;
                        while (remain > 0.0001) {
                            try (PreparedStatement sel = conn.prepareStatement(selByName)) {
                                sel.setString(1, inner);
                                try (ResultSet rs = sel.executeQuery()) {
                                    if (!rs.next()) break;

                                    String dDate = rs.getString("DeliveryDate");
                                    double stock = rs.getDouble("inventory");
                                    if (stock <= 0.00001) break;

                                    double needDb = remain * innerFactor;
                                    double useDb  = Math.min(needDb, stock);
                                    if (useDb <= 0.00001) break;

                                    double usedSaleUnit = useDb / innerFactor;

                                    try (PreparedStatement upd = conn.prepareStatement(updByName)) {
                                        upd.setDouble(1, useDb);
                                        upd.setString(2, inner);
                                        upd.setString(3, dDate);
                                        int affected = upd.executeUpdate();
                                        if (affected == 0)
                                            throw new SQLException("세트 구성품 차감 실패");
                                    }

                                    remain -= usedSaleUnit;
                                    if (remain < 0.0001) break;
                                }
                            }
                        }
                    }
                }
            }
        }else if ("일반세트".equals(serial) || "한약세트".equals(serial)) {
            // ✅ 세트 차감
            String sql = "SELECT medicineName, inventory AS perSetQty FROM regularSet WHERE setName = ?";
            try (PreparedStatement ps = conn.prepareStatement(sql)) {
                ps.setString(1, serial);  // 세트 이름
                try (ResultSet rs = ps.executeQuery()) {
                    while (rs.next()) {
                        String medName   = rs.getString("medicineName");
                        double perSetQty = rs.getDouble("perSetQty");

                        // 세트 판매 수량 × 세트당 구성품 개수
                        double remain = qtySale * perSetQty;

                        while (remain > 0) {
                            try (PreparedStatement sel = conn.prepareStatement(bySerial ? selBySerial : selByName)) {
                                if (bySerial) {
                                    sel.setString(1, serial);
                                    sel.setString(2, medName);
                                } else {
                                    sel.setString(1, medName);
                                }

                                try (ResultSet rsStock = sel.executeQuery()) {
                                    if (!rsStock.next()) break;

                                    String dDate = rsStock.getString("DeliveryDate");
                                    double stock = rsStock.getDouble("inventory");

                                    double needDb = remain * factor;
                                    double useDb  = Math.min(needDb, stock);
                                    double usedSaleUnit = useDb / factor;

                                    try (PreparedStatement upd = conn.prepareStatement(bySerial ? updBySerial : updByName)) {
                                        int p = 1;
                                        upd.setDouble(p++, useDb);
                                        if (bySerial) upd.setString(p++, serial);
                                        upd.setString(p++, medName);
                                        upd.setString(p, dDate);

                                        if (upd.executeUpdate() == 0) {
                                            throw new SQLException("세트 구성품 차감 실패: " + medName);
                                        }
                                    }

                                    remain -= usedSaleUnit;
                                }
                            }
                        }
                    }
                }
            }
        } else {
            // 단품 차감 (기존 코드)
        }


        try (PreparedStatement ps = conn.prepareStatement(

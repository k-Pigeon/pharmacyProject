<!DOCTYPE html>
<html>
<head>
<title>에스팜</title>
<style>
#header ul {
	display: block;
}

#wrap #section {
	display: block;
	width: 100%;
	height: 95vh;
	transform: translateY(5vh);
}

#wrap #section h1 {
	text-align: center;
}

#wrap #section .tableWrapper {
	height: 75%;
	overflow-y: auto;
	margin: auto;
	width: 90%;
	border: 1px solid #ccc;
}

#wrap #section .salesTable {
	border-collapse: separate;
	border-spacing: 0;
	width: 100%;
	table-layout: fixed;
}

#wrap #section .salesTable thead th {
	position: sticky;
	top: 0;
	background-color: #6c4ba0;
	z-index: 1;
	color: white;
}

#wrap #section .salesTable th, #wrap #section .salesTable td {
	text-align: center;
	padding: 8px;
	border: 1px solid #ccc;
}

#wrap #section .salesTable td:nth-child(1) {
	background-color: #c6aef0;
	color: white;
}

#wrap #section .salesfilter {
	width: 90%;
	height: 100px;
	margin: 0 auto;
}

#wrap #section .salesfilter .startSales, #wrap #section .salesfilter .endSales
	{
	width: 120px;
	height: 35px;
}

#wrap #section .salesfilter .dateBtn {
	margin-top: 5px;
	width: 50%;
}

#wrap #section .salesfilter .dateBtn .dateBtnfilter {
	color: #090909;
	padding: 0.7em 1.7em;
	font-size: 18px;
	border-radius: 0.5em;
	background: #e8e8e8;
	cursor: pointer;
	border: 1px solid #e8e8e8;
	transition: all 0.3s;
	box-shadow: 6px 6px 12px #c5c5c5, -6px -6px 12px #ffffff;
}

#wrap #section .salesfilter .dateBtn .dateBtnfilter:active {
	color: #666;
	box-shadow: inset 4px 4px 12px #c5c5c5, inset -4px -4px 12px #ffffff;
}

#wrap #section .salesfilter .excelDownload {
	position: absolute;
	top: 7%;
	right: 5%;
	font-weight: 600;
	color: white;
	text-transform: uppercase;
	padding: 1em 2em;
	background-color: #00bcd4; /* 시원한 바다색 (cyan 계열) */
	border: 2px solid #008ba3;
	border-radius: 10px;
	cursor: pointer;
	box-shadow: 0 8px 12px rgba(0, 128, 192, 0.3);
	transition: background-color 0.2s ease, transform 0.2s ease;
}

#wrap #section .salesfilter .excelDownload:hover {
	background-color: #008ba3;
	transform: translateY(-2px);
	box-shadow: 0 12px 18px rgba(0, 128, 192, 0.4);
}

#wrap #section .salesfilter .excelDownload:active {
	background-color: #006978;
	transform: translateY(1px);
	box-shadow: 0 4px 8px rgba(0, 128, 192, 0.2);
}

#wrap #section .salesfilter .datePicker .toggleSwitch {
	position: relative;
	top: 5px;
	left: 5%;
	height: 2rem;
	width: 100px;
	cursor: pointer;
	appearance: none;
	-webkit-appearance: none;
	border-radius: 9999px;
	background-color: rgba(100, 116, 139, 0.377);
	transition: all .3s ease;
	left: 5%;
}

#wrap #section .salesfilter .datePicker .toggleSwitch:checked {
	background-color: rgba(236, 72, 153, 1);
}

#wrap #section .salesfilter .datePicker .toggleSwitch::after {
	position: absolute;
	width: 95%;
	content: "일별";
	text-align: center;
}

#wrap #section .salesfilter .datePicker .toggleSwitch::before {
	position: absolute;
	content: "";
	left: -20px;
	top: -7px;
	display: block;
	height: 45px;
	width: 45px;
	cursor: pointer;
	border: 1px solid rgba(100, 116, 139, 0.527);
	border-radius: 9999px;
	background-color: rgba(255, 255, 255, 1);
	box-shadow: 0 3px 10px rgba(100, 116, 139, 0.327);
	transition: all .3s ease;
}

#wrap #section .salesfilter .datePicker .toggleSwitch:checked::before {
	transform: translateX(85px);
	border-color: rgba(236, 72, 153, 1);
}

#wrap #section .salesfilter .datePicker .toggleSwitch:checked::after {
	position: absolute;
	width: 95%;
	content: "월별";
	text-align: center;
}

#wrap .tableWrapper .salesTable .totalSales tr.detailTR {
	position: relative;
	background: linear-gradient(145deg, #2a2a2a, #1a1a1a); /* 은은한 빛 */
	color: #fff;
	transform: translateY(-4px); /* 위로 살짝 떠오름 */
	box-shadow: 0 12px 24px rgba(10px, 10px, 10px, 0.8); /* 입체 그림자 */
	z-index: 10;
	transition: all 0.2s ease-in-out;
	border-radius: 8px;
}

.medicineBorder {
	width: 210px;
	height: 50px;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	background: linear-gradient(to bottom, rgb(227, 213, 255),
		rgb(255, 231, 231));
	border-radius: 30px;
	overflow: hidden;
	cursor: pointer;
	box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.075);
}

.medicineBorder .medicineTotal {
	width: 200px;
	height: 40px;
	border: none;
	outline: none;
	caret-color: rgb(255, 81, 0);
	background-color: rgb(255, 255, 255);
	border-radius: 30px;
	padding-left: 15px;
	letter-spacing: 0.8px;
	color: rgb(19, 19, 19);
	font-size: 13.4px;
}

#wrap #section .salesfilter .dateBtn .filterSelect {
	background: #D8BFD8;
	border: 1px solid #E6E6FA;
}
/* 이미 있던 속성에 이어서 덮어쓰기 */
.salesDetail{                /* 오버레이 */
    display:none;
    position:absolute;
    inset:0;
    background:rgba(0,0,0,.6);
    z-index:10000;
}
/* ───────── 2. 팝업 컨테이너 (.showToDetail) ───────── */
.showToDetail {
  background: #ffffff;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
}
/* 네온 외곽선 제거 */
.showToDetail::before,
.showToDetail::after { content: none; }

/* ───────── 3. 내부 프레임 (.frame) ───────── */
.frame {
  position: absolute;
  inset: 0;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  pointer-events: none;      /* 기존 값 유지 */
}
/* 프레임 네온선 제거 */
.frame::before,
.frame::after { content: none; }

/* ───────── 4. 패널 (.panel) ───────── */
.panel {
  position: relative;
  inset: auto;
  background: #ffffff;
  clip-path: none;           /* 각진 모서리 해제 */
}

/* ───────── 5. 테이블 (.cyber-table) ───────── */
.flaTable {
  width: 100%;
  border-collapse: collapse;
  table-layout: fixed;
  font-family: "Pretendard", "Noto Sans KR", sans-serif;
  font-size: 0.9rem;
  color: #222;
  background: #ffffff;
}
/* 셀 공통 */
.flaTable th,
.flaTable td {
  border: 1px solid #eaeaea;
  padding: 10px 8px;
  text-align: center;
}
/* 헤더 */
.flaTable thead th {
  background: #f5f6f8;
  font-weight: 600;
  letter-spacing: 0;
  text-shadow: none;
}
/* 바디 행 호버: 강조색만 */
.flaTable tbody tr:hover td {
  background: #f0f7ff;
  transform: none;
  box-shadow: none;
}
/* 지그재그 배경 선택 */
.flaTable tbody tr:nth-child(odd) {
  background: #fafafa;
}

/* ───────── 6. 스크롤 영역 ───────── */
.table-scroll-wrapper {
  max-height: 420px;         /* 필요 시 조정 */
  overflow-y: auto;
  border-top: 1px solid #eaeaea;
}
/* 깔끔한 스크롤바 (크롬) */
.table-scroll-wrapper::-webkit-scrollbar {
  display:none;
}
.alignPosition{
position: absolute;
    width: 80%;
    height: auto;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border: 10px solid #D9B7F5;
    border-radius: 10px;
}
</style>
</head>
<body>
	<div id="wrap" style="display: block;">
		<header>
			<jsp:include page="header.jsp"></jsp:include>
		</header>
		<section id="section">
			<h1>매출</h1>
			<div class="salesfilter">
				<div class="datePicker">
					결재일 : <input type="date" class="endSales"> ~ <input
						type="date" class="startSales"> <input
						class="toggleSwitch" type="checkbox" checked>
				</div>
				<div class="dateBtn">
					<input type="button" class="dateBtnfilter week" value="1주일">
					<input type="button" class="dateBtnfilter month" value="1개월">
					<input type="button" class="dateBtnfilter 3month" value="3개월">
					<input type="button" class="dateBtnfilter 6month" value="6개월">
					<input type="button" class="dateBtnfilter 1year" value="1년">
					<div class="medicineBorder">
						<input type="text" class="medicineTotal" placeholder="제품명 입력">
					</div>
				</div>

				<button type="button" class="excelDownload">Excel 다운로드</button>
			</div>
			<div class="tableWrapper">
				<table class="salesTable">
					<thead>
						<tr>
							<th>날짜</th>
							<th>판매액</th>
							<th>사입가</th>
							<th>마진</th>
							<th>마진률</th>
						</tr>
					</thead>
					<tbody class="totalSales">

					</tbody>
				</table>
			</div>
		</section>
	</div>
	<div class="salesDetail">
		<div class="alignPosition">
			<table class="flaTable">
				<colgroup>
					<col width="40%">
					<col width="15%">
					<col width="15%">
					<col width="15%">
					<col width="15%">
				</colgroup>
				<thead>
					<tr>
						<th>제품 이름</th>
						<th>사입가</th>
						<th>단가</th>
						<th>마진</th>
						<th>마진률</th>
					</tr>
				</thead>
			</table>
			<div class="table-scroll-wrapper">
				<table class="flaTable body-only">
					<colgroup>
						<col width="40%">
						<col width="15%">
						<col width="15%">
						<col width="15%">
						<col width="15%">
					</colgroup>
					<tbody>

					</tbody>
				</table>
			</div>
		</div>

	</div>

	<script src="jquery-3.7.1.min.js"></script>
	<script
		src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
	<script src="script.js"></script>
	<script>
$(document).ready(function(){
	$("#wrap #section .tableWrapper").on("dblclick", ".salesTable .totalSales tr", function(e){
		var $dateDetail = $(this).find("td:eq(0)").text().substring(0, 7);
		$.ajax({
			url : "totalDetail.jsp",
			method:"POST",
			data : {
				dateDetail : $dateDetail
			},
			success:function(response){
				$(".salesDetail .flaTable tbody").find("tr").remove();
				$(".salesDetail .flaTable tbody").html(response);
				$(".salesDetail").show();
			},
			error:function(){
				return false;
			}
		});
		$(".salesDetail").show();
	});
	$(document).on("keydown", function(e){
		if((e.key === "Escape" || e.keyCode === 27)){
			e.preventDefault();
			if($(".salesDetail").is(":visible")){
				$(".salesDetail").hide();
			}
		}
	});
	//짝홀수 tr 색상구분
	function classification(){
		var $trClassfication = $("#wrap #section").find(".salesTable tbody tr:visible");
		$trClassfication.each(function(index){
			if(index % 2 === 0){
				$(this).css("background-color", "#ddd");
			}else{
				$(this).css("background-color", "#bbb");
			}
		});
	}

	//토글 변함에 따라 표시값도 변화
	function applyView() {
		const grouped = $(".toggleSwitch").is(":checked");
		$(".glanceSummary").toggle(!grouped);
		$(".group-summary").toggle(grouped);
		classification();
	}

	//클릭한 날짜 변수 값에 따라 필터 날짜 변환
	function getDateRangeByValue(valueText){
		let months = 0, days = 0;
		if (valueText.includes("1주일")) days = 7;
		else if (valueText.includes("1개월")) months = 1;
		else if (valueText.includes("3개월")) months = 3;
		else if (valueText.includes("6개월")) months = 6;
		else if (valueText.includes("1년")) months = 12;
		let endDate = new Date();
		let startDate = new Date();
		if (months > 0) startDate.setMonth(startDate.getMonth() - months);
		else if (days > 0) startDate.setDate(startDate.getDate() - days);
		return {
			start: startDate.toISOString().split("T")[0],
			end: endDate.toISOString().split("T")[0],
			months: months
		};
	}

	//검색한 의약품 이름에 따라 토글 사용방식 변환
	function fetchData(opts){
		const isGrouped = $(".toggleSwitch").is(":checked") ? "1" : "0";
		const medicine = $(".medicineTotal").val().trim();
		const data = {
			startDate: opts.startDate,
			endDate: opts.endDate,
			checkedState: isGrouped,
			filterValue: opts.months || 0
		};
		if (medicine !== "") {
			data.medicineTotal = medicine;
			$.post("filterMedicine.jsp", data, function(resp){
				$(".totalSales").html(resp);
				applyView();
			});
		} else {
			$.post("filterSales.jsp", data, function(resp){
				$(".totalSales").html(resp);
				applyView();
			});
		}
	}

	$(".medicineTotal").on("keydown", function(e){
		if(e.key !== "Enter") return;
		e.preventDefault();
		const selected = $(".filterSelect").val() || "1개월";
		const range = getDateRangeByValue(selected);
		$(".startSales").val(range.start);
		$(".endSales").val(range.end);
		fetchData({startDate: range.start, endDate: range.end, months: range.months});
	});

	$(".dateBtnfilter").on("click", function(){
		$(".filterSelect").removeClass("filterSelect");
		$(this).addClass("filterSelect");
		const valueText = $(this).val();
		const range = getDateRangeByValue(valueText);
		$(".startSales").val(range.start);
		$(".endSales").val(range.end);
		fetchData({startDate: range.start, endDate: range.end, months: range.months});
	});

	$(".startSales, .endSales").on("change", function(){
		const start = $(".startSales").val();
		const end = $(".endSales").val();
		if(start && end) fetchData({startDate: start, endDate: end, months: 0});
	});

	$(".toggleSwitch").on("change", function(){
		const start = $(".startSales").val();
		const end = $(".endSales").val();
		if (start && end) fetchData({startDate: start, endDate: end, months: 0});
		$(".filterSelect").click();
	});

	$(".excelDownload").on("click", function(){
		var table = document.querySelector('.salesTable');
		var workbook = XLSX.utils.table_to_book(table, { sheet: "Sheet1" });
		let today = new Date();
		let year = today.getFullYear();
		let month = today.getMonth() + 1;
		let date = today.getDate();
		XLSX.writeFile(workbook, `${year}.${month}.${date}_판매매출현황.xlsx`);
	});

	$(".salesTable").on("mouseover", ".totalSales tr", function(){
		$(".salesTable tr").removeClass("detailTR");
		$(this).addClass("detailTR");
	}).on("mouseout", function(){
		$(".salesTable .totalSales tr").removeClass("detailTR");
	});

	let today = new Date();
	$(".startSales, .endSales").val(today.toISOString().substring(0, 10));
});
</script>

</body>
</html>
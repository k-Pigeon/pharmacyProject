<%@ page language="java" contentType="application/json; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="java.sql.*" %>
<%@ page import="org.json.JSONArray" %>
<%@ page import="org.json.JSONObject" %>
<%@ include file="sessionManager.jsp"%>
<%@ include file="DBconnection.jsp"%>
<%
String dbName = (session != null) ? (String) session.getAttribute("dbName") : null;
String id = (session != null) ? (String) session.getAttribute("id") : null;
String password = (session != null) ? (String) session.getAttribute("password") : null;

if (id == null || dbName == null) {
    response.sendRedirect("login.jsp");
    return;
}

jdbcDriver = dbName;
%>
<%
    String custnumber = request.getParameter("custnumber");  // 클라이언트에서 전달된 고객 번호
    JSONArray resultArray = new JSONArray();
    
    PreparedStatement ps = null;
    ResultSet rs = null;
    
    try {
        // DB 연결
        String query = "SELECT saleDate, price, symptoms FROM SalesData WHERE customer_id = ?";
        ps = conn.prepareStatement(query);
        ps.setString(1, custnumber);
        rs = ps.executeQuery();

        // 결과를 JSON 배열로 변환
        while (rs.next()) {
            JSONObject saleData = new JSONObject();
            saleData.put("saleDate", rs.getString("saleDate"));
            saleData.put("price", rs.getDouble("price"));
            saleData.put("symptoms", rs.getString("symptoms"));
            resultArray.put(saleData);
        }
        
        // JSON 배열 응답
        response.getWriter().write(resultArray.toString());
        
    } catch (Exception e) {
        e.printStackTrace();
        response.getWriter().write("Error: " + e.getMessage());
    } finally {
        try {
            if (rs != null) rs.close();
            if (ps != null) ps.close();
            if (conn != null) conn.close();
        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
%>

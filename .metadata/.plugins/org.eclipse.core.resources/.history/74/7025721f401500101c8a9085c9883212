<%
request.setCharacterEncoding("UTF-8");

BufferedReader reader = request.getReader();
StringBuilder sb = new StringBuilder();
String line;
while ((line = reader.readLine()) != null) {
    sb.append(line);
}

String json = sb.toString();

JsonObject obj = JsonParser.parseString(json).getAsJsonObject();
String medicineName = obj.get("medicineName").getAsString();
JsonArray products = obj.getAsJsonArray("products");

Class.forName("com.mysql.cj.jdbc.Driver");
conn = DriverManager.getConnection(jdbcDriver, dbUser, dbPwd);

// 일단 기존 데이터 삭제 후 재삽입 (또는 UPDATE 방식으로도 가능)
String deleteSql = "DELETE FROM testTable WHERE medicineName = ?";
PreparedStatement deleteStmt = conn.prepareStatement(deleteSql);
deleteStmt.setString(1, medicineName);
deleteStmt.executeUpdate();

String insertSql = "INSERT INTO testTable (medicineName, standard, buyingPrice, price) VALUES (?, ?, ?, ?)";
PreparedStatement insertStmt = conn.prepareStatement(insertSql);

for (int i = 0; i < products.size(); i++) {
    JsonObject product = products.get(i).getAsJsonObject();
    insertStmt.setString(1, medicineName);
    insertStmt.setString(2, product.get("standard").getAsString());
    insertStmt.setDouble(3, product.get("buyingPrice").getAsDouble());
    insertStmt.setDouble(4, product.get("price").getAsDouble());
    insertStmt.executeUpdate();
}

out.print("success");
%>

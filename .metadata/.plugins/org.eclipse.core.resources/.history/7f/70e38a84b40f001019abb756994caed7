    data-inventory='<%= rs.getString("inventory") %>'
    data-kind='<%= rs.getString("kind") %>'
    data-serialnumber='<%= rs.getString("serialNumber") %>'
    data-receiptdate='<%= rs.getString("receiptDate") %>'

<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ page import="java.sql.*, javax.servlet.http.*, javax.servlet.*"%>
<%@ include file="DBconnection.jsp" %>
<%
request.setCharacterEncoding("UTF-8");

String userId   = request.getParameter("userId");
String password = request.getParameter("password");
String isAjax   = request.getParameter("ajax");

String idSortation = "";
String role = "";

/* =====================================================
   1️⃣ 실행 환경 판별 (로컬 / 운영)
   ===================================================== */
String serverName = request.getServerName();
boolean isLocal = serverName.equals("localhost") || serverName.equals("127.0.0.1");

/* =====================================================
   2️⃣ DB 접속 정보 (환경 기준)
   ===================================================== */
String jdbcDriver;
String dbUser;
String dbPwd;

if (isLocal) {
    // 🔹 로컬 개발 환경
    jdbcDriver = "jdbc:mysql://localhost:3306/tutorial?useUnicode=true&characterEncoding=utf8";
    dbUser = "root";
    dbPwd  = "pharmacy@1234";
} else {
    // 🔹 Cafe24 운영 환경
    jdbcDriver = "jdbc:mysql://rlawldls04171.cafe24.com:3306/rlawldls04171?useUnicode=true&characterEncoding=utf8";
    dbUser = "rlawldls04171";
    dbPwd  = "jikim@136464790";
}

conn = null;
PreparedStatement pstmt = null;
ResultSet rs = null;

try {
    Class.forName("com.mysql.cj.jdbc.Driver");

    /* =====================================================
       3️⃣ DB 연결
       ===================================================== */
    conn = DriverManager.getConnection(jdbcDriver, dbUser, dbPwd);

    /* =====================================================
       4️⃣ 로그인 검증
       ===================================================== */
    String sql = "SELECT userId FROM users WHERE userId = ? AND password = ?";
    pstmt = conn.prepareStatement(sql);
    pstmt.setString(1, userId);
    pstmt.setString(2, password);

    rs = pstmt.executeQuery();

    if (!rs.next()) {
        // 로그인 실패
        if ("true".equals(isAjax)) {
            out.print("fail");
        } else {
            response.sendRedirect("login.jsp?error=fail");
        }
        return;
    }

    String userIdInt = rs.getString("userId");

    /* =====================================================
       5️⃣ 권한 판별
       ===================================================== */
    if ("D".equals(userIdInt)) {
        role = "admin";
    } else {
        role = "user";
    }

    /* =====================================================
       6️⃣ 회원 구분
       ===================================================== */
    if ("E".equals(userIdInt)) {
        idSortation = "2";
    }

    /* =====================================================
       7️⃣ 세션 저장 (DB 정보 포함)
       ===================================================== */
    session.setAttribute("dbName", jdbcDriver);
    session.setAttribute("id", dbUser);
    session.setAttribute("password", dbPwd);
    session.setAttribute("programID", userIdInt);
    session.setAttribute("idSortation", idSortation);
    session.setAttribute("role", role);

    /* =====================================================
       8️⃣ 응답 분기
       ===================================================== */
    if ("true".equals(isAjax)) {
        out.print(role);   // admin / user
    } else {
        response.sendRedirect("index2.jsp");
    }

} catch (Exception e) {
    e.printStackTrace();
    response.sendError(500, "로그인 처리 중 서버 오류");
} finally {
    if (rs != null)    try { rs.close(); } catch (Exception ignored) {}
    if (pstmt != null) try { pstmt.close(); } catch (Exception ignored) {}
}
%>
<%@ include file="DBclose.jsp" %>
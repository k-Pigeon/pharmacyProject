<%!
/** 날짜 문자열을 YYYY-MM-DD 형태로 변환 */
private String formatDate(String inputDate) {
    try {
        if (inputDate == null || inputDate.trim().isEmpty()) return null;
        if (inputDate.contains("-")) return inputDate;

        String[] parts = inputDate.split("[/.-]");
        if (parts.length != 3) throw new IllegalArgumentException("잘못된 날짜 형식: " + inputDate);

        int year = Integer.parseInt(parts[0]);
        if (year < 100) year += 2000;

        String month = String.format("%02d", Integer.parseInt(parts[1]));
        String day = String.format("%02d", Integer.parseInt(parts[2]));

        return year + "-" + month + "-" + day;
    } catch (Exception e) {
        System.err.println("날짜 변환 오류: " + inputDate + " → " + e.getMessage());
        return inputDate;
    }
}
%>

<%
request.setCharacterEncoding("UTF-8");
String idSortation = (session != null) ? (String) session.getAttribute("idSortation") : null;

StringBuilder sb = new StringBuilder();
String line;
BufferedReader reader = request.getReader();
while ((line = reader.readLine()) != null) sb.append(line);

try {
    JSONObject data = new JSONObject(sb.toString());
    conn.setAutoCommit(false);

    for (String key : data.keySet()) {
        JSONObject row = data.getJSONObject(key);

        // key = "medicineName|DeliveryDate|standard"
        String[] parts = key.split("\\|");
        if (parts.length < 3) continue;

        String medicineName = parts[0];
        String deliveryDate = formatDate(parts[1]); // ✅ 바로 변환
        String standard = parts[2];

        // ======== inventory 계산 처리 ========
        if (row.has("inventory")) {
            try {
                double inv = Double.parseDouble(row.getString("inventory"));
                double factor = 1.0;

                if (standard != null && !standard.trim().isEmpty()) {
                    Matcher m = Pattern.compile("\\d+(\\.\\d+)?").matcher(standard);
                    int count = 0;
                    while (m.find()) {
                        factor *= Double.parseDouble(m.group());
                        count++;
                        if (count >= 2) break;
                    }
                }

                double newInv = inv * factor;
                row.put("inventory", String.valueOf(newInv));
            } catch (Exception ex) {
                ex.printStackTrace();
            }
        }

        // ======== receiptDate 변환 (row 내부 값) ========
        if (row.has("receiptDate")) {
            String formatted = formatDate(row.getString("receiptDate"));
            row.put("receiptDate", formatted);
        }

        // ======== SQL 생성 및 실행 ========
        StringBuilder sql = new StringBuilder("UPDATE testTable" + idSortation + " SET ");
        List<String> cols = new ArrayList<>();
        for (String col : row.keySet()) cols.add(col + "=?");
        sql.append(String.join(",", cols));
        sql.append(" WHERE medicineName=? AND DeliveryDate=? AND standard=?");

        PreparedStatement pstmt = conn.prepareStatement(sql.toString());
        int i = 1;
        for (String col : row.keySet()) pstmt.setString(i++, row.getString(col));
        pstmt.setString(i++, medicineName);
        pstmt.setString(i++, deliveryDate);
        pstmt.setString(i, standard);

        pstmt.executeUpdate();
        pstmt.close();
    }

    conn.commit();
    conn.setAutoCommit(true);
    out.print("{\"status\":\"success\"}");
} catch (Exception e) {
    conn.rollback();
    e.printStackTrace();
    out.print("{\"status\":\"error\",\"message\":\"" + e.getMessage() + "\"}");
}
%>

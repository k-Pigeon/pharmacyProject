	private String fmtDate(String s) {
		try {
			if (s == null)
				return null;
			s = s.trim().replace('T', ' ');
			if (s.isEmpty() || "null".equalsIgnoreCase(s) || "undefined".equalsIgnoreCase(s))
				return null;
			if (s.matches("\\d{4}-\\d{2}-\\d{2}\\s+\\d{2}:\\d{2}:\\d{2}"))
				return s;
			if (s.matches("\\d{4}-\\d{2}-\\d{2}"))
				return s + " 00:00:00";
			if (s.matches("\\d{2,4}/\\d{1,2}/\\d{1,2}")) {
				String[] p = s.split("/");
				int y = Integer.parseInt(p[0]);
				int m = Integer.parseInt(p[1]);
				int d = Integer.parseInt(p[2]);
				if (y < 100)
					y += 2000;
				return String.format("%04d-%02d-%02d 00:00:00", y, m, d);
			}
		} catch (Exception ignore) {
		}
		return null;
	}

	/** saleDate 충돌 시 1ms 증가하여 유니크하게 보정 */
	private Timestamp ensureUniqueSaleTs(Connection conn, String idSortation, Timestamp baseTs) throws SQLException {
		final String sql1 = "SELECT 1 FROM SalesRecord" + idSortation + " WHERE saleDate=? LIMIT 1";
		final String sql2 = "SELECT 1 FROM priceRecord" + idSortation + " WHERE saleDate=? LIMIT 1";
		final String sql3 = "SELECT 1 FROM discountedDB WHERE sale_date=? LIMIT 1";
		Timestamp ts = baseTs;
		while (true) {
			boolean used = false;
			try (PreparedStatement ps = conn.prepareStatement(sql1)) {
				ps.setTimestamp(1, ts);
				try (ResultSet rs = ps.executeQuery()) {
					if (rs.next())
						used = true;
				}
			}
			if (!used) {
				try (PreparedStatement ps = conn.prepareStatement(sql2)) {
					ps.setTimestamp(1, ts);
					try (ResultSet rs = ps.executeQuery()) {
						if (rs.next())
							used = true;
					}
				}
			}
			if (!used) {
				try (PreparedStatement ps = conn.prepareStatement(sql3)) {
					ps.setTimestamp(1, ts);
					try (ResultSet rs = ps.executeQuery()) {
						if (rs.next())
							used = true;
					}
				}
			}
			if (!used)
				break;
			ts = new Timestamp(ts.getTime() + 1);
		}
		return ts;
	}

	private double parseFactor(String standard) {
		if (standard == null)
			return 1.0;
		Matcher m = Pattern.compile("\\d+(?:\\.\\d+)?").matcher(standard);
		double prod = 1.0;
		boolean found = false;
		while (m.find()) {
			found = true;
			prod *= Double.parseDouble(m.group());
		}
		return found ? (prod > 0 ? prod : 1.0) : 1.0;
	}

	/** 지정된 세트명이 productSet 테이블에 존재하는지 */
	private boolean isProductSet(Connection conn, String setName) throws SQLException {
		String q = "SELECT 1 FROM productSet WHERE setName=? LIMIT 1";
		try (PreparedStatement ps = conn.prepareStatement(q)) {
			ps.setString(1, setName);
			try (ResultSet rs = ps.executeQuery()) {
				return rs.next();
			}
		}
	}

	/** productSet 구성품 기준 FIFO 차감: (판매수량 * standard곱) */
	private void deductByProductSet(Connection conn, String idSortation, String setName, double qtySale)
			throws SQLException {
		String detailQ = "SELECT psd.medicineName, psd.standard " + "FROM productSet_detail psd "
				+ "JOIN productSet ps ON ps.id = psd.productSet_id " + "WHERE ps.setName=?";

		try (PreparedStatement ps = conn.prepareStatement(detailQ)) {
			ps.setString(1, setName);
			try (ResultSet rs = ps.executeQuery()) {
				boolean any = false;
				while (rs.next()) {
					any = true;
					String innerName = rs.getString("medicineName");
					if (innerName == null || innerName.trim().isEmpty())
						continue;

					// standard에서 숫자 전부 곱
					double factor = parseFactor(rs.getString("standard"));

					// 최종 차감량 = 판매수량 * factor
					fifoDeductByName(conn, idSortation, innerName, qtySale, factor);
				}
				if (!any) {
					throw new SQLException("productSet 구성품이 없습니다: " + setName);
				}
			}
		}
	}

	/** regularSet 조인으로 한 번에 차감(세트 수량 * 구성품 inventory) */
	/** regularSet: (판매수량 * 구성품수량 * standard factor) 만큼 FIFO 차감 */
	private void deductByRegularSetLoopFIFO(Connection conn, String idSortation, String setName, double qtySale)
			throws SQLException {
		final String sel = "SELECT medicineName, COALESCE(inventory, 1) AS inv, standard "
				+ "FROM regularSet WHERE setName=?";

		try (PreparedStatement ps = conn.prepareStatement(sel)) {
			ps.setString(1, setName);
			try (ResultSet rs = ps.executeQuery()) {
				boolean any = false;
				while (rs.next()) {
					any = true;
					String med = rs.getString("medicineName");
					if (med == null || med.trim().isEmpty())
						continue;

					double inv = rs.getDouble("inv"); // DB의 구성품 수량
					double factor = parseFactor(rs.getString("standard")); // "2x3" 등 → 배수

					double compQty = qtySale * inv; // "넘어온 inventory * DB inventory"
					// standard는 FIFO 함수의 factor 인자로 전달하여 DB 단위로 환산
					fifoDeductByName(conn, idSortation, med, compQty, factor);
				}
				if (!any) {
					throw new SQLException("regularSet 구성품이 없습니다: " + setName);
				}
			}
		}
	}

	/** FIFO: 이름 기준 차감(standard factor 반영) */
	private void fifoDeductByName(Connection conn, String idSortation, String medName, double qtySale, double factor)
			throws SQLException {
		String sel = "SELECT DeliveryDate, inventory FROM testTable" + idSortation
				+ " WHERE medicineName=? AND returnInv='0' AND inventory>0 ORDER BY DeliveryDate ASC LIMIT 1";
		String upd = "UPDATE testTable" + idSortation
				+ " SET inventory = inventory - ? WHERE medicineName=? AND DeliveryDate=? AND returnInv='0'";
		double remain = qtySale;
		double unit = (factor > 0) ? factor : 1.0;

		while (remain > 1e-9) {
			String dDate = null;
			double stock = 0.0;
			try (PreparedStatement ps = conn.prepareStatement(sel)) {
				ps.setString(1, medName);
				try (ResultSet rs = ps.executeQuery()) {
					if (!rs.next())
						throw new SQLException("재고 부족(이름기준): " + medName);
					dDate = rs.getString("DeliveryDate");
					stock = rs.getDouble("inventory");
				}
			}
			if (stock <= 1e-9)
				throw new SQLException("재고 0 행 발견: " + medName);

			double needDb = remain * unit; // DB 저장 단위로 환산
			double useDb = Math.min(needDb, stock);

			try (PreparedStatement ps = conn.prepareStatement(upd)) {
				ps.setDouble(1, useDb);
				ps.setString(2, medName);
				ps.setString(3, dDate);
				int a = ps.executeUpdate();
				if (a == 0)
					throw new SQLException("차감 실패(이름기준): " + medName);
			}
			remain -= (useDb / unit);
		}
	}

	/** FIFO: 시리얼+이름 기준 차감(standard factor 반영) */
	private void fifoDeductBySerial(Connection conn, String idSortation, String serial, String medName, double qtySale,
			double factor) throws SQLException {
		String sel = "SELECT DeliveryDate, inventory FROM testTable" + idSortation
				+ " WHERE SerialNumber=? AND medicineName=? AND returnInv='0' AND inventory>0 ORDER BY DeliveryDate ASC LIMIT 1";
		String upd = "UPDATE testTable" + idSortation
				+ " SET inventory = inventory - ? WHERE medicineName=? AND DeliveryDate=? AND returnInv='0'";
		double remain = qtySale;
		double unit = (factor > 0) ? factor : 1.0;

		while (remain > 1e-9) {
			String dDate = null;
			double stock = 0.0;
			try (PreparedStatement ps = conn.prepareStatement(sel)) {
				ps.setString(1, serial);
				ps.setString(2, medName);
				try (ResultSet rs = ps.executeQuery()) {
					if (!rs.next())
						throw new SQLException("재고 부족(시리얼기준): " + medName + " / " + serial);
					dDate = rs.getString("DeliveryDate");
					stock = rs.getDouble("inventory");
				}
			}
			if (stock <= 1e-9)
				throw new SQLException("재고 0 행 발견: " + medName + " / " + serial);

			double needDb = remain * unit;
			double useDb = Math.min(needDb, stock);

			try (PreparedStatement ps = conn.prepareStatement(upd)) {
				ps.setDouble(1, useDb);
				ps.setString(2, medName);
				ps.setString(3, dDate);
				int a = ps.executeUpdate();
				if (a == 0)
					throw new SQLException("차감 실패(시리얼기준): " + medName + " / " + serial);
			}
			remain -= (useDb / unit);
		}

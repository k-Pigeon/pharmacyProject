			            // л°ӣм•„мҳЁ лҚ°мқҙн„°лЎң н…Ңмқҙлё”мқ„ мұ„мҡ°кё°
			            data.forEach(function(item) {
			                var newRow = "<tr class='insertTR'>";
			                newRow += "<td><input type='text' name='medicineName[]' class='medicineName' autocomplete='off' value='" + item.medicine_name + "'></td>";
			                newRow += "<td><input type='text' name='inventory[]' class='inventory' autocomplete='off' oninput='updateTotalPrice(this)' value='" + item.inventory + "'></td>";
			                newRow += "<td><input type='text' name='standard[]' class='standard' autocomplete='off' value='" + item.standard + "'></td>";
			                newRow += "<td><input type='text' name='price[]' class='price' autocomplete='off' oninput='updateTotalPrice(this)' value='" + item.price + "'></td>";
			                newRow += "<td><input type='text' name='totalPrice' class='totalPrice' autocomplete='off' value='" + item.total_price + "'></td>";
			                newRow += "</tr>";
			                $(".copyTable .registrationData").prepend(newRow); // н…Ңмқҙлё”м—җ м¶”к°Җ
			            });
			        },
			        error: function(xhr, status, error) {
			            console.log("Error: " + error);
			        }
			    });
			});

		    // к°Ғ н–үмқҳ totalPrice кі„мӮ° н•ЁмҲҳ
		    function updateTotalPrice(row) {
		        var price = parseFloat($(row).find(".price").val());
		        var inventory = parseFloat($(row).find(".inventory").val());

		        if (!isNaN(price) && !isNaN(inventory)) {
		            var totalPrice = price * inventory;
		            $(row).find(".totalPrice").val(totalPrice.toFixed(0));  // мҶҢмҲҳм җ 2мһҗлҰ¬лЎң л°ҳмҳҒ
		        } else {
		            $(row).find(".totalPrice").val('');  // мң нҡЁн•ҳм§Җ м•Ҡмңјл©ҙ л№Ҳ к°’
		        }
		    }
		    
		    $("input[value='л“ұлЎқ [F11]']").click(function() {
		        var customerId = $(".custnumber").val(); // кі к°қлІҲнҳё


		            const rows = $("#popup-content .result-row");

		            if (e.key === "ArrowDown") { // вҶ“ нӮӨ
		                e.preventDefault();
		                if (currentRowIndex < rows.length - 1) {
		                    currentRowIndex++;
		                }
		            } else if (e.key === "ArrowUp") { // вҶ‘ нӮӨ
		                e.preventDefault();
		                if (currentRowIndex > 0) {
		                    currentRowIndex--;
		                }
		            } else if (e.key === "Enter" && currentRowIndex >= 0) { // Enter нӮӨлЎң м„ нғқлҗң н–ү мІҳлҰ¬
		                e.preventDefault();
		                const selectedRow = $(rows[currentRowIndex]); // нҳ„мһ¬ к°•мЎ°лҗң н–ү
		                populateFields(selectedRow.data()); // м„ нғқлҗң лҚ°мқҙн„° мұ„мҡ°кё°
		            }

		            // к°•мЎ° нҡЁкіј м—…лҚ°мқҙнҠё
		            rows.removeClass("highlight"); // лӘЁл“  н–үмқҳ к°•мЎ° м ңкұ°
		            if (currentRowIndex >= 0) {
		                $(rows[currentRowIndex]).addClass("highlight"); // нҳ„мһ¬ м„ нғқлҗң н–үм—җ к°•мЎ° м¶”к°Җ
		            }
		        }
		    });

		 // мһ…л Ҙ н•„л“ңм—җ лҚ°мқҙн„° мұ„мҡ°кё°
		    function populateFields(data) {
		        // нҳ„мһ¬ м„ нғқлҗң н–үм—җл§Ң к°’ мұ„мҡ°кё°
		        currentRow.find(".medicineName").val(data.medicinename);
		        currentRow.find(".companyName").val(data.companyname);
		        currentRow.find(".standard").val(data.standard);
		        currentRow.find(".kind").val(data.kind);
		        currentRow.find(".inventory").val("1"); // кё°ліё мҲҳлҹү 1
		        currentRow.find(".SerialNumber").val(data.serialnumber);
		        currentRow.find(".DeliveryDate").val(data.deliverydate);
		        currentRow.find(".Buyingprice").val(data.buyingprice);
		        currentRow.find(".price").val(data.price);

		        // рҹ”№ totalPrice мһҗлҸҷ кі„мӮ° м¶”к°Җ
		        let inventory = parseFloat(currentRow.find(".inventory").val()) || 0;
		        let price = parseFloat(currentRow.find(".price").val()) || 0;
		        currentRow.find(".totalPrice").val(inventory * price); // кі„мӮ° нӣ„ мһ…л Ҙ

		        $("#popup").hide(); // нҢқм—… мҲЁкё°кё°
		        currentRow.find(".DeliveryDate").focus(); // мһ…л Ҙ н•„л“ңм—җ нҸ¬м»ӨмҠӨ мқҙлҸҷ
		    }
		});
	</script>
</body>

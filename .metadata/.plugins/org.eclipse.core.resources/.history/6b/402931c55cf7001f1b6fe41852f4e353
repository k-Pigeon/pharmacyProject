		    let currentRowIndex = -1; // нҳ„мһ¬ м„ нғқлҗң н–үмқҳ мқёлҚұмҠӨ мҙҲкё°нҷ”
		    let currentRow; // нҳ„мһ¬ м„ нғқлҗң н–үмқ„ м¶”м Ғн•  ліҖмҲҳ м¶”к°Җ
		    // кІҖмғү мһ…л Ҙ мӢң Ajax мҡ”мІӯ
		    $("#section .RegistrationUi .membertable .registrationData").on("keydown", ".insertTR .medicineName", function (e) {

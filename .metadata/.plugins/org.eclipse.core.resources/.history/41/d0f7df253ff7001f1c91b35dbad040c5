<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %>
<%@ page import="java.sql.*, java.util.*" %>

<%
    // DB 연결 설정
    String dbURL = "jdbc:mysql://localhost:3306/your_database"; // 데이터베이스 URL
    String dbUser = "root"; // DB 사용자
    String dbPass = "your_password"; // DB 비밀번호

    Connection conn = null;
    PreparedStatement ps = null;
    ResultSet rs = null;

    try {
        // DB 연결
        Class.forName("com.mysql.cj.jdbc.Driver");
        conn = DriverManager.getConnection(dbURL, dbUser, dbPass);

        // 고객 번호 받기
        String customerId = request.getParameter("custNumber");

        // 판매 테이블에 판매 기록 삽입
        String[] medicineNames = request.getParameterValues("medicineName[]");
        String[] inventories = request.getParameterValues("inventory[]");
        String[] standards = request.getParameterValues("standard[]");
        String[] prices = request.getParameterValues("price[]");
        String[] totalPrices = request.getParameterValues("totalPrice[]");
        
        String saleDate = new java.text.SimpleDateFormat("yyyy-MM-dd").format(new java.util.Date());

        // 약품별로 판매 기록을 삽입
        for (int i = 0; i < medicineNames.length; i++) {
            String medicineName = medicineNames[i];
            String inventory = inventories[i];
            String standard = standards[i];
            String price = prices[i];
            String totalPrice = totalPrices[i];

            // 판매 기록 삽입
            String saleInsertQuery = "INSERT INTO Sales (sale_date, customer_id, medicine_name, inventory, standard, price, total_price) VALUES (?, ?, ?, ?, ?, ?, ?)";
            ps = conn.prepareStatement(saleInsertQuery);
            ps.setString(1, saleDate);
            ps.setString(2, customerId);
            ps.setString(3, medicineName);
            ps.setInt(4, Integer.parseInt(inventory));
            ps.setString(5, standard);
            ps.setDouble(6, Double.parseDouble(price));
            ps.setDouble(7, Double.parseDouble(totalPrice));
            ps.executeUpdate();
        }
        
        out.println("Data inserted successfully.");
    } catch (Exception e) {
        e.printStackTrace();
        out.println("Error: " + e.getMessage());
    } finally {
        try {
            if (rs != null) rs.close();
            if (ps != null) ps.close();
            if (conn != null) conn.close();
        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
%>

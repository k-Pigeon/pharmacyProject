<%
request.setCharacterEncoding("UTF-8");

java.util.Date today = new java.util.Date();
java.sql.Timestamp sqlDate = new java.sql.Timestamp(today.getTime());

PreparedStatement pstmt = null;
PreparedStatement clientpstmt = null;
PreparedStatement ptement = null;
PreparedStatement statement2 = null;
PreparedStatement discountStmt = null;
PreparedStatement statement3 = null;
PreparedStatement statement4 = null;

try {
    conn.setAutoCommit(false);

    StringBuilder sb = new StringBuilder();
    try {
        BufferedReader reader = request.getReader();
        String line;
        while ((line = reader.readLine()) != null) {
            sb.append(line);
        }
    } catch (Exception e) {
        e.printStackTrace();
    }

    JSONArray jsonArray = new JSONArray(sb.toString());

    JSONObject paramObj = jsonArray.getJSONObject(jsonArray.length() - 1);
    String medicinePrice = paramObj.getString("medicinePrice");
    String generalPrice = paramObj.getString("generalPrice");
    String clientName = paramObj.getString("discounted");

    String priceSql = "INSERT INTO priceRecord (saleDate, maxmedicinePrice, generalPrice) VALUES (?, ?, ?)";
    pstmt = conn.prepareStatement(priceSql);
    pstmt.setTimestamp(1, sqlDate);
    pstmt.setString(2, medicinePrice);
    pstmt.setString(3, generalPrice);
    pstmt.executeUpdate();

    String discountSql = "INSERT INTO discountedDB (sale_date, discounted) VALUES (?, ?)";
    discountStmt = conn.prepareStatement(discountSql);
    discountStmt.setTimestamp(1, sqlDate);
    discountStmt.setString(2, clientName);
    discountStmt.executeUpdate();

    for (int i = 0; i < jsonArray.length() - 2; i++) {
        JSONObject obj = jsonArray.getJSONObject(i);
        double inventoryAdjustment = obj.optDouble("inventory", 0.0);
        int price = obj.optInt("price", 0);

        String sortationSQL = "SELECT kind FROM testTable WHERE SerialNumber = ? AND medicineName = ?";
        ptement = conn.prepareStatement(sortationSQL);
        ptement.setString(1, obj.optString("serialNumber", ""));
        ptement.setString(2, obj.optString("medicineName", ""));
        ResultSet rs = ptement.executeQuery();

        String standardSQL = "SELECT REGEXP_REPLACE(?, '[^0-9]', '') AS standard FROM testTable WHERE medicineName = ?";
        statement2 = conn.prepareStatement(standardSQL);
        statement2.setString(1, obj.optString("standard", ""));
        statement2.setString(2, obj.optString("medicineName", ""));
        ResultSet standRS = statement2.executeQuery();

        String NameSQL = "SELECT SUBSTRING(REPLACE(?, ' ', ''), 1, CHAR_LENGTH(REPLACE(?, ' ', '')) - 2) AS Result FROM testTable";
        statement3 = conn.prepareStatement(NameSQL);
        statement3.setString(1, obj.optString("medicineName", ""));
        statement3.setString(2, obj.optString("medicineName", ""));
        ResultSet NameRS = statement3.executeQuery();

        String kind = null, standard = null, medicineName = null;
        if (rs.next()) kind = rs.getString("kind");
        if (standRS.next()) standard = standRS.getString("standard");
        if (NameRS.next()) medicineName = NameRS.getString("Result");

        if ("일반세트".equals(obj.optString("serialNumber", ""))) {
            // 일반세트 처리 생략 (변경 없음)
        } else if ("한약세트".equals(obj.optString("serialNumber", ""))) {
            // 한약세트 처리 생략 (변경 없음)
        } else {
            while (inventoryAdjustment > 0) {
                String selectDateSQL = "SELECT DeliveryDate, inventory FROM testTable WHERE SerialNumber = ? AND medicineName = ? AND returnInv = '0' AND inventory > 0 ORDER BY DeliveryDate ASC LIMIT 1";
                PreparedStatement selectDateStmt = conn.prepareStatement(selectDateSQL);
                selectDateStmt.setString(1, obj.optString("serialNumber", ""));
                selectDateStmt.setString(2, obj.optString("medicineName", ""));
                ResultSet dateRS = selectDateStmt.executeQuery();

                if (!dateRS.next()) break;

                String minDeliveryDate = dateRS.getString("DeliveryDate");
                double availableInventory = dateRS.getDouble("inventory");
                dateRS.close(); selectDateStmt.close();

                double deductedInventory = Math.min(inventoryAdjustment, availableInventory);

                standard = obj.optString("standard", "");
                double standardFactor = 1.0;

                try {
                    Pattern numberPattern = Pattern.compile("\\d+(\\.\\d+)?");
                    Matcher matcher = numberPattern.matcher(standard);
                    double firstNum = 1.0, secondNum = 1.0;
                    int count = 0;
                    while (matcher.find()) {
                        double num = Double.parseDouble(matcher.group());
                        if (count == 0) firstNum = num;
                        else if (count == 1) { secondNum = num; break; }
                        count++;
                    }
                    standardFactor = firstNum * secondNum;
                } catch (Exception e) {
                    standardFactor = 1.0;
                }

                double calculatedInventory = inventoryAdjustment * standardFactor;

                String updateSQL = "UPDATE testTable SET inventory = inventory - (? * ?) WHERE medicineName = ? AND DeliveryDate = ?";
                PreparedStatement updateStmt = conn.prepareStatement(updateSQL);
                updateStmt.setDouble(1, deductedInventory);
                updateStmt.setDouble(2, calculatedInventory);
                updateStmt.setString(3, obj.optString("medicineName", ""));
                updateStmt.setString(4, minDeliveryDate);
                updateStmt.executeUpdate();
                updateStmt.close();

                inventoryAdjustment -= deductedInventory;
            }
        }

        try {
            double inventory = obj.optDouble("inventory", 0.0);
            String standardStr = obj.optString("standard", "");
            double standardValue = inventory;

            try {
                Pattern numberPattern = Pattern.compile("\\d+(\\.\\d+)?");
                Matcher matcher = numberPattern.matcher(standardStr);
                double firstNum = 1.0, secondNum = 1.0;
                int count = 0;
                while (matcher.find()) {
                    double num = Double.parseDouble(matcher.group());
                    if (count == 0) firstNum = num;
                    else if (count == 1) { secondNum = num; break; }
                    count++;
                }
                double factor = firstNum * secondNum;
                standardValue = inventory * factor;
            } catch (Exception e) {
                standardValue = inventory;
            }

            String salesSql = "INSERT INTO SalesRecord (saleDate, medicineName, Buyingprice, price, inventory, SerialNumber, DeliveryDate, standard) VALUES (?, ?, ?, ?, ?, ?, ?, ?)";
            statement4 = conn.prepareStatement(salesSql);
            statement4.setTimestamp(1, sqlDate);
            statement4.setString(2, obj.optString("medicineName", ""));
            statement4.setString(3, obj.optString("Buyingprice", ""));
            statement4.setInt(4, price);
            statement4.setDouble(5, standardValue);
            statement4.setString(6, obj.optString("serialNumber", ""));
            statement4.setString(7, obj.optString("deliveryDate", ""));
            statement4.setString(8, obj.optString("standard", ""));
            statement4.executeUpdate();
        } catch (SQLException e) {
            e.printStackTrace();
            throw new SQLException("Error inserting into SalesRecord: " + e.getMessage());
        }
    }

    conn.commit();
    out.println("{\"result\":\"success\"}");

} catch (Exception e) {
    try {
        if (conn != null) conn.rollback();
    } catch (SQLException rollbackEx) {
        rollbackEx.printStackTrace();
    }
    e.printStackTrace();
    out.println("{\"result\":\"error\", \"message\":\"" + e.getMessage() + "\"}");
} finally {
    try {
        if (pstmt != null) pstmt.close();
        if (clientpstmt != null) clientpstmt.close();
        if (ptement != null) ptement.close();
        if (statement2 != null) statement2.close();
        if (statement3 != null) statement3.close();
        if (conn != null) conn.close();
    } catch (SQLException e) {
        e.printStackTrace();
    }
}

<!DOCTYPE html>
<html>
<head>
<title>에스팜</title>
<style>
#header ul {
	display: block;
}

#wrap #section {
	display: block;
	width: 100%;
	height: 95vh;
	transform: translateY(5vh);
}

#wrap #section h1 {
	text-align: center;
}

#wrap #section .tableWrapper {
	height: 75%;
	overflow-y: auto;
	margin: auto;
	width: 90%;
	border: 1px solid #ccc;
}

#wrap #section .salesTable {
	border-collapse: separate;
	border-spacing: 0;
	width: 100%;
	table-layout: fixed;
}

#wrap #section .salesTable thead th {
	position: sticky;
	top: 0;
	background-color: #6c4ba0;
	z-index: 1;
	color: white;
}

#wrap #section .salesTable th, #wrap #section .salesTable td {
	text-align: center;
	padding: 8px;
	border: 1px solid #ccc;
}

#wrap #section .salesTable td:nth-child(1) {
	background-color: #c6aef0;
	color: white;
}

#wrap #section .salesfilter {
	width: 90%;
	height: 100px;
	margin: 0 auto;
}

#wrap #section .salesfilter .startSales, #wrap #section .salesfilter .endSales
	{
	width: 120px;
	height: 35px;
}

#wrap #section .salesfilter .dateBtn {
	margin-top: 5px;
	width:50%;
}

#wrap #section .salesfilter .dateBtn .dateBtnfilter {
	color: #090909;
	padding: 0.7em 1.7em;
	font-size: 18px;
	border-radius: 0.5em;
	background: #e8e8e8;
	cursor: pointer;
	border: 1px solid #e8e8e8;
	transition: all 0.3s;
	box-shadow: 6px 6px 12px #c5c5c5, -6px -6px 12px #ffffff;
}

#wrap #section .salesfilter .dateBtn .dateBtnfilter:active {
	color: #666;
	box-shadow: inset 4px 4px 12px #c5c5c5, inset -4px -4px 12px #ffffff;
}

#wrap #section .salesfilter .excelDownload {
	position: absolute;
	top: 7%;
	right: 5%;
	font-weight: 600;
	color: white;
	text-transform: uppercase;
	padding: 1em 2em;
	background-color: #00bcd4; /* 시원한 바다색 (cyan 계열) */
	border: 2px solid #008ba3;
	border-radius: 10px;
	cursor: pointer;
	box-shadow: 0 8px 12px rgba(0, 128, 192, 0.3);
	transition: background-color 0.2s ease, transform 0.2s ease;
}

#wrap #section .salesfilter .excelDownload:hover {
	background-color: #008ba3;
	transform: translateY(-2px);
	box-shadow: 0 12px 18px rgba(0, 128, 192, 0.4);
}

#wrap #section .salesfilter .excelDownload:active {
	background-color: #006978;
	transform: translateY(1px);
	box-shadow: 0 4px 8px rgba(0, 128, 192, 0.2);
}

#wrap #section .salesfilter .datePicker .toggleSwitch {
	position: relative;
	top: 5px;
	left: 5%;
	height: 2rem;
	width: 100px;
	cursor: pointer;
	appearance: none;
	-webkit-appearance: none;
	border-radius: 9999px;
	background-color: rgba(100, 116, 139, 0.377);
	transition: all .3s ease;
	left: 5%;
}

#wrap #section .salesfilter .datePicker .toggleSwitch:checked {
	background-color: rgba(236, 72, 153, 1);
}

#wrap #section .salesfilter .datePicker .toggleSwitch::after {
	position: absolute;
	width: 95%;
	content: "일별";
	text-align: center;
}

#wrap #section .salesfilter .datePicker .toggleSwitch::before {
	position: absolute;
	content: "";
	left: -20px;
	top: -7px;
	display: block;
	height: 45px;
	width: 45px;
	cursor: pointer;
	border: 1px solid rgba(100, 116, 139, 0.527);
	border-radius: 9999px;
	background-color: rgba(255, 255, 255, 1);
	box-shadow: 0 3px 10px rgba(100, 116, 139, 0.327);
	transition: all .3s ease;
}

#wrap #section .salesfilter .datePicker .toggleSwitch:checked::before {
	transform: translateX(85px);
	border-color: rgba(236, 72, 153, 1);
}

#wrap #section .salesfilter .datePicker .toggleSwitch:checked::after {
	position: absolute;
	width: 95%;
	content: "월별";
	text-align: center;
}
#wrap .tableWrapper .salesTable .totalSales tr.detailTR{
  position: relative;
  background: linear-gradient(145deg, #2a2a2a, #1a1a1a); /* 은은한 빛 */
  color: #fff;
  transform: translateY(-4px); /* 위로 살짝 떠오름 */
  box-shadow: 0 12px 24px rgba(10px, 10px, 10px, 0.8); /* 입체 그림자 */
  z-index: 10;
  transition: all 0.2s ease-in-out;
  border-radius: 8px;
}
</style>
</head>
<body>
	<div id="wrap" style="display: block;">
		<header>
			<jsp:include page="header.jsp"></jsp:include>
		</header>
		<section id="section">
			<h1>매출</h1>
			<div class="salesfilter">
				<div class="datePicker">
					결재일 : <input type="date" class="startSales"> ~ <input
						type="date" class="endSales"> <input class="toggleSwitch"
						type="checkbox" checked>
				</div>
				<div class="dateBtn">
					<input type="button" class="dateBtnfilter week" value="1주일">
					<input type="button" class="dateBtnfilter month" value="1개월">
					<input type="button" class="dateBtnfilter 3month" value="3개월">
					<input type="button" class="dateBtnfilter 6month" value="6개월">
					<input type="button" class="dateBtnfilter 1year" value="1년">
					<input type="text" class="medicineTotal" placeholder="제품명 입력">
				</div>
				
				<button type="button" class="excelDownload">Excel 다운로드</button>
			</div>
			<div class="tableWrapper">
				<table class="salesTable">
					<thead>
						<tr>
							<th>날짜</th>
							<th>판매액</th>
							<th>사입가</th>
							<th>마진</th>
							<th>마진률</th>
						</tr>
					</thead>
					<tbody class="totalSales">

					</tbody>
				</table>
			</div>
		</section>
	</div>
	<script src="jquery-3.7.1.min.js"></script>
	<script
		src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
	<script src="script.js"></script>
	<script>
    $(function () {
        /* =============== 전역 유틸 =============== */
        const fmt = d => d.toISOString().split("T")[0];

        function classification () {
          $(".salesTable tbody tr:visible").each(function (idx) {
            $(this).css("background-color", idx % 2 ? "#bbb" : "#ddd");
          });
        }

        function applyView () {
          const grouped     = $(".toggleSwitch").is(":checked");
          $(".glanceSummary").toggle(!grouped);
          $(".group-summary").toggle(grouped);
          classification();
        }

        /* =============== 기간 버튼 =============== */
        $(document).on("click", ".dateBtnfilter", function () {
          $(".dateBtnfilter.filterSelect").removeClass("filterSelect");
          $(this).addClass("filterSelect");

          const label = $(this).val();
          let months = 0, days = 0;
          if (label === "1주일") days = 7;
          else if (label === "1개월") months = 1;
          else if (label === "3개월") months = 3;
          else if (label === "6개월") months = 6;
          else if (label === "1년")  months = 12;

          const end   = new Date();
          const start = new Date();
          if (months) end.setMonth(end.getMonth() - months);
          if (days)   end.setDate (end.getDate()  - days);

          $(".startSales").val(fmt(start));
          $(".endSales").val(fmt(end)).trigger("change");

          /* 기간만 바꾼 경우 전체 매출 조회 */
          $.post("filterSales.jsp", { filterValue: months || -days })
            .done(resp => { $(".totalSales").html(resp); applyView(); })
            .fail(xhr => alert("기간 필터 실패: " + xhr.status));
        });

        /* =============== 제품 검색 (Enter) =============== */
        $(document).on("keyup", ".medicineTotal", function (e) {
          if (e.key !== "Enter") return;
          const medicine = this.value.trim();
          if (!medicine) return alert("제품명을 입력하세요.");

          const sel = $(".dateBtnfilter.filterSelect").val() || "1개월"; // 기본
          let months = 0; if (sel !== "1주일") months = parseInt(sel);

          $.post("filterMedicine.jsp", {
            medicineTotal: medicine,
            startDate: $(".startSales").val(),
            endDate  : $(".endSales").val(),
            checkedState: $(".toggleSwitch").is(":checked") ? "1" : "0",
            filterValue : months
          })
          .done(resp => { $(".totalSales").html(resp); applyView(); })
          .fail(xhr => alert("제품 필터 실패: " + xhr.status));
        });

        /* 실시간 입력 변화 시 뷰만 갱신 */
        $(document).on("input", ".medicineTotal", applyView);

        /* =============== 날짜 직접 변경 =============== */
        $(document).on("change", ".startSales, .endSales", function () {
          const s = $(".startSales").val();
          const e = $(".endSales").val();
          if (!s || !e) return;
          $.post("filterDate.jsp", { startDate: s, endDate: e, checkedState: $(".toggleSwitch").is(":checked") ? "1" : "0" })
            .done(resp => { $(".totalSales").html(resp); applyView(); })
            .fail(xhr => alert("날짜 필터 실패: " + xhr.status));
        });

        /* =============== 토글 스위치 =============== */
        $(document).on("change", ".toggleSwitch", function () {
          // 소폭 날짜 변화를 줘서 서버측 캐싱 회피(원 코드 로직 유지)
          const $s = $(".startSales"), $e = $(".endSales");
          const os = new Date($s.val()), oe = new Date($e.val());
          os.setDate(os.getDate() - 1); oe.setDate(oe.getDate() - 1);
          $s.val(fmt(os)); $e.val(fmt(oe));
          setTimeout(() => { $s.val(fmt(new Date(os.getTime()+86400000))); $e.val(fmt(new Date(oe.getTime()+86400000))); $s.trigger("change"); }, 100);
          applyView();
        });

        /* =============== 초기 상태 =============== */
        const today = new Date();
        $(".startSales, .endSales").val(fmt(today));

        /* =============== Excel 다운로드 =============== */
        $(document).on("click", ".excelDownload", function () {
          const wb = XLSX.utils.table_to_book(document.querySelector(".salesTable"), { sheet: "Sheet1" });
          const d  = new Date(); const file = `${d.getFullYear()}.${d.getMonth()+1}.${d.getDate()}_판매매출현황.xlsx`;
          XLSX.writeFile(wb, file);
        });
      });
    </script>
	</script>
</body>
</html>
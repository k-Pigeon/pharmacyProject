<%@ page language="java" contentType="application/json; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="java.io.BufferedReader" %>
<%@ page import="java.io.FileInputStream" %>
<%@ page import="java.io.InputStreamReader" %>
<%@ page import="java.io.IOException" %>
<%@ page import="org.json.JSONObject" %>

<%
	request.setCharacterEncoding("UTF-8");
    // 클라이언트에서 전달된 고객 번호
    String custnumber = request.getParameter("custnumber");
    System.out.println("Received custnumber: " + custnumber);  // 고객 번호 출력 (디버깅)

    // CSV 파일 경로
    String csvFilePath = getServletContext().getRealPath("/DB백업.csv");  // CSV 파일 경로
    BufferedReader br = null;
    String line;
    JSONObject responseJson = new JSONObject();
    boolean found = false;

    try {
        // CSV 파일을 UTF-8로 읽기 위해 InputStreamReader 사용
        FileInputStream fis = new FileInputStream(csvFilePath);
        InputStreamReader isr = new InputStreamReader(fis, "UTF-8");
        br = new BufferedReader(isr);
        
        // 첫 번째 행을 읽고, 두 번째 행부터 비교
        int rowIndex = 1; // 첫 번째 행은 건너뜁니다.
        while ((line = br.readLine()) != null) {
            String[] data = line.split(",");  // 쉼표로 구분된 데이터를 배열로 나눔

            // 각 행에서 받은 데이터를 출력하여 확인
            //System.out.println("Read line: " + line);  // 읽은 행 출력 (디버깅)
            System.out.println("First column value: " + data[0]);  // 첫 번째 열 값 출력 (디버깅)

            // 데이터가 두 개 이상일 경우에만 진행
            if (data.length >= 2) {
                String rowNumber = data[0].trim();  // 첫 번째 열 (고객 번호)
                String memo = data[1].trim();  // 두 번째 열 (메모)
                
                // 고객 번호가 일치하면 해당 메모를 JSON으로 반환
                if (rowNumber.equals(custnumber)) {
                    responseJson.put("rowNumber", rowNumber);
                    responseJson.put("memo", memo);
                    found = true;
                    break;
                }
            }
        }

        // 고객 번호를 찾지 못한 경우 오류 메시지 추가
        if (!found) {
            responseJson.put("error", "고객 번호를 찾을 수 없습니다.");
        }
    } catch (IOException e) {
        e.printStackTrace();
        responseJson.put("error", "파일을 읽는 도중 오류가 발생했습니다.");
    } finally {
        try {
            if (br != null) {
                br.close();  // 리소스 해제
            }
        } catch (IOException e) {
            e.printStackTrace();
        }
    }

    // 응답으로 JSON 객체를 반환
    response.setContentType("application/json; charset=UTF-8");
    response.getWriter().write(responseJson.toString());
%>

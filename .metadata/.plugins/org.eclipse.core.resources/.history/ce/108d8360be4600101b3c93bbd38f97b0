				<%
        try {
            // SQL 쿼리 실행 (LIKE 검색)
            String query = " SELECT SerialNumber, medicineName, inventory, "
                         + " DeliveryDate, receiptDate, kind, Buyingprice, price, companyName, standard"
                         + " FROM testTable WHERE medicineName LIKE ?";
            pstmt = conn.prepareStatement(query);
            pstmt.setString(1, "%" + medicineName + "%");
            rs = pstmt.executeQuery();

            // 검색 결과 출력
            while (rs.next()) {
                String serialNumber = rs.getString("SerialNumber");
                String medicineNames = rs.getString("medicineName");
                String deliveryDate = rs.getString("DeliveryDate");
                String receiptDate = rs.getString("receiptDate");
                String kind = rs.getString("kind");
                String buyingPrice = rs.getString("Buyingprice");
                String price = rs.getString("price");
                String companyName = rs.getString("companyName");
                String standard = rs.getString("standard");

                double inventory = rs.getDouble("inventory"); // 원래 inventory 값
                double calculatedInventory = inventory; // 기본적으로 inventory 유지

                // 🔹 standard 값에 따라 inventory 조정
                if (standard != null && !standard.trim().isEmpty()) {
                    if (standard.contains("g") || standard.contains("포")) {
                        // "ml", "g", "포" 포함된 경우 → inventory 그대로 유지
                        calculatedInventory = inventory;
                    } else {
                        String[] parts = standard.split(" "); // 공백으로 나누기
                        double standardValue = 1.0; // 기본값

                        try {
                            if (parts.length == 2) { 
                                // 예: "20g 4포" → 20 * 4
                                double num1 = Double.parseDouble(parts[0].replaceAll("[^0-9]", ""));
                                double num2 = Double.parseDouble(parts[1].replaceAll("[^0-9]", ""));
                                standardValue = num1 * num2;
                            } else if (parts.length == 1) {
                                // 숫자 하나만 있는 경우
                                standardValue = Double.parseDouble(standard.replaceAll("[^0-9]", ""));
                            }

                            if (standardValue > 0) {
                                calculatedInventory = inventory / standardValue;
                            }
                        } catch (NumberFormatException e) {
                            System.err.println("NumberFormatException 발생: " + e.getMessage());
                            calculatedInventory = inventory; // 변환 실패 시 원래 값 유지
                        }
                    }
                }
    %>

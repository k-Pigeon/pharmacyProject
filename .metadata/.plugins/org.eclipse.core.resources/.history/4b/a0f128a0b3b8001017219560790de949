<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="java.io.*, java.util.*, java.sql.*, org.json.*, java.util.regex.*" %>
<%@ include file="sessionManager.jsp"%>
<%@ include file="DBconnection.jsp"%>

<%
String dbName = (session != null) ? (String) session.getAttribute("dbName") : null;
String id = (session != null) ? (String) session.getAttribute("id") : null;
String idSortation = (session != null) ? (String) session.getAttribute("idSortation") : null;

if (id == null || dbName == null) {
    response.sendRedirect("login.jsp");
    return;
}
request.setCharacterEncoding("UTF-8");
boolean prevAutoCommit = conn.getAutoCommit();
conn.setAutoCommit(false);

JSONArray warnList = new JSONArray();

try {
    // ----- 재고 부족 데이터 수집 (예시로 testTable 기준) -----
    String sql = "SELECT medicineName, quantity, inventory, standard FROM testTable" + idSortation + " WHERE returnInv='0'";
    try (PreparedStatement pstmt = conn.prepareStatement(sql); ResultSet rs = pstmt.executeQuery()) {
        while (rs.next()) {
            String name = rs.getString("medicineName");
            double inv = rs.getDouble("inventory");
            double qty = rs.getDouble("quantity");
            String std = rs.getString("standard");

            // 표준계수 계산
            double standardFactor = 1.0;
            try {
                Matcher m = Pattern.compile("\\d+(\\.\\d+)?").matcher(std == null ? "" : std);
                List<Double> nums = new ArrayList<>();
                while (m.find()) nums.add(Double.parseDouble(m.group()));
                if (nums.size() >= 2) {
                    standardFactor = nums.get(0) * nums.get(1);
                } else if (nums.size() == 1) {
                    standardFactor = nums.get(0);
                }
            } catch (Exception e) {}

            double realInv = inv / standardFactor;
            realInv = Math.round(realInv * 100.0) / 100.0;

            if (realInv < qty) {
                JSONObject warn = new JSONObject();
                warn.put("medicineName", name);
                warn.put("standard", std);
                warn.put("realInv", realInv);
                warn.put("quantity", qty);
                warnList.put(warn);
            }
        }
    }

    conn.commit();
} catch (Exception e) {
    e.printStackTrace();
    if (conn != null) try { conn.rollback(); } catch (SQLException ignore) {}
} finally {
    try { conn.setAutoCommit(prevAutoCommit); } catch (SQLException ignore) {}
}
%>

<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<title>재고 부족 경고</title>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<style>
body {
    font-family: "Noto Sans KR", sans-serif;
    background-color: #f9f9f9;
    padding: 40px;
}
h2 { color: #cc0000; }

#warningBox {
    position: fixed;
    right: 25px;
    bottom: -400px;
    background: #fff8f8;
    border: 1px solid #ffb3b3;
    border-radius: 12px;
    width: 360px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    padding: 20px;
    opacity: 0;
    transition: all 0.6s ease;
}
#warningBox.show {
    bottom: 25px;
    opacity: 1;
}
#warningList div {
    background: #fff;
    border-left: 4px solid #ff6666;
    border-radius: 6px;
    margin-bottom: 10px;
    padding: 8px;
}
#warningList b { color: #333; }
#warningList span { color: #d60000; font-weight: bold; }
#closeWarning {
    background: #d60000;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 5px 10px;
    margin-top: 10px;
    float: right;
    cursor: pointer;
}
#closeWarning:hover { background: #b30000; }
</style>
</head>

<body>
<h2>⚠ 재고 부족 자동 감지 시스템</h2>
<p>아래는 현재 재고가 부족한 품목 목록입니다.</p>

<div id="warningBox">
    <h3>⚠ 재고 부족 경고</h3>
    <div id="warningList"></div>
    <button id="closeWarning">닫기</button>
    <div style="clear:both;"></div>
</div>

<script>
const warnings = <%= warnList.toString() %>;

function showWarnings(list) {
    const box = $("#warningBox");
    const wrap = $("#warningList");
    wrap.empty();

    if (!list || list.length === 0) {
        wrap.append("<div>✅ 모든 재고가 충분합니다.</div>");
        box.addClass("show");
        setTimeout(() => box.removeClass("show"), 5000);
        return;
    }

    list.forEach(w => {
        wrap.append(`
            <div>
                <b>${w.medicineName}</b> (${w.standard})<br>
                남은 재고: <span>${w.realInv}</span> / 필요 수량: ${w.quantity}
            </div>
        `);
    });

    box.addClass("show");
    setTimeout(() => box.removeClass("show"), 8000);
}

$("#closeWarning").click(() => $("#warningBox").removeClass("show"));
$(document).ready(() => showWarnings(warnings));
</script>

</body>
</html>

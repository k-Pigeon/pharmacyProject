<%@ page contentType="application/json; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="java.io.*, java.sql.*, org.json.*, java.util.*" %>
<%@ include file="sessionManager.jsp" %>
<%@ include file="DBconnection.jsp" %>

<%
request.setCharacterEncoding("UTF-8");
StringBuilder sb = new StringBuilder();
String line;
BufferedReader reader = request.getReader();
while ((line = reader.readLine()) != null) sb.append(line);

try {
    JSONObject data = new JSONObject(sb.toString());
    conn.setAutoCommit(false);

    for (String key : data.keySet()) {
        JSONObject row = data.getJSONObject(key);

        // key = "medicineName|DeliveryDate|standard"
        String[] parts = key.split("\\|");
        if (parts.length < 3) continue;
        String medicineName = parts[0];
        String deliveryDate = parts[1];
        String standard = parts[2];

        StringBuilder sql = new StringBuilder("UPDATE testTable" + idSortation + " SET ");
        List<String> cols = new ArrayList<>();
        for (String col : row.keySet()) cols.add(col + "=?");
        sql.append(String.join(",", cols));
        sql.append(" WHERE medicineName=? AND DeliveryDate=? AND standard=?");

        PreparedStatement pstmt = conn.prepareStatement(sql.toString());
        int i = 1;
        for (String col : row.keySet()) pstmt.setString(i++, row.getString(col));
        pstmt.setString(i++, medicineName);
        pstmt.setString(i++, deliveryDate);
        pstmt.setString(i, standard);

        pstmt.executeUpdate();
        pstmt.close();
    }

    conn.commit();
    conn.setAutoCommit(true);
    out.print("{\"status\":\"success\"}");
} catch (Exception e) {
    conn.rollback();
    e.printStackTrace();
    out.print("{\"status\":\"error\",\"message\":\"" + e.getMessage() + "\"}");
}
%>
